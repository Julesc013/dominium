{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Base Dimension Schema",
  "version": "1.0.0",
  "description": "Canonical base dimension declaration.",
  "x-doc-ref": [
    "docs/materials/UNITS_AND_DIMENSIONS.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "base_dimension_id",
    "description",
    "version_introduced",
    "deprecated",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "base_dimension_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version_introduced": {
      "type": "string",
      "minLength": 1
    },
    "deprecated": {
      "type": "boolean"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
