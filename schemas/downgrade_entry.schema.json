{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Downgrade Entry Schema",
  "version": "1.0.0",
  "description": "Deterministic downgrade entry for control negotiation axes.",
  "x-doc-ref": [
    "docs/control/CONTROL_PLANE_CONSTITUTION.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "downgrade_id",
    "axis",
    "from_value",
    "to_value",
    "reason_code",
    "remediation_hint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "downgrade_id": {
      "type": "string",
      "minLength": 1
    },
    "axis": {
      "type": "string",
      "enum": [
        "abstraction",
        "fidelity",
        "view",
        "epistemic",
        "budget"
      ]
    },
    "from_value": {
      "type": "string",
      "minLength": 1
    },
    "to_value": {
      "type": "string",
      "minLength": 1
    },
    "reason_code": {
      "type": "string",
      "minLength": 1
    },
    "remediation_hint": {
      "type": "string",
      "minLength": 1
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "downgrade_id": "downgrade.01",
      "axis": "fidelity",
      "from_value": "micro",
      "to_value": "meso",
      "reason_code": "downgrade.budget_insufficient",
      "remediation_hint": "remedy.ctrl.increase_budget_or_reduce_scope",
      "extensions": {}
    }
  ]
}
