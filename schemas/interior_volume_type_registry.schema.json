{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Interior Volume Type Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic interior volume type registry output.",
  "x-doc-ref": [
    "docs/interior/INTERIOR_VOLUME_MODEL.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "volume_types",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "volume_types": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "volume_type_id",
          "description",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "volume_type_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  }
}
