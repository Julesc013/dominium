{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Repro Bundle Manifest Schema",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "schema_version",
    "bundle_version",
    "created_by_product_id",
    "build_id",
    "seed",
    "session_id",
    "session_template_id",
    "contract_bundle_hash",
    "semantic_contract_registry_hash",
    "pack_lock_hash",
    "overlay_manifest_hash",
    "proof_anchor_count",
    "canonical_event_count",
    "log_event_count",
    "view_fingerprint_count",
    "proof_window_hash",
    "canonical_event_hash",
    "log_window_hash",
    "environment_summary",
    "included_artifacts",
    "bundle_hash",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "bundle_version": { "type": "string", "const": "1.0.0" },
    "created_by_product_id": { "type": "string", "minLength": 1 },
    "build_id": { "type": "string" },
    "seed": { "type": "string" },
    "session_id": { "type": "string" },
    "session_template_id": { "type": "string" },
    "contract_bundle_hash": { "type": "string" },
    "semantic_contract_registry_hash": { "type": "string" },
    "pack_lock_hash": { "type": "string" },
    "overlay_manifest_hash": { "type": "string" },
    "proof_anchor_count": { "type": "integer", "minimum": 0 },
    "canonical_event_count": { "type": "integer", "minimum": 0 },
    "log_event_count": { "type": "integer", "minimum": 0 },
    "view_fingerprint_count": { "type": "integer", "minimum": 0 },
    "proof_window_hash": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "canonical_event_hash": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "log_window_hash": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "environment_summary": { "type": "object", "additionalProperties": true },
    "included_artifacts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "bundle_hash": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "deterministic_fingerprint": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "extensions": { "type": "object", "additionalProperties": true }
  }
}
