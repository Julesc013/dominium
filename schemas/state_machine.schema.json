{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "State Machine Schema",
  "version": "1.0.0",
  "description": "Deterministic process-triggered state machine component.",
  "x-doc-ref": [
    "docs/architecture/CORE_ABSTRACTIONS.md",
    "docs/architecture/BEHAVIORAL_COMPONENTS_STANDARD.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "machine_id",
    "machine_type_id",
    "state_id",
    "transitions",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "machine_id": {
      "type": "string",
      "minLength": 1
    },
    "machine_type_id": {
      "type": "string",
      "minLength": 1
    },
    "state_id": {
      "type": "string",
      "minLength": 1
    },
    "transitions": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "required": [
              "transition_id",
              "from_state_id",
              "to_state_id",
              "trigger_process_id",
              "priority",
              "extensions"
            ],
            "additionalProperties": false,
            "properties": {
              "transition_id": {
                "type": "string",
                "minLength": 1
              },
              "from_state_id": {
                "type": "string",
                "minLength": 1
              },
              "to_state_id": {
                "type": "string",
                "minLength": 1
              },
              "trigger_process_id": {
                "type": "string",
                "minLength": 1
              },
              "priority": {
                "type": "integer"
              },
              "guard_conditions": {
                "type": "object",
                "additionalProperties": true
              },
              "extensions": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        ]
      }
    },
    "transition_rows": {
      "type": "array",
      "items": {
        "$ref": "state_transition.schema.json"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "machine_id": "state_machine.door.alpha",
      "machine_type_id": "state_machine.door",
      "state_id": "closed",
      "transitions": [
        "door.open"
      ],
      "transition_rows": [
        {
          "schema_version": "1.0.0",
          "transition_id": "door.open",
          "from_state": "closed",
          "to_state": "open",
          "trigger_process_id": "process.door_open",
          "guard_conditions": {},
          "priority": 10,
          "extensions": {}
        }
      ],
      "extensions": {}
    }
  ]
}
