{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "State Machine Schema",
  "version": "1.0.0",
  "description": "Deterministic process-triggered state machine component.",
  "x-doc-ref": [
    "docs/architecture/CORE_ABSTRACTIONS.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "machine_id",
    "machine_type_id",
    "state_id",
    "transitions",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "machine_id": {
      "type": "string",
      "minLength": 1
    },
    "machine_type_id": {
      "type": "string",
      "minLength": 1
    },
    "state_id": {
      "type": "string",
      "minLength": 1
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "transition_id",
          "from_state_id",
          "to_state_id",
          "trigger_process_id",
          "priority",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "transition_id": {
            "type": "string",
            "minLength": 1
          },
          "from_state_id": {
            "type": "string",
            "minLength": 1
          },
          "to_state_id": {
            "type": "string",
            "minLength": 1
          },
          "trigger_process_id": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "integer"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "machine_id": "state_machine.door.alpha",
      "machine_type_id": "state_machine.door",
      "state_id": "closed",
      "transitions": [
        {
          "transition_id": "door.open",
          "from_state_id": "closed",
          "to_state_id": "open",
          "trigger_process_id": "process.door_open",
          "priority": 10,
          "extensions": {}
        }
      ],
      "extensions": {}
    }
  ]
}

