{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tier Taxonomy Schema",
  "version": "1.0.0",
  "description": "Deterministic fidelity tier taxonomy contract.",
  "x-doc-ref": [
    "docs/reality/UNIVERSE_PHYSICS_PROFILE.md",
    "docs/canon/constitution_v1.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "taxonomy_id",
    "tiers",
    "collapse_required_invariants",
    "expand_redaction_rules",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "taxonomy_id": {
      "type": "string",
      "minLength": 1
    },
    "tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "collapse_required_invariants": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "expand_redaction_rules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "taxonomy_id": "default_minimal",
      "tiers": [
        "macro",
        "render"
      ],
      "collapse_required_invariants": [
        "inv.population_conservation"
      ],
      "expand_redaction_rules": [
        "redact.identity.default"
      ],
      "extensions": {}
    }
  ]
}
