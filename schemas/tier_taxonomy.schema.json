{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tier Taxonomy Schema",
  "version": "1.0.0",
  "description": "Deterministic fidelity tier taxonomy contract.",
  "x-doc-ref": [
    "docs/reality/TIER_TAXONOMY_AND_TRANSITIONS.md",
    "docs/canon/constitution_v1.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "taxonomy_id",
    "tiers",
    "allowed_transitions",
    "default_transition_policy_id",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "taxonomy_id": {
      "type": "string",
      "minLength": 1
    },
    "tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "allowed_transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from_tier",
          "to_tier"
        ],
        "additionalProperties": false,
        "properties": {
          "from_tier": {
            "type": "string",
            "minLength": 1
          },
          "to_tier": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "default_transition_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "taxonomy_id": "tiers.standard",
      "tiers": [
        "macro",
        "meso",
        "micro",
        "render"
      ],
      "allowed_transitions": [
        {
          "from_tier": "macro",
          "to_tier": "meso"
        },
        {
          "from_tier": "macro",
          "to_tier": "micro"
        },
        {
          "from_tier": "meso",
          "to_tier": "micro"
        },
        {
          "from_tier": "micro",
          "to_tier": "meso"
        },
        {
          "from_tier": "micro",
          "to_tier": "macro"
        },
        {
          "from_tier": "meso",
          "to_tier": "macro"
        }
      ],
      "default_transition_policy_id": "transition.policy.default_realistic",
      "extensions": {}
    }
  ]
}
