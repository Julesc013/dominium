{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "View Policy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic camera view policy registry output.",
  "x-doc-ref": [
    "docs/audit/VIEW_EPISTEMIC_CONTROL_BASELINE.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "view_policies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "view_policies": {
      "type": "array",
      "items": {
        "$ref": "view_policy.schema.json"
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "view_policies": [],
      "registry_hash": "ce3095e6fdc7082d20539df3f97bf21b1594f0ca2f1e98243f7b8c8ae4e669f2"
    }
  ]
}
