{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DT Quantization Rule Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic registry output for dt quantization rules.",
  "x-doc-ref": [
    "docs/reality/TIME_CONSTITUTION.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "rules",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "dt_rule_id",
          "allowed_dt_values",
          "default_dt",
          "deterministic_rounding_rule",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "dt_rule_id": {
            "type": "string"
          },
          "allowed_dt_values": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "integer",
              "minimum": 1
            }
          },
          "default_dt": {
            "type": "integer",
            "minimum": 1
          },
          "deterministic_rounding_rule": {
            "type": "string"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  }
}
