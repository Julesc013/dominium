      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "agent_id",
          "state_hash"
        ],
        "additionalProperties": false,
        "properties": {
          "agent_id": {
            "type": "string"
          },
          "state_hash": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
