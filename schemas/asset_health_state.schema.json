{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Asset Health State Schema",
  "version": "1.0.0",
  "description": "Canonical deterministic asset health state payload.",
  "x-doc-ref": [
    "docs/materials/DECAY_FAILURE_MAINTENANCE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "asset_id",
    "failure_mode_ids",
    "accumulated_wear",
    "maintenance_backlog",
    "last_inspection_tick",
    "last_maintenance_tick",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "asset_id": {
      "type": "string",
      "minLength": 1
    },
    "failure_mode_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "accumulated_wear": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "hazard_state": {
      "type": "object",
      "additionalProperties": true
    },
    "maintenance_backlog": {
      "type": "integer",
      "minimum": 0
    },
    "last_inspection_tick": {
      "type": "integer",
      "minimum": 0
    },
    "last_maintenance_tick": {
      "type": "integer",
      "minimum": 0
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "accumulated_wear": {},
      "asset_id": "asset_id.example",
      "extensions": {},
      "failure_mode_ids": [],
      "last_inspection_tick": 0,
      "last_maintenance_tick": 0,
      "maintenance_backlog": 0,
      "schema_version": "1.0.0"
    }
  ]
}
