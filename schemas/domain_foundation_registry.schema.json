{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Domain Foundation Registry Schema",
  "version": "1.0.0",
  "description": "Structural domain taxonomy registry used for domain/solver/contract governance.",
  "x-doc-ref": [
    "docs/scale/DOMAIN_MODEL.md",
    "docs/scale/DOMAIN_REGISTRY.md",
    "schema/scale/domain_registry.schema"
  ],
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "records"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "dominium.registry.domain_registry"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "domain_id",
          "human_name",
          "description",
          "scope_tags",
          "required_capabilities",
          "provided_capabilities",
          "fields_declared",
          "processes_declared",
          "solver_kinds_allowed",
          "contract_ids",
          "status",
          "version_introduced",
          "deprecated",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "domain_id": {
            "type": "string",
            "pattern": "^dom\\.domain\\.[a-z0-9_.-]+$"
          },
          "human_name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "scope_tags": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "macro",
                "system",
                "body",
                "region",
                "local"
              ]
            }
          },
          "required_capabilities": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "provided_capabilities": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "fields_declared": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "processes_declared": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "solver_kinds_allowed": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "macro_capsule",
                "coarse",
                "refined",
                "micro"
              ]
            }
          },
          "contract_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^dom\\.contract\\.[a-z0-9_.-]+$"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "experimental",
              "deprecated"
            ]
          },
          "version_introduced": {
            "type": "integer",
            "minimum": 1
          },
          "deprecated": {
            "type": "boolean"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "examples": [
    {
      "schema_id": "dominium.registry.domain_registry",
      "schema_version": "1.0.0",
      "records": [
        {
          "domain_id": "dom.domain.gravity.macro",
          "human_name": "Gravity Macro",
          "description": "Coarse gravitational field orchestration for macro capsules.",
          "scope_tags": [
            "macro",
            "system"
          ],
          "required_capabilities": [
            "capability.observation.gravity"
          ],
          "provided_capabilities": [
            "capability.domain.gravity.macro"
          ],
          "fields_declared": [
            "field.gravity.vector"
          ],
          "processes_declared": [
            "process.region_management_tick"
          ],
          "solver_kinds_allowed": [
            "macro_capsule",
            "coarse"
          ],
          "contract_ids": [
            "dom.contract.mass_conservation",
            "dom.contract.deterministic_transition"
          ],
          "status": "active",
          "version_introduced": 1,
          "deprecated": false,
          "extensions": {}
        }
      ]
    }
  ]
}
