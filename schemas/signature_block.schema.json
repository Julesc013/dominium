{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Signature Block Schema",
  "version": "1.0.0",
  "description": "Deterministic additive signature hook for RELEASE-2 detached or inline verification.",
  "type": "object",
  "required": [
    "signature_id",
    "signer_id",
    "signed_hash",
    "signature_bytes",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "signature_id": {
      "type": "string",
      "minLength": 1
    },
    "signer_id": {
      "type": "string",
      "minLength": 1
    },
    "signed_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "signature_bytes": {
      "type": "string",
      "minLength": 1
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
