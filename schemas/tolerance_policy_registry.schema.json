{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tolerance Policy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic SPEC-1 tolerance policy registry output.",
  "x-doc-ref": [
    "docs/specs/SPECSHEET_CONSTITUTION.md",
    "docs/architecture/registry_compile.md",
    "schemas/tolerance_policy.schema.json"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "tolerance_policies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "tolerance_policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "tolerance_policy_id",
          "description",
          "numeric_tolerances",
          "rounding_rules",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "tolerance_policy_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "numeric_tolerances": {
            "type": "object",
            "additionalProperties": {
              "type": [
                "integer",
                "number"
              ]
            }
          },
          "rounding_rules": {
            "type": "object",
            "additionalProperties": true
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "tolerance_policies": [],
      "registry_hash": "f7f4b4cfaaf5e7c6ad2e46bc04f04f0b8f4db22844fcd8ac7ddc44506e8c9a0f"
    }
  ]
}
