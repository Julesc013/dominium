{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Machine Type Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic machine type registry output.",
  "x-doc-ref": [
    "docs/interaction/MACHINE_PORTS.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "machine_types",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "machine_types": {
      "type": "array",
      "items": {
        "$ref": "machine_type.schema.json"
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  }
}