{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Core Constraint Type Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic core constraint type registry output.",
  "x-doc-ref": [
    "docs/architecture/CORE_ABSTRACTIONS.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "constraint_types",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "constraint_types": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "constraint_type_id",
          "description",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "constraint_type_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "constraint_types": [],
      "registry_hash": "30de5d77d5f38e4f1738517900293752a7d9a4ff2f9a6f8fe314f0f4af8f7d2b"
    }
  ]
}

