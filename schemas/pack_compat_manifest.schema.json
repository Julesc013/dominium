{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pack Compatibility Manifest Schema",
  "version": "1.0.0",
  "description": "Deterministic compatibility metadata sidecar for pack loading, offline verification, and pack-lock identity.",
  "type": "object",
  "required": [
    "schema_version",
    "pack_id",
    "pack_version",
    "trust_level_id",
    "capability_ids",
    "required_contract_ranges",
    "required_registry_ids",
    "degrade_mode_id",
    "migration_refs",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "pack_version": {
      "type": "string",
      "minLength": 1
    },
    "trust_level_id": {
      "type": "string",
      "minLength": 1
    },
    "capability_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_contract_ranges": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "min_version": {
            "type": "string"
          },
          "max_version": {
            "type": "string"
          },
          "exact_version": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "required_protocol_ranges": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "min_version": {
            "type": "string"
          },
          "max_version": {
            "type": "string"
          },
          "exact_version": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "supported_engine_version_range": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "integer",
          "boolean",
          "null"
        ]
      }
    },
    "required_registry_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "provides": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "degrade_mode_id": {
      "type": "string",
      "minLength": 1
    },
    "migration_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
