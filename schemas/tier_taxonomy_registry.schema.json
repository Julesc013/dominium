{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tier Taxonomy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic tier taxonomy registry output.",
  "x-doc-ref": [
    "docs/reality/UNIVERSE_PHYSICS_PROFILE.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "taxonomies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "taxonomies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "taxonomy_id",
          "tiers",
          "collapse_required_invariants",
          "expand_redaction_rules",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "taxonomy_id": {
            "type": "string"
          },
          "tiers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "collapse_required_invariants": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expand_redaction_rules": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  }
}
