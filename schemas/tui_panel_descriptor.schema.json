{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TUI Panel Descriptor Schema",
  "version": "1.0.0",
  "description": "Deterministic AppShell TUI panel descriptor.",
  "type": "object",
  "required": [
    "schema_version",
    "panel_id",
    "product_id",
    "title",
    "position_hint",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "panel_id": {
      "type": "string",
      "minLength": 1
    },
    "product_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "position_hint": {
      "type": "string",
      "minLength": 1
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
