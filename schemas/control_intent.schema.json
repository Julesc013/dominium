{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Control Intent Schema",
  "version": "1.0.0",
  "description": "Deterministic CTRL-1 control request payload.",
  "x-doc-ref": [
    "docs/control/CONTROL_PLANE_CONSTITUTION.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "control_intent_id",
    "requester_subject_id",
    "target_kind",
    "target_id",
    "requested_action_id",
    "parameters",
    "request_vector",
    "created_tick",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "control_intent_id": {
      "type": "string",
      "minLength": 1
    },
    "requester_subject_id": {
      "type": "string",
      "minLength": 1
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "surface",
        "pose_slot",
        "mount_point",
        "machine",
        "structure",
        "graph",
        "none"
      ]
    },
    "target_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "requested_action_id": {
      "type": "string",
      "minLength": 1
    },
    "parameters": {
      "type": "object",
      "additionalProperties": true
    },
    "request_vector": {
      "type": "object",
      "required": [
        "abstraction_level_requested",
        "fidelity_requested",
        "view_requested",
        "inspection_requested",
        "reenactment_requested"
      ],
      "additionalProperties": false,
      "properties": {
        "abstraction_level_requested": {
          "type": "string",
          "enum": [
            "AL0",
            "AL1",
            "AL2",
            "AL3",
            "AL4"
          ]
        },
        "fidelity_requested": {
          "type": "string",
          "enum": [
            "macro",
            "meso",
            "micro"
          ]
        },
        "view_requested": {
          "type": "string",
          "minLength": 1
        },
        "inspection_requested": {
          "type": "string",
          "enum": [
            "none",
            "macro",
            "meso",
            "micro"
          ]
        },
        "reenactment_requested": {
          "type": "string",
          "enum": [
            "none",
            "macro",
            "meso",
            "micro"
          ]
        }
      }
    },
    "created_tick": {
      "type": "integer",
      "minimum": 0
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "control_intent_id": "control.intent.f6f9ca5b0b9ad85472fbe57a",
      "requester_subject_id": "agent.alpha",
      "target_kind": "surface",
      "target_id": "assembly.machine.alpha",
      "requested_action_id": "action.surface.execute_task",
      "parameters": {
        "process_id": "process.machine_operate",
        "inputs": {
          "machine_id": "machine.alpha"
        }
      },
      "request_vector": {
        "abstraction_level_requested": "AL0",
        "fidelity_requested": "meso",
        "view_requested": "view.mode.first_person",
        "inspection_requested": "none",
        "reenactment_requested": "none"
      },
      "created_tick": 0,
      "deterministic_fingerprint": "5d4eb4d3fba6604d5f73de2bf1329e84d788aa7c2f8f3118e9ab07f90677353f",
      "extensions": {}
    }
  ]
}
