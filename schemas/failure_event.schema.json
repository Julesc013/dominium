{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Failure Event Schema",
  "version": "1.0.0",
  "description": "Canonical deterministic failure event payload.",
  "x-doc-ref": [
    "docs/materials/DECAY_FAILURE_MAINTENANCE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "tick",
    "asset_id",
    "failure_mode_id",
    "severity",
    "consequences",
    "provenance_event_id",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "tick": {
      "type": "integer",
      "minimum": 0
    },
    "asset_id": {
      "type": "string",
      "minLength": 1
    },
    "failure_mode_id": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "integer",
      "minimum": 0
    },
    "consequences": {
      "type": "object",
      "additionalProperties": true
    },
    "provenance_event_id": {
      "type": "string",
      "minLength": 1
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
