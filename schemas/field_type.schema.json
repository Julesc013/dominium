{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Field Type Schema",
  "version": "1.0.0",
  "description": "Deterministic FIELD-1 field type declaration.",
  "x-doc-ref": [
    "docs/fields/FIELD_LAYER_MODEL.md",
    "docs/audit/FIELD_LAYER_BASELINE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "field_type_id",
    "description",
    "value_kind",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "field_type_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "value_kind": {
      "type": "string",
      "enum": ["scalar", "vector"]
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "field_type_id": "field.temperature",
      "description": "Ambient temperature field.",
      "value_kind": "scalar",
      "extensions": {}
    }
  ]
}
