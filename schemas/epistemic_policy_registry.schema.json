{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Epistemic Policy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic epistemic policy registry output.",
  "x-doc-ref": [
    "docs/net/EPISTEMIC_SCOPE_AND_FOG_OF_WAR.md",
    "docs/net/EPISTEMICS_OVER_NETWORK.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "policies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "epistemic_policy_id",
          "description",
          "allowed_observation_channels",
          "forbidden_channels",
          "retention_policy_id",
          "inference_policy_id",
          "max_precision_rules",
          "deterministic_filters",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "epistemic_policy_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "allowed_observation_channels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "forbidden_channels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "retention_policy_id": {
            "type": "string"
          },
          "inference_policy_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "max_precision_rules": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "rule_id",
                "channel_id",
                "max_distance_mm",
                "position_quantization_mm",
                "orientation_quantization_mdeg"
              ],
              "additionalProperties": false,
              "properties": {
                "rule_id": {
                  "type": "string"
                },
                "channel_id": {
                  "type": "string"
                },
                "max_distance_mm": {
                  "type": "integer",
                  "minimum": 0
                },
                "position_quantization_mm": {
                  "type": "integer",
                  "minimum": 1
                },
                "orientation_quantization_mdeg": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          },
          "deterministic_filters": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "max_inspection_level": {
            "type": "string",
            "enum": [
              "macro",
              "meso",
              "micro"
            ]
          },
          "max_reenactment_level": {
            "type": "string",
            "enum": [
              "macro",
              "meso",
              "micro"
            ]
          },
          "redaction_rules": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "rule_id",
                "channel_pattern",
                "redaction_mode"
              ],
              "additionalProperties": false,
              "properties": {
                "rule_id": {
                  "type": "string"
                },
                "channel_pattern": {
                  "type": "string"
                },
                "redaction_mode": {
                  "type": "string",
                  "enum": [
                    "none",
                    "coarse",
                    "diegetic",
                    "masked"
                  ]
                }
              }
            }
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [
        {
          "pack_id": "law.lab.unrestricted",
          "version": "1.0.0",
          "canonical_hash": "placeholder.law.lab.unrestricted.v1",
          "signature_status": "signed"
        }
      ],
      "policies": [
        {
          "epistemic_policy_id": "ep.policy.lab_broad",
          "description": "Broad deterministic lab observation policy.",
          "allowed_observation_channels": [
            "ch.diegetic.clock",
            "ch.nondiegetic.nav"
          ],
          "forbidden_channels": [],
          "retention_policy_id": "ep.retention.session_basic",
          "inference_policy_id": null,
          "max_precision_rules": [
            {
              "rule_id": "precision.near.default",
              "channel_id": "ch.nondiegetic.nav",
              "max_distance_mm": 500000,
              "position_quantization_mm": 1,
              "orientation_quantization_mdeg": 1
            }
          ],
          "deterministic_filters": [
            "filter.channel_allow_deny",
            "filter.quantize_precision",
            "filter.redact_forbidden"
          ],
          "max_inspection_level": "meso",
          "max_reenactment_level": "meso",
          "redaction_rules": [
            {
              "rule_id": "redact.example.truth",
              "channel_pattern": "ch.truth.overlay.*",
              "redaction_mode": "masked"
            }
          ],
          "extensions": {}
        }
      ],
      "registry_hash": "26e4dd6ed6ca8df4c8fc5d77e513fb9cc66f0959e425db165716469aca7f2272"
    }
  ]
}
