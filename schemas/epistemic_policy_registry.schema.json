{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Epistemic Policy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic epistemic policy registry output.",
  "x-doc-ref": [
    "docs/net/EPISTEMIC_SCOPE_AND_FOG_OF_WAR.md",
    "docs/net/EPISTEMICS_OVER_NETWORK.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "policies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "epistemic_policy_id",
          "description",
          "allowed_observation_channels",
          "forbidden_channels",
          "retention_policy_id",
          "inference_policy_id",
          "max_precision_rules",
          "deterministic_filters",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "epistemic_policy_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "allowed_observation_channels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "forbidden_channels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "retention_policy_id": {
            "type": "string"
          },
          "inference_policy_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "max_precision_rules": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "rule_id",
                "channel_id",
                "max_distance_mm",
                "position_quantization_mm",
                "orientation_quantization_mdeg"
              ],
              "additionalProperties": false,
              "properties": {
                "rule_id": {
                  "type": "string"
                },
                "channel_id": {
                  "type": "string"
                },
                "max_distance_mm": {
                  "type": "integer",
                  "minimum": 0
                },
                "position_quantization_mm": {
                  "type": "integer",
                  "minimum": 1
                },
                "orientation_quantization_mdeg": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          },
          "deterministic_filters": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  }
}
