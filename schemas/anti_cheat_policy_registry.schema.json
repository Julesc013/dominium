{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Anti-Cheat Policy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic anti-cheat policy registry output.",
  "x-doc-ref": [
    "docs/net/ANTI_CHEAT_POLICY_FRAMEWORK.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "policies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "policy_id",
          "human_name",
          "description",
          "modules_enabled",
          "default_actions",
          "allowed_in_singleplayer",
          "allowed_in_private_server",
          "required_for_ranked",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "policy_id": {
            "type": "string"
          },
          "human_name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "modules_enabled": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "default_actions": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "enum": [
                "audit",
                "refuse",
                "terminate",
                "throttle"
              ]
            }
          },
          "allowed_in_singleplayer": {
            "type": "boolean"
          },
          "allowed_in_private_server": {
            "type": "boolean"
          },
          "required_for_ranked": {
            "type": "boolean"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "policies": [],
      "registry_hash": "cd7f5df1f6cb2faf95a6e15d2094159881f10f219f3d17766bf28f80fdf8fffb"
    }
  ]
}
