{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Calibration Model Schema",
  "version": "1.0.0",
  "description": "Diegetic instrument calibration model contract.",
  "x-doc-ref": [
    "docs/diegetics/DIEGETIC_INSTRUMENT_DOCTRINE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "calibration_model_id",
    "description",
    "model_kind",
    "parameters",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "calibration_model_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "model_kind": {
      "type": "string",
      "enum": [
        "none",
        "quality_linear_stub"
      ]
    },
    "parameters": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "calibration_model_id": "calib.none",
      "description": "No calibration adjustment.",
      "model_kind": "none",
      "parameters": {},
      "extensions": {}
    }
  ]
}
