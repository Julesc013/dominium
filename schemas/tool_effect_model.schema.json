{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tool Effect Model Schema",
  "version": "1.0.0",
  "description": "Deterministic ToolEffect parameter model for process intent pass-through.",
  "x-doc-ref": [
    "docs/interaction/TOOLS_AND_EFFECTS.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "effect_model_id",
    "description",
    "parameters",
    "deterministic_rules",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "effect_model_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "parameters": {
      "type": "object",
      "required": [
        "efficiency_multiplier",
        "precision_level",
        "torque_limit",
        "rate_limit"
      ],
      "additionalProperties": false,
      "properties": {
        "efficiency_multiplier": {
          "type": "integer"
        },
        "precision_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "lab"
          ]
        },
        "torque_limit": {
          "type": [
            "integer",
            "null"
          ]
        },
        "rate_limit": {
          "type": [
            "integer",
            "null"
          ]
        }
      }
    },
    "deterministic_rules": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "effect_model_id": "effect.basic_fastening",
      "description": "Deterministic fastening effect baseline.",
      "parameters": {
        "efficiency_multiplier": 1000,
        "precision_level": "medium",
        "torque_limit": 5000,
        "rate_limit": 1200
      },
      "deterministic_rules": {
        "randomness": "none",
        "rounding_rule": "fixed_point_floor"
      },
      "extensions": {}
    }
  ]
}
