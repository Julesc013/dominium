{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mobility Network Binding Schema",
  "version": "1.0.0",
  "description": "Deterministic MOB-2 binding between formalization and mobility network graph artifacts.",
  "x-doc-ref": [
    "docs/mobility/MOBILITY_NETWORKGRAPH.md",
    "docs/audit/MOBILITY_NETWORK_BASELINE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "binding_id",
    "formalization_id",
    "graph_id",
    "node_ids",
    "edge_ids",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "binding_id": {
      "type": "string",
      "minLength": 1
    },
    "formalization_id": {
      "type": "string",
      "minLength": 1
    },
    "graph_id": {
      "type": "string",
      "minLength": 1
    },
    "node_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "edge_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "binding_id": "binding.mob.net.demo",
      "formalization_id": "formalization.mob.demo",
      "graph_id": "graph.mobility.demo",
      "node_ids": [
        "node.mob.demo.a",
        "node.mob.demo.b"
      ],
      "edge_ids": [
        "edge.mob.demo.ab"
      ],
      "deterministic_fingerprint": "8544e1a8d43a175f6b52218fd470942f0d340261f2551ad8fa8fd3e3f26d29a9",
      "extensions": {}
    }
  ]
}
