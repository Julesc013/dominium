{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Element Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic element registry output.",
  "x-doc-ref": [
    "docs/materials/MATERIAL_TAXONOMY.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "elements",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "element_id",
          "atomic_number",
          "molar_mass_raw",
          "charge_default",
          "base_energy_content_raw",
          "tags",
          "version_introduced",
          "deprecated",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "element_id": {
            "type": "string"
          },
          "atomic_number": {
            "type": [
              "integer",
              "null"
            ]
          },
          "molar_mass_raw": {
            "type": "integer"
          },
          "charge_default": {
            "type": [
              "integer",
              "null"
            ]
          },
          "base_energy_content_raw": {
            "type": [
              "integer",
              "null"
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "version_introduced": {
            "type": "string"
          },
          "deprecated": {
            "type": "boolean"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  }
}
