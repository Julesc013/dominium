{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Command Descriptor Schema",
  "version": "1.0.0",
  "description": "Deterministic AppShell command descriptor.",
  "type": "object",
  "required": [
    "schema_version",
    "command_id",
    "command_path",
    "product_ids",
    "description",
    "supported_mode_ids",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "command_id": {
      "type": "string",
      "minLength": 1
    },
    "command_path": {
      "type": "string",
      "minLength": 1
    },
    "product_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "supported_mode_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
