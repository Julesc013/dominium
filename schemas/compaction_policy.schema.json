{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Compaction Policy Schema",
  "version": "1.0.0",
  "description": "Deterministic RS-3 save compaction policy row.",
  "x-doc-ref": [
    "docs/reality/TIME_CONSTITUTION.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "compaction_policy_id",
    "rules",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "compaction_policy_id": {
      "type": "string"
    },
    "rules": {
      "type": "object",
      "required": [
        "keep_every_nth_checkpoint",
        "merge_intent_logs",
        "prune_old_run_meta"
      ],
      "additionalProperties": true,
      "properties": {
        "keep_every_nth_checkpoint": {
          "type": "integer",
          "minimum": 1
        },
        "merge_intent_logs": {
          "type": "boolean"
        },
        "prune_old_run_meta": {
          "type": "boolean"
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "compaction_policy_id": "compaction.policy.default",
      "rules": {
        "keep_every_nth_checkpoint": 4,
        "merge_intent_logs": true,
        "prune_old_run_meta": true,
        "prune_run_meta_older_than_ticks": 2048
      },
      "extensions": {}
    }
  ]
}
