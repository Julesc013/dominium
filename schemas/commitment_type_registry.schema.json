{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Commitment Type Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic commitment type registry output.",
  "x-doc-ref": [
    "docs/materials/NOTHING_JUST_HAPPENS.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "commitment_types",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {"type": "string"},
          "version": {"type": "string"},
          "canonical_hash": {"type": "string"},
          "signature_status": {"type": "string"}
        }
      }
    },
    "commitment_types": {
      "type": "array",
      "items": {
        "$ref": "commitment_type.schema.json"
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "commitment_types": [],
      "registry_hash": "03a2ce9b6ca26f7e4a828128c6f19e080f15f34e88cab5b938a653f312f73b57"
    }
  ]
}
