{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Construction Event Type Schema",
  "version": "1.0.0",
  "description": "Canonical provenance event type entry payload.",
  "x-doc-ref": [
    "docs/materials/PROVENANCE_EVENTS.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "event_type_id",
    "description",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "event_type_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "description": "example",
      "event_type_id": "event_type_id.example",
      "extensions": {},
      "schema_version": "1.0.0"
    }
  ]
}
