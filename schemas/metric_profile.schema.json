{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Metric Profile Schema",
  "version": "1.0.0",
  "description": "Canonical GEO-0 metric and bounded geodesic contract.",
  "x-doc-ref": [
    "docs/geo/GEO_CONSTITUTION.md",
    "docs/canon/constitution_v1.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "metric_profile_id",
    "metric_kind",
    "parameters",
    "tolerance_policy_id",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "metric_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "metric_kind": {
      "type": "string",
      "enum": [
        "euclidean",
        "spherical_stub",
        "torus_wrap",
        "custom"
      ]
    },
    "parameters": {
      "type": "object",
      "additionalProperties": true
    },
    "tolerance_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "metric_profile_id": "geo.metric.euclidean",
      "metric_kind": "euclidean",
      "parameters": {
        "norm": "l2"
      },
      "tolerance_policy_id": "tol.geo.exact_integer",
      "deterministic_fingerprint": "8b4d16238e4e1d3390c0281f6c1d7fbfb6855b7aeaaef3a0f0c08ed08d59ab79",
      "extensions": {}
    }
  ]
}
