{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stacking Policy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic CTRL-8 stacking policy registry output.",
  "x-doc-ref": [
    "docs/audit/EFFECT_SYSTEM_BASELINE.md",
    "docs/architecture/registry_compile.md",
    "schemas/stacking_policy.schema.json"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "stacking_policies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "stacking_policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "stacking_policy_id",
          "mode",
          "tie_break_rule",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "stacking_policy_id": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "replace",
              "max",
              "min",
              "add",
              "multiply"
            ]
          },
          "tie_break_rule": {
            "type": "string"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "stacking_policies": [],
      "registry_hash": "f7f4b4cfaaf5e7c6ad2e46bc04f04f0b8f4db22844fcd8ac7ddc44506e8c9a0f"
    }
  ]
}
