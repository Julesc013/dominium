{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Control Action Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic control action registry output.",
  "x-doc-ref": [
    "docs/embodiment/CONTROL_SUBSTRATE_DOCTRINE.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "actions",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "action_id",
          "description",
          "required_entitlements",
          "produces_intent_id",
          "payload_schema_id",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "action_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "required_entitlements": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "produces_intent_id": {
            "type": "string"
          },
          "payload_schema_id": {
            "type": "string"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "actions": [],
      "registry_hash": "90a0f3d307e94a17a665f8f8ead7db7f7931d61069b4b0c71f1014ec3e0f7187"
    }
  ]
}
