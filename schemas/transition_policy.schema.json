{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Transition Policy Schema",
  "version": "1.0.0",
  "description": "Deterministic tier transition policy row.",
  "x-doc-ref": [
    "docs/reality/TIER_TAXONOMY_AND_TRANSITIONS.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "transition_policy_id",
    "description",
    "max_micro_regions",
    "max_micro_entities",
    "hysteresis_rules",
    "arbitration_rule_id",
    "degrade_order",
    "refuse_thresholds",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "transition_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "max_micro_regions": {
      "type": "integer",
      "minimum": 0
    },
    "max_micro_entities": {
      "type": "integer",
      "minimum": 0
    },
    "hysteresis_rules": {
      "type": "object",
      "additionalProperties": true
    },
    "arbitration_rule_id": {
      "type": "string",
      "minLength": 1
    },
    "degrade_order": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "refuse_thresholds": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "transition_policy_id": "transition.policy.default_realistic",
      "description": "Default deterministic transition policy.",
      "max_micro_regions": 128,
      "max_micro_entities": 100000,
      "hysteresis_rules": {
        "min_transition_interval_ticks": 0
      },
      "arbitration_rule_id": "arb.priority_by_distance",
      "degrade_order": [
        "fine",
        "medium",
        "coarse"
      ],
      "refuse_thresholds": {
        "max_forced_micro_regions": 512
      },
      "extensions": {}
    }
  ]
}
