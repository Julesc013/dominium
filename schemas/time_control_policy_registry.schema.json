{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Time Control Policy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic registry output for time control policies.",
  "x-doc-ref": [
    "docs/reality/TIME_CONSTITUTION.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "policies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "time_control_policy_id",
          "allow_variable_dt",
          "allow_pause",
          "allow_rate_change",
          "allowed_rate_range",
          "dt_quantization_rule_id",
          "checkpoint_interval_ticks",
          "compaction_policy_id",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "time_control_policy_id": {
            "type": "string"
          },
          "allow_variable_dt": {
            "type": "boolean"
          },
          "allow_pause": {
            "type": "boolean"
          },
          "allow_rate_change": {
            "type": "boolean"
          },
          "allowed_rate_range": {
            "type": "object",
            "required": [
              "min",
              "max"
            ],
            "additionalProperties": false,
            "properties": {
              "min": {
                "type": "integer",
                "minimum": 0
              },
              "max": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "dt_quantization_rule_id": {
            "type": "string"
          },
          "checkpoint_interval_ticks": {
            "type": "integer",
            "minimum": 1
          },
          "compaction_policy_id": {
            "type": "string"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  }
}
