{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Order Schema",
  "version": "1.0.0",
  "description": "Canonical deterministic CIV-3 order assembly record.",
  "x-doc-ref": [
    "docs/civilisation/ORDER_LANGUAGE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "order_id",
    "order_type_id",
    "issuer_subject_id",
    "target_kind",
    "target_id",
    "created_tick",
    "status",
    "priority",
    "payload",
    "required_entitlements",
    "refusal",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "order_id": {
      "type": "string"
    },
    "order_type_id": {
      "type": "string"
    },
    "issuer_subject_id": {
      "type": "string"
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "agent",
        "cohort",
        "faction",
        "territory"
      ]
    },
    "target_id": {
      "type": "string"
    },
    "created_tick": {
      "type": "integer",
      "minimum": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "created",
        "queued",
        "executing",
        "completed",
        "failed",
        "refused"
      ]
    },
    "priority": {
      "type": "integer",
      "minimum": 0
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "required_entitlements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "refusal": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "order_id": "order.a9bd08a9b0c6446e",
      "order_type_id": "order.move",
      "issuer_subject_id": "peer.alpha",
      "target_kind": "cohort",
      "target_id": "cohort.alpha.001",
      "created_tick": 10,
      "status": "queued",
      "priority": 60,
      "payload": {
        "destination": "region.alpha",
        "speed_policy_id": "speed.default"
      },
      "required_entitlements": [
        "entitlement.civ.order"
      ],
      "refusal": null,
      "extensions": {}
    }
  ]
}
