{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reenactment Request Schema",
  "version": "1.0.0",
  "description": "Deterministic reenactment request payload.",
  "x-doc-ref": [
    "docs/materials/REENACTMENT_MODEL.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "request_id",
    "target_id",
    "tick_range",
    "desired_fidelity",
    "max_cost_units",
    "requester_subject_id",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "tick_range": {
      "type": "object",
      "required": [
        "start_tick",
        "end_tick"
      ],
      "additionalProperties": false,
      "properties": {
        "start_tick": {
          "type": "integer",
          "minimum": 0
        },
        "end_tick": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "desired_fidelity": {
      "type": "string",
      "enum": [
        "macro",
        "meso",
        "micro"
      ]
    },
    "max_cost_units": {
      "type": "integer",
      "minimum": 0
    },
    "requester_subject_id": {
      "type": "string",
      "minLength": 1
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
