{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tick T Schema",
  "version": "1.0.0",
  "description": "Canonical unsigned 64-bit tick wrapper for deterministic long-run time validation.",
  "type": "object",
  "required": [
    "schema_version",
    "tick_value",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "tick_value": {
      "type": "integer",
      "minimum": 0,
      "maximum": 18446744073709551615
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "tick_value": 10000,
      "deterministic_fingerprint": "0fe724f2b5fcb455e0eb0ee19312024afd6d9154f6ebb7f80cb9d31c98a30b18",
      "extensions": {}
    }
  ]
}
