{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Force Application Schema",
  "version": "1.0.0",
  "description": "Canonical PHYS-1 process payload for deterministic force-to-momentum mutation.",
  "x-doc-ref": [
    "docs/physics/PHYSICS_CONSTITUTION.md",
    "docs/audit/FORCE_MOMENTUM_BASELINE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "application_id",
    "target_assembly_id",
    "force_vector",
    "duration_ticks",
    "originating_process_id",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "application_id": {
      "type": "string",
      "minLength": 1
    },
    "target_assembly_id": {
      "type": "string",
      "minLength": 1
    },
    "force_vector": {
      "type": "object",
      "required": [
        "x",
        "y",
        "z"
      ],
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        },
        "z": {
          "type": "integer"
        }
      }
    },
    "duration_ticks": {
      "type": "integer",
      "minimum": 1
    },
    "torque": {
      "type": [
        "integer",
        "null"
      ]
    },
    "originating_process_id": {
      "type": "string",
      "minLength": 1
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "application_id": "force.alpha.0001",
      "target_assembly_id": "body.mob.free.alpha",
      "force_vector": {
        "x": 0,
        "y": -9800,
        "z": 0
      },
      "duration_ticks": 1,
      "torque": 0,
      "originating_process_id": "process.apply_force",
      "deterministic_fingerprint": "e00234ce9685b7b95a96ef5a0dfead66f2486f89a0f2c9cb436b45f17e35cdf6",
      "extensions": {}
    }
  ]
}
