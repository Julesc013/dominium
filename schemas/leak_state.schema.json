{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Leak State Schema",
  "version": "1.0.0",
  "description": "Deterministic FLUID leak state row.",
  "x-doc-ref": [
    "docs/fluid/CONTAINMENT_AND_FAILURE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "target_id",
    "leak_rate",
    "active",
    "last_update_tick",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "leak_rate": {
      "type": "integer",
      "minimum": 0
    },
    "active": {
      "type": "boolean"
    },
    "last_update_tick": {
      "type": "integer",
      "minimum": 0
    },
    "deterministic_fingerprint": {
      "type": "string"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "target_id": "edge.pipe.mainline.001",
      "leak_rate": 35,
      "active": true,
      "last_update_tick": 420,
      "deterministic_fingerprint": "95b7d445d58d7e5239377b24f4e83d0c63d9f7d985d8bd93f77e5cd4f642f0ed",
      "extensions": {}
    }
  ]
}
