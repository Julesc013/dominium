{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Causality Strictness Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic causality strictness registry output.",
  "x-doc-ref": [
    "docs/materials/NOTHING_JUST_HAPPENS.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "strictness_levels",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {"type": "string"},
          "version": {"type": "string"},
          "canonical_hash": {"type": "string"},
          "signature_status": {"type": "string"}
        }
      }
    },
    "strictness_levels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "strictness_id",
          "description",
          "commitments_required_for",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "strictness_id": {"type": "string"},
          "description": {"type": "string"},
          "commitments_required_for": {
            "type": "array",
            "items": {"type": "string"}
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "strictness_levels": [],
      "registry_hash": "189f7f0f13092229e2de349f2f84195cb03fbc6abf4f8f96f89701f92de911ec"
    }
  ]
}
