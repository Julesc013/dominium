{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Part Class Schema",
  "version": "1.0.0",
  "description": "Canonical abstract part class declaration.",
  "x-doc-ref": [
    "docs/materials/BOM_AND_ASSEMBLY_GRAPH.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "part_class_id",
    "description",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "part_class_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "default_material_class": {
      "type": [
        "string",
        "null"
      ]
    },
    "default_shape_tag": {
      "type": [
        "string",
        "null"
      ]
    },
    "failure_mode_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "part_class_id": "partclass.example",
      "description": "Example part class.",
      "default_material_class": "material.steel_basic",
      "default_shape_tag": "shape.prism",
      "failure_mode_tags": [
        "failure.example"
      ],
      "extensions": {}
    }
  ]
}
