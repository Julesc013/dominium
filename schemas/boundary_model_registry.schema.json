{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Boundary Model Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic boundary model registry output.",
  "x-doc-ref": [
    "docs/reality/UNIVERSE_PHYSICS_PROFILE.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "boundary_models",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "boundary_models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "boundary_model_id",
          "universe_type",
          "allow_boundary_flux",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "boundary_model_id": {
            "type": "string"
          },
          "universe_type": {
            "type": "string"
          },
          "allow_boundary_flux": {
            "type": "boolean"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  }
}
