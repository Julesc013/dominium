{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AppShell Message Key Registry Schema",
  "version": "1.0.0",
  "type": "object",
  "required": ["schema_version", "registry_id", "messages", "deterministic_fingerprint", "extensions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "registry_id": { "type": "string", "minLength": 1 },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["message_key", "category_id", "description"],
        "additionalProperties": false,
        "properties": {
          "message_key": { "type": "string", "minLength": 1 },
          "category_id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "deterministic_fingerprint": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "extensions": { "type": "object", "additionalProperties": true }
  }
}
