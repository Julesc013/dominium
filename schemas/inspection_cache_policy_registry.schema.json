{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Inspection Cache Policy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic registry output for RS-5 inspection cache policies.",
  "x-doc-ref": [
    "docs/reality/PERFORMANCE_CONSTITUTION.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "policies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "policies": {
      "type": "array",
      "items": {
        "$ref": "./inspection_cache_policy.schema.json"
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "policies": [],
      "registry_hash": "1111111111111111111111111111111111111111111111111111111111111111"
    }
  ]
}
