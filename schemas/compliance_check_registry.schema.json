{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Compliance Check Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic SPEC-1 compliance check registry output.",
  "x-doc-ref": [
    "docs/specs/SPECSHEET_CONSTITUTION.md",
    "docs/architecture/registry_compile.md",
    "schemas/compliance_check.schema.json"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "compliance_checks",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "compliance_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "check_id",
          "description",
          "applies_to_target_kinds",
          "required_inputs",
          "output_grade",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "check_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "applies_to_target_kinds": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "structure",
                "ag",
                "geometry",
                "vehicle",
                "network_edge"
              ]
            }
          },
          "required_inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "output_grade": {
            "type": "string",
            "enum": [
              "pass",
              "warn",
              "fail"
            ]
          },
          "failure_refusal_code": {
            "type": [
              "string",
              "null"
            ]
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "compliance_checks": [],
      "registry_hash": "f7f4b4cfaaf5e7c6ad2e46bc04f04f0b8f4db22844fcd8ac7ddc44506e8c9a0f"
    }
  ]
}
