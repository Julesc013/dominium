{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Numeric Precision Policy Schema",
  "version": "1.0.0",
  "description": "Deterministic numeric precision policy contract.",
  "x-doc-ref": [
    "docs/reality/UNIVERSE_PHYSICS_PROFILE.md",
    "docs/canon/constitution_v1.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "policy_id",
    "invariant_numeric_type",
    "solver_numeric_type",
    "quantization_rules",
    "error_accumulation_strategy",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "invariant_numeric_type": {
      "type": "string",
      "enum": [
        "fixed_point",
        "required"
      ]
    },
    "solver_numeric_type": {
      "type": "string",
      "enum": [
        "fixed_point",
        "deterministic_float"
      ]
    },
    "quantization_rules": {
      "type": "object",
      "additionalProperties": true
    },
    "error_accumulation_strategy": {
      "type": "string",
      "minLength": 1
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "policy_id": "default_null",
      "invariant_numeric_type": "fixed_point",
      "solver_numeric_type": "fixed_point",
      "quantization_rules": {},
      "error_accumulation_strategy": "none",
      "extensions": {}
    }
  ]
}
