{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Formalization Event Schema",
  "version": "1.0.0",
  "description": "Deterministic FORM-1 event-sourced formalization transition row.",
  "x-doc-ref": [
    "docs/infrastructure/FORMALIZATION_MODEL.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "tick",
    "formalization_id",
    "transition",
    "actor_subject_id",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "tick": {
      "type": "integer",
      "minimum": 0
    },
    "formalization_id": {
      "type": "string",
      "minLength": 1
    },
    "transition": {
      "type": "string",
      "minLength": 1
    },
    "actor_subject_id": {
      "type": "string",
      "minLength": 1
    },
    "provenance_event_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "decision_log_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "event_id": "formalization.event.6d55731ca2fd",
      "tick": 114,
      "formalization_id": "formalization.23f8e53ac8d9",
      "transition": "inferred->formal",
      "actor_subject_id": "subject.player.alpha",
      "provenance_event_id": "provenance.formalization.6d55731ca2fd",
      "decision_log_ref": "decision.ctrl.38da8f",
      "deterministic_fingerprint": "6e86f5cb6620bc6dd11d4e02be7e6f2c2bc8ea33fd3f52e5b6b40d083443f768",
      "extensions": {}
    }
  ]
}
