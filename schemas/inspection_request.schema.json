{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Inspection Request Schema",
  "version": "1.0.0",
  "description": "Deterministic derived inspection request payload.",
  "x-doc-ref": [
    "docs/materials/INSPECTION_SYSTEM.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "request_id",
    "requester_subject_id",
    "target_kind",
    "target_id",
    "desired_fidelity",
    "tick",
    "max_cost_units",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "requester_subject_id": {
      "type": "string",
      "minLength": 1
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "structure",
        "project",
        "node",
        "manifest",
        "cohort",
        "faction"
      ]
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "desired_fidelity": {
      "type": "string",
      "enum": [
        "macro",
        "meso",
        "micro"
      ]
    },
    "tick": {
      "type": "integer",
      "minimum": 0
    },
    "time_range": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "start_tick",
        "end_tick"
      ],
      "additionalProperties": false,
      "properties": {
        "start_tick": {
          "type": "integer",
          "minimum": 0
        },
        "end_tick": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "max_cost_units": {
      "type": "integer",
      "minimum": 0
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
