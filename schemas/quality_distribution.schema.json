{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Quality Distribution Schema",
  "version": "1.0.0",
  "description": "Canonical quality/defect distribution model declaration.",
  "x-doc-ref": [
    "docs/materials/MATERIAL_TAXONOMY.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "quality_distribution_model_id",
    "description",
    "parameters",
    "tags",
    "version_introduced",
    "deprecated",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "quality_distribution_model_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "parameters": {
      "type": "object",
      "additionalProperties": true
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version_introduced": {
      "type": "string",
      "minLength": 1
    },
    "deprecated": {
      "type": "boolean"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
