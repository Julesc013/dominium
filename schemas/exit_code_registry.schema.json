{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Exit Code Registry Schema",
  "version": "1.0.0",
  "description": "Deterministic AppShell exit-code registry.",
  "type": "object",
  "required": [
    "schema_version",
    "registry_id",
    "ranges",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "registry_id": {
      "type": "string",
      "minLength": 1
    },
    "ranges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "range_id",
          "start_code",
          "end_code",
          "description"
        ],
        "additionalProperties": true,
        "properties": {
          "range_id": {
            "type": "string",
            "minLength": 1
          },
          "start_code": {
            "type": "integer",
            "minimum": 0
          },
          "end_code": {
            "type": "integer",
            "minimum": 0
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
