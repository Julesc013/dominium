{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Session Specification Schema",
  "version": "1.0.0",
  "description": "Canonical session composition contract for deterministic run configuration.",
  "x-doc-ref": [
    "docs/canon/constitution_v1.md §3 A4, §5 C1-C4",
    "docs/canon/glossary_v1.md SessionSpec",
    "docs/contracts/session_spec.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "universe_id",
    "save_id",
    "scenario_id",
    "mission_id",
    "experience_id",
    "parameter_bundle_id",
    "physics_profile_id",
    "authority_context",
    "pack_lock_hash",
    "budget_policy_id",
    "fidelity_policy_id",
    "deterministic_rng_roots"
  ],
  "dependentRequired": {
    "constraints_id": [
      "selected_seed",
      "search_plan_hash"
    ]
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "universe_id": {
      "type": "string"
    },
    "save_id": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string",
      "description": "Optional bundle selection identifier used to produce lockfile and registries."
    },
    "pipeline_id": {
      "type": "string",
      "pattern": "^pipeline\\.[a-z0-9_.-]+$",
      "description": "Declared session lifecycle pipeline contract identifier."
    },
    "network": {
      "type": "object",
      "description": "Optional deterministic multiplayer transport/handshake contract payload. Required when using multiplayer pipeline variants.",
      "required": [
        "endpoint",
        "transport_id",
        "client_peer_id",
        "server_peer_id",
        "requested_replication_policy_id",
        "anti_cheat_policy_id",
        "securex_policy_id",
        "schema_versions"
      ],
      "anyOf": [
        {
          "required": [
            "server_profile_id"
          ]
        },
        {
          "required": [
            "server_policy_id"
          ]
        }
      ],
      "additionalProperties": false,
      "properties": {
        "endpoint": {
          "type": "string",
          "minLength": 1
        },
        "transport_id": {
          "type": "string",
          "enum": [
            "transport.loopback",
            "transport.tcp",
            "transport.udp"
          ]
        },
        "client_peer_id": {
          "type": "string",
          "minLength": 1
        },
        "server_peer_id": {
          "type": "string",
          "minLength": 1
        },
        "requested_replication_policy_id": {
          "type": "string",
          "minLength": 1
        },
        "anti_cheat_policy_id": {
          "type": "string",
          "minLength": 1
        },
        "server_profile_id": {
          "type": "string",
          "minLength": 1
        },
        "server_policy_id": {
          "type": "string",
          "minLength": 1
        },
        "desired_law_profile_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "securex_policy_id": {
          "type": "string"
        },
        "physics_profile_id": {
          "type": "string",
          "minLength": 1
        },
        "schema_versions": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "scenario_id": {
      "type": "string"
    },
    "mission_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "experience_id": {
      "type": "string"
    },
    "parameter_bundle_id": {
      "type": "string"
    },
    "physics_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "authority_context": {
      "type": "object",
      "required": [
        "authority_origin",
        "experience_id",
        "law_profile_id",
        "entitlements",
        "epistemic_scope",
        "privilege_level"
      ],
      "additionalProperties": false,
      "properties": {
        "authority_origin": {
          "type": "string",
          "enum": [
            "client",
            "server",
            "tool",
            "replay"
          ]
        },
        "experience_id": {
          "type": "string"
        },
        "law_profile_id": {
          "type": "string"
        },
        "entitlements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "epistemic_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scope_id",
            "visibility_level"
          ],
          "properties": {
            "scope_id": {
              "type": "string"
            },
            "visibility_level": {
              "type": "string"
            }
          }
        },
        "privilege_level": {
          "type": "string",
          "enum": [
            "observer",
            "operator",
            "system"
          ]
        },
        "profile_bindings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "binding_id",
              "scope",
              "target_id",
              "profile_id",
              "tick_applied"
            ],
            "additionalProperties": false,
            "properties": {
              "binding_id": {
                "type": "string",
                "minLength": 1
              },
              "scope": {
                "type": "string",
                "enum": [
                  "universe",
                  "session",
                  "authority",
                  "system"
                ]
              },
              "target_id": {
                "type": "string",
                "minLength": 1
              },
              "profile_id": {
                "type": "string",
                "minLength": 1
              },
              "tick_applied": {
                "type": "integer",
                "minimum": 0
              },
              "extensions": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "effective_profile_snapshot": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "profile_bindings": {
      "type": "array",
      "description": "Explicit profile overlays bound at SessionSpec scope.",
      "items": {
        "type": "object",
        "required": [
          "binding_id",
          "scope",
          "target_id",
          "profile_id",
          "tick_applied"
        ],
        "additionalProperties": false,
        "properties": {
          "binding_id": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "type": "string",
            "enum": [
              "universe",
              "session",
              "authority",
              "system"
            ]
          },
          "target_id": {
            "type": "string",
            "minLength": 1
          },
          "profile_id": {
            "type": "string",
            "minLength": 1
          },
          "tick_applied": {
            "type": "integer",
            "minimum": 0
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "pack_lock_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "contract_bundle_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$",
      "description": "Pinned universe semantic contract bundle fingerprint for load/replay refusal checks."
    },
    "semantic_contract_registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$",
      "description": "Optional semantic contract registry hash recorded at session creation time."
    },
    "budget_policy_id": {
      "type": "string"
    },
    "fidelity_policy_id": {
      "type": "string"
    },
    "time_control_policy_id": {
      "type": "string",
      "description": "Session-selected deterministic time control policy identifier."
    },
    "constraints_id": {
      "type": "string",
      "description": "Optional worldgen constraints artifact identifier used for deterministic multi-seed planning."
    },
    "selected_seed": {
      "type": "string",
      "description": "Deterministically selected worldgen seed (base seed when no constraints are selected)."
    },
    "search_plan_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$",
      "description": "Canonical hash of worldgen search plan artifact when constraints are active."
    },
    "deterministic_rng_roots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "stream_name",
          "root_seed"
        ],
        "additionalProperties": false,
        "properties": {
          "stream_name": {
            "type": "string"
          },
          "root_seed": {
            "type": "string"
          }
        }
      },
      "minItems": 1
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "universe_id": "universe.f7f79f62a426e393",
      "save_id": "save.lab.bootstrap",
      "bundle_id": "bundle.base.lab",
      "pipeline_id": "pipeline.client.default",
      "scenario_id": "scenario.lab.galaxy_nav",
      "mission_id": null,
      "experience_id": "profile.lab.developer",
      "parameter_bundle_id": "params.lab.placeholder",
      "physics_profile_id": "physics.null",
      "authority_context": {
        "authority_origin": "client",
        "experience_id": "profile.lab.developer",
        "law_profile_id": "law.lab.unrestricted",
        "entitlements": [
          "session.boot",
          "ui.window.lab.nav"
        ],
        "epistemic_scope": {
          "scope_id": "epistemic.lab.placeholder",
          "visibility_level": "placeholder"
        },
        "privilege_level": "observer"
      },
      "pack_lock_hash": "17a8255be7f6d082c7fce0f6bc2d0ad4cc4f95e14f7696b1ef255fca605dc04d",
      "contract_bundle_hash": "95313b59cd3663a63c46d7ced657b12a0fa1eec1c730d334fef8b198ff89e279",
      "semantic_contract_registry_hash": "a996c8327410bd3965108401f98c0d0aacd1fb173b9e7bcbace0da6241f5625b",
      "budget_policy_id": "policy.budget.default_lab",
      "fidelity_policy_id": "policy.fidelity.default_lab",
      "time_control_policy_id": "time.policy.null",
      "constraints_id": "constraints.lab.navigation.default",
      "selected_seed": "33dbcef8b6ab9ee0",
      "search_plan_hash": "53eda2d58cc9f2eca6d3ed76f88bc8a1450c4f26f6f397103f0f74101dca2c31",
      "deterministic_rng_roots": [
        {
          "stream_name": "rng.session.core",
          "root_seed": "0d34f20bbfe8d44f22573afd356fd39c784b6d0bec295f4b3032fd665a5f0a15"
        },
        {
          "stream_name": "rng.session.ui",
          "root_seed": "67b1103bc5cd75c9f868bd168e9b4eb7aeb0c0dc51b85a89f9c31fd57ec32fbc"
        }
      ]
    }
  ]
}
