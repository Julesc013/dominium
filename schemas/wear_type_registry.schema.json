{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wear Type Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic wear type registry output.",
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "wear_types",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "wear_types": {
      "type": "array",
      "items": {
        "$ref": "wear_type.schema.json"
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "wear_types": [],
      "registry_hash": "403f7894f6e32af9f8ef2ea57d8eb4517a6493deaa040ca539f67de33411ce84"
    }
  ]
}
