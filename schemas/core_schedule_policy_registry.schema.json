{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Core Schedule Policy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic core schedule policy registry output.",
  "x-doc-ref": [
    "docs/architecture/CORE_ABSTRACTIONS.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "schedule_policies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "schedule_policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "schedule_policy_id",
          "description",
          "default_rule_type",
          "default_interval_ticks",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "schedule_policy_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "default_rule_type": {
            "type": "string",
            "enum": [
              "none",
              "interval"
            ]
          },
          "default_interval_ticks": {
            "type": "integer",
            "minimum": 0
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "schedule_policies": [],
      "registry_hash": "920f4ea19495dc5b8f89f57fd4e52c4d8966e80b5ad1fd6327ca5d1f42075f3e"
    }
  ]
}

