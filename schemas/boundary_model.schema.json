{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Boundary Model Schema",
  "version": "1.0.0",
  "description": "Universe boundary topology contract.",
  "x-doc-ref": [
    "docs/reality/UNIVERSE_PHYSICS_PROFILE.md",
    "docs/canon/constitution_v1.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "boundary_model_id",
    "universe_type",
    "allow_boundary_flux",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "boundary_model_id": {
      "type": "string",
      "minLength": 1
    },
    "universe_type": {
      "type": "string",
      "enum": [
        "closed",
        "open",
        "procedural_infinite"
      ]
    },
    "allow_boundary_flux": {
      "type": "boolean"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "boundary_model_id": "procedural_infinite",
      "universe_type": "procedural_infinite",
      "allow_boundary_flux": false,
      "extensions": {}
    }
  ]
}
