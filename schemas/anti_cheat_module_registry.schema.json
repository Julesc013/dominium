{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Anti-Cheat Module Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic anti-cheat module registry output.",
  "x-doc-ref": [
    "docs/net/ANTI_CHEAT_POLICY_FRAMEWORK.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "modules",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "module_id",
          "description",
          "inputs",
          "outputs",
          "determinism_notes",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "module_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "determinism_notes": {
            "type": "string"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "modules": [],
      "registry_hash": "4ea0fcb8a4d8134d53e5da19765d2ce5922c57af8f42b26170095dbec417ad83"
    }
  ]
}
