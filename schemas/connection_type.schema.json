{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Connection Type Schema",
  "version": "1.0.0",
  "description": "Assembly graph connection type declaration.",
  "x-doc-ref": [
    "docs/materials/BOM_AND_ASSEMBLY_GRAPH.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "connection_type_id",
    "description",
    "default_stiffness",
    "default_max_load",
    "supports_rotation",
    "supports_translation",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "connection_type_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "default_stiffness": {
      "type": "integer",
      "minimum": 0
    },
    "default_max_load": {
      "type": "integer",
      "minimum": 0
    },
    "supports_rotation": {
      "type": "boolean"
    },
    "supports_translation": {
      "type": "boolean"
    },
    "requires_part_classes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "connection_type_id": "conn.example",
      "description": "Example connection type.",
      "default_stiffness": 1000,
      "default_max_load": 100000,
      "supports_rotation": false,
      "supports_translation": false,
      "requires_part_classes": [
        "partclass.bolt.generic"
      ],
      "extensions": {}
    }
  ]
}
