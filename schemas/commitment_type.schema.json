{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Commitment Type Schema",
  "version": "1.0.0",
  "description": "Canonical deterministic MAT-8 commitment type record.",
  "x-doc-ref": [
    "docs/materials/NOTHING_JUST_HAPPENS.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "commitment_type_id",
    "description",
    "required_entitlements",
    "produces_event_type_ids",
    "strictness_requirements",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "commitment_type_id": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "required_entitlements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "produces_event_type_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "strictness_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
