{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Render Proxy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic render proxy registry output.",
  "x-doc-ref": [
    "docs/embodiment/REPRESENTATION_LAYER.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "render_proxies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "render_proxies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "render_proxy_id",
          "supported_body_shapes",
          "mesh_ref",
          "material_ref",
          "lod_set_ref",
          "bounds_override",
          "attachments_allowed",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "render_proxy_id": {
            "type": "string"
          },
          "supported_body_shapes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "capsule",
                "aabb",
                "convex_hull"
              ]
            }
          },
          "mesh_ref": {
            "type": "string"
          },
          "material_ref": {
            "type": "string"
          },
          "lod_set_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "bounds_override": {
            "type": [
              "object",
              "null"
            ],
            "required": [
              "x_mm",
              "y_mm",
              "z_mm"
            ],
            "additionalProperties": false,
            "properties": {
              "x_mm": {
                "type": "integer"
              },
              "y_mm": {
                "type": "integer"
              },
              "z_mm": {
                "type": "integer"
              }
            }
          },
          "attachments_allowed": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "render_proxies": [],
      "registry_hash": "7dadf22bc129f6542ff66fbf4fd2d9adf3f6f56408d7f97e7a4538b66d1f8446"
    }
  ]
}
