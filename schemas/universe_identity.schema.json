{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Universe Identity Schema",
  "version": "1.0.0",
  "description": "Canonical immutable universe identity contract for Dominium session bootstrap.",
  "x-doc-ref": [
    "docs/canon/constitution_v1.md §3 A1/A6",
    "docs/canon/glossary_v1.md UniverseIdentity",
    "docs/roadmap/milestone_lab_galaxy.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "universe_id",
    "global_seed",
    "domain_binding_ids",
    "physics_profile_id",
    "base_scenario_id",
    "initial_pack_set_hash_expectation",
    "compatibility_schema_refs",
    "immutable_after_create",
    "extensions",
    "identity_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Payload schema version for CompatX routing."
    },
    "universe_id": {
      "type": "string",
      "minLength": 1
    },
    "global_seed": {
      "type": [
        "string",
        "integer"
      ],
      "description": "Deterministic seed root; explicit string or integer only."
    },
    "domain_binding_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "physics_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "base_scenario_id": {
      "type": "string"
    },
    "initial_pack_set_hash_expectation": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "compatibility_schema_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "immutable_after_create": {
      "type": "boolean",
      "const": true
    },
    "extensions": {
      "type": "object"
    },
    "identity_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "universe_id": "universe.8de7ca4fb8e4eb67",
      "global_seed": "dominium.lab.galaxy.seed.0001",
      "domain_binding_ids": [
        "domain.navigation",
        "domain.astronomy"
      ],
      "physics_profile_id": "physics.null",
      "base_scenario_id": "scenario.lab.galaxy_nav",
      "initial_pack_set_hash_expectation": "d9eb253e069b2ce7fbbdb5f95f98cc28fbf3622f29227cececad2e89d13718a5",
      "compatibility_schema_refs": [
        "bundle_lockfile@1.0.0",
        "session_spec@1.0.0",
        "universe_identity@1.0.0"
      ],
      "immutable_after_create": true,
      "extensions": {},
      "identity_hash": "5ce1f4975ab8e443664f94f79e4a00c3d54f14ab1ec691e4d8f9f646d159c111"
    }
  ]
}

