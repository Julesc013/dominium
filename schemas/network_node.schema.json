{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Network Node Schema",
  "version": "1.0.0",
  "description": "Deterministic universal NetworkGraph node payload.",
  "x-doc-ref": [
    "docs/architecture/CORE_ABSTRACTIONS.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "node_id",
    "node_type_id",
    "payload_ref",
    "tags",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "node_type_id": {
      "type": "string",
      "minLength": 1
    },
    "payload_ref": {
      "type": "object",
      "additionalProperties": true
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "node_id": "node.factory.alpha",
      "node_type_id": "logistics.factory",
      "payload_ref": {
        "location_ref": "site.factory.alpha"
      },
      "tags": [
        "baseline"
      ],
      "extensions": {}
    }
  ]
}

