{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Commitment Schema",
  "version": "1.0.0",
  "description": "Canonical deterministic MAT-8 commitment assembly record.",
  "x-doc-ref": [
    "docs/materials/NOTHING_JUST_HAPPENS.md",
    "docs/materials/PROVENANCE_AND_COMMITMENTS.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "commitment_id",
    "commitment_type_id",
    "actor_subject_id",
    "target_kind",
    "target_id",
    "created_tick",
    "scheduled_start_tick",
    "scheduled_end_tick",
    "required_inputs",
    "expected_outputs",
    "status",
    "linked_project_id",
    "linked_manifest_id",
    "linked_event_ids",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "commitment_id": {
      "type": "string"
    },
    "commitment_type_id": {
      "type": "string"
    },
    "actor_subject_id": {
      "type": "string"
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "structure",
        "logistics",
        "maintenance",
        "research",
        "custom"
      ]
    },
    "target_id": {
      "type": "string"
    },
    "created_tick": {
      "type": "integer",
      "minimum": 0
    },
    "scheduled_start_tick": {
      "type": "integer",
      "minimum": 0
    },
    "scheduled_end_tick": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "required_inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "expected_outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "scheduled",
        "executing",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "linked_project_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "linked_manifest_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "linked_event_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "commitment_id": "commitment.a9bd08a9b0c6446e",
      "commitment_type_id": "commit.construction.project",
      "actor_subject_id": "subject.operator.alpha",
      "target_kind": "structure",
      "target_id": "structure.alpha",
      "created_tick": 100,
      "scheduled_start_tick": 101,
      "scheduled_end_tick": 140,
      "required_inputs": [],
      "expected_outputs": [],
      "status": "planned",
      "linked_project_id": "project.alpha",
      "linked_manifest_id": null,
      "linked_event_ids": [],
      "deterministic_fingerprint": "b0d19159edbe5f4f55ff920f9dca8d4d6b4cc8c25330f2ba7db44ea2f24c53d8",
      "extensions": {}
    }
  ]
}
