{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Order Assimilate Payload Schema",
  "version": "1.0.0",
  "description": "CIV-3 assimilation/recruitment order payload (stub-safe).",
  "x-doc-ref": [
    "docs/civilisation/ORDER_LANGUAGE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "target_faction_id",
    "method",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "target_faction_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "method": {
      "type": "string",
      "enum": [
        "invite",
        "force",
        "trade"
      ]
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "target_faction_id": "faction.alpha",
      "method": "invite",
      "extensions": {}
    }
  ]
}
