{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Perception Interest Policy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic perception-interest policy registry used for SRZ hybrid client delta filtering.",
  "x-doc-ref": [
    "docs/net/SRZ_HYBRID_POLICY.md",
    "docs/net/EPISTEMICS_OVER_NETWORK.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "policies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "policy_id",
          "human_name",
          "description",
          "max_objects_per_tick",
          "distance_bands",
          "lens_visibility_rules",
          "deterministic_ordering_rule_id",
          "bandwidth_budget_units",
          "resync_window_ticks",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "policy_id": {
            "type": "string"
          },
          "human_name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "max_objects_per_tick": {
            "type": "integer",
            "minimum": 1
          },
          "distance_bands": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "band_id",
                "max_distance",
                "max_objects"
              ],
              "additionalProperties": false,
              "properties": {
                "band_id": {
                  "type": "string"
                },
                "max_distance": {
                  "type": "number",
                  "minimum": 0
                },
                "max_objects": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          },
          "lens_visibility_rules": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "lens_type",
                "max_objects_multiplier"
              ],
              "additionalProperties": false,
              "properties": {
                "lens_type": {
                  "type": "string"
                },
                "max_objects_multiplier": {
                  "type": "number",
                  "minimum": 0
                }
              }
            }
          },
          "deterministic_ordering_rule_id": {
            "type": "string"
          },
          "bandwidth_budget_units": {
            "type": "integer",
            "minimum": 1
          },
          "resync_window_ticks": {
            "type": "integer",
            "minimum": 1
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "policies": [],
      "registry_hash": "74b83947f840fc2f6df6d5dc49f3d3be60b5a45cbf8fb8a2cfbbdb6f29183949"
    }
  ]
}
