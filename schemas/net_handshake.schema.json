{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Network Handshake Schema",
  "version": "1.0.0",
  "description": "Deterministic multiplayer compatibility handshake artifact contract.",
  "x-doc-ref": [
    "docs/net/HANDSHAKE_AND_COMPATIBILITY.md",
    "docs/contracts/refusal_contract.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "handshake_id",
    "protocol_version",
    "client_peer_id",
    "server_peer_id",
    "requested_replication_policy_id",
    "negotiated_replication_policy_id",
    "anti_cheat_policy_id",
    "server_law_profile_id",
    "server_profile_id",
    "pack_lock_hash",
    "registry_hashes",
    "schema_versions",
    "securex_policy_id",
    "result",
    "refusal",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "handshake_id": {
      "type": "string",
      "minLength": 1
    },
    "protocol_version": {
      "type": "string",
      "minLength": 1
    },
    "client_peer_id": {
      "type": "string",
      "minLength": 1
    },
    "server_peer_id": {
      "type": "string",
      "minLength": 1
    },
    "requested_replication_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "negotiated_replication_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "anti_cheat_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "server_law_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "server_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "pack_lock_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "registry_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[A-Fa-f0-9]{64}$"
      }
    },
    "schema_versions": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "securex_policy_id": {
      "type": "string"
    },
    "result": {
      "type": "string",
      "enum": [
        "accept",
        "refuse"
      ]
    },
    "refusal": {
      "type": "object",
      "required": [
        "reason_code",
        "message",
        "remediation_hint",
        "relevant_ids"
      ],
      "additionalProperties": false,
      "properties": {
        "reason_code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "remediation_hint": {
          "type": "string"
        },
        "relevant_ids": {
          "type": "object"
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "handshake_id": "hs.peer.client.alpha.server.lab.0001",
      "protocol_version": "1.0.0",
      "client_peer_id": "peer.client.alpha",
      "server_peer_id": "peer.server.lab",
      "requested_replication_policy_id": "policy.net.lockstep",
      "negotiated_replication_policy_id": "policy.net.lockstep",
      "anti_cheat_policy_id": "policy.ac.casual_default",
      "server_law_profile_id": "law.lab.unrestricted",
      "server_profile_id": "server.profile.private_relaxed",
      "pack_lock_hash": "83e022ebf2ffc2686d0c2b8854b24b3febd5c80edbe06b3f4a0931575d8eb1b8",
      "registry_hashes": {},
      "schema_versions": {
        "session_spec": "1.0.0",
        "net_handshake": "1.0.0"
      },
      "securex_policy_id": "",
      "result": "accept",
      "refusal": {
        "reason_code": "",
        "message": "",
        "remediation_hint": "",
        "relevant_ids": {}
      },
      "extensions": {}
    }
  ]
}
