{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Universe Physics Profile Schema",
  "version": "1.0.0",
  "description": "Canonical immutable universe physics profile contract.",
  "x-doc-ref": [
    "docs/reality/UNIVERSE_PHYSICS_PROFILE.md",
    "docs/canon/constitution_v1.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "physics_profile_id",
    "description",
    "enabled_domain_ids",
    "conservation_contract_set_id",
    "allowed_exception_types",
    "numeric_precision_policy_id",
    "tier_taxonomy_id",
    "time_model_id",
    "boundary_model_id",
    "error_budget",
    "version_introduced",
    "deprecated",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "physics_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "enabled_domain_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "conservation_contract_set_id": {
      "type": "string",
      "minLength": 1
    },
    "allowed_exception_types": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "numeric_precision_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "tier_taxonomy_id": {
      "type": "string",
      "minLength": 1
    },
    "time_model_id": {
      "type": "string",
      "minLength": 1
    },
    "boundary_model_id": {
      "type": "string",
      "minLength": 1
    },
    "error_budget": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "integer",
          "number"
        ]
      }
    },
    "version_introduced": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "deprecated": {
      "type": "boolean"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "physics_profile_id": "physics.null",
      "description": "Built-in null profile for zero-pack deterministic boot.",
      "enabled_domain_ids": [],
      "conservation_contract_set_id": "contracts.null",
      "allowed_exception_types": [],
      "numeric_precision_policy_id": "default_null",
      "tier_taxonomy_id": "default_minimal",
      "time_model_id": "default_single_tick",
      "boundary_model_id": "procedural_infinite",
      "error_budget": {},
      "version_introduced": "1.0.0",
      "deprecated": false,
      "extensions": {}
    }
  ]
}
