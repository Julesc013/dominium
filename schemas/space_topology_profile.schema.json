{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Space Topology Profile Schema",
  "version": "1.0.0",
  "description": "Canonical GEO-0 topology atlas and neighborhood contract.",
  "x-doc-ref": [
    "docs/geo/GEO_CONSTITUTION.md",
    "docs/canon/constitution_v1.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "topology_profile_id",
    "dimension_D",
    "chart_definitions",
    "boundary_rule_id",
    "neighbor_policy_id",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "topology_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "dimension_D": {
      "type": "integer",
      "minimum": 1
    },
    "chart_definitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "chart_id",
          "chart_kind",
          "transform_refs",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "chart_id": {
            "type": "string",
            "minLength": 1
          },
          "chart_kind": {
            "type": "string",
            "minLength": 1
          },
          "transform_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "boundary_rule_id": {
      "type": "string",
      "minLength": 1
    },
    "neighbor_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "portal_identifications_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "topology_profile_id": "geo.topology.torus_r2",
      "dimension_D": 2,
      "chart_definitions": [
        {
          "chart_id": "chart.global.r2",
          "chart_kind": "cartesian",
          "transform_refs": [
            "transform.identity"
          ],
          "extensions": {
            "wrap_axes": [
              "x",
              "y"
            ]
          }
        }
      ],
      "boundary_rule_id": "boundary.periodic_wrap",
      "neighbor_policy_id": "neighbor.moore.r1",
      "portal_identifications_ref": null,
      "deterministic_fingerprint": "9b14a10d4ab0d753cddc73f609730e7fc6f4ce39bf55bc6ecf3cf6a3c2188cbe",
      "extensions": {}
    }
  ]
}
