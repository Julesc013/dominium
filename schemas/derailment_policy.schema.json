{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Derailment Policy Schema",
  "version": "1.0.0",
  "description": "Deterministic MOB-6 derailment policy contract.",
  "x-doc-ref": [
    "docs/mobility/MICRO_CONSTRAINED_MOTION.md",
    "docs/audit/MICRO_CONSTRAINED_MOTION_BASELINE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "derail_policy_id",
    "threshold_model_id",
    "allow_stochastic",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "derail_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "threshold_model_id": {
      "type": "string",
      "minLength": 1
    },
    "allow_stochastic": {
      "type": "boolean"
    },
    "rng_stream_name": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "allow_stochastic": {
            "const": true
          }
        }
      },
      "then": {
        "required": [
          "rng_stream_name"
        ]
      }
    }
  ],
  "examples": [
    {
      "schema_version": "1.0.0",
      "derail_policy_id": "derail.strict_threshold",
      "threshold_model_id": "threshold.v2_overturn",
      "allow_stochastic": false,
      "rng_stream_name": null,
      "extensions": {}
    }
  ]
}
