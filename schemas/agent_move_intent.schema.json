{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Move Intent Schema",
  "version": "1.0.0",
  "description": "Deterministic kinematic movement intent payload for embodied agents.",
  "x-doc-ref": [
    "docs/embodiment/MOVEMENT_PROCESSES.md",
    "docs/canon/constitution_v1.md §3 A1/A2",
    "docs/canon/glossary_v1.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "agent_id",
    "move_vector_local",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "agent_id": {
      "type": "string"
    },
    "move_vector_local": {
      "type": "object",
      "required": [
        "x",
        "y",
        "z"
      ],
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        },
        "z": {
          "type": "integer"
        }
      }
    },
    "speed_scalar": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "tick_duration": {
      "type": "integer",
      "minimum": 1
    },
    "stance": {
      "type": "string"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "agent_id": "agent.lab.navigator.001",
      "move_vector_local": {
        "x": 100,
        "y": 0,
        "z": 0
      },
      "speed_scalar": 1000,
      "tick_duration": 1,
      "stance": "default",
      "extensions": {}
    }
  ]
}
