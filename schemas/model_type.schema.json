{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Model Type Schema",
  "version": "1.0.0",
  "description": "Deterministic constitutive model type row.",
  "type": "object",
  "required": ["schema_version", "model_type_id", "description", "parameter_schema_id", "extensions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "model_type_id": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "parameter_schema_id": {"type": "string", "minLength": 1},
    "extensions": {"type": "object", "additionalProperties": true}
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "model_type_id": "model_type.signal_attenuation_stub",
      "description": "Signal attenuation stub model type.",
      "parameter_schema_id": "dominium.schema.models.model_binding.v1",
      "extensions": {}
    }
  ]
}
