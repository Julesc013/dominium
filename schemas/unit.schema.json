{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unit Schema",
  "version": "1.0.0",
  "description": "Canonical unit declaration bound to a dimension.",
  "x-doc-ref": [
    "docs/materials/UNITS_AND_DIMENSIONS.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "unit_id",
    "dimension_id",
    "scale_factor_to_canonical",
    "display_symbol",
    "description",
    "version_introduced",
    "deprecated",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "unit_id": {
      "type": "string",
      "minLength": 1
    },
    "dimension_id": {
      "type": "string",
      "minLength": 1
    },
    "scale_factor_to_canonical": {
      "type": "integer"
    },
    "display_symbol": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version_introduced": {
      "type": "string",
      "minLength": 1
    },
    "deprecated": {
      "type": "boolean"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
