{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Core Flow Solver Policy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic core flow solver policy registry output.",
  "x-doc-ref": [
    "docs/architecture/CORE_ABSTRACTIONS.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "solver_policies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "solver_policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "solver_policy_id",
          "description",
          "solver_kind",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "solver_policy_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "solver_kind": {
            "type": "string",
            "minLength": 1
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "solver_policies": [],
      "registry_hash": "a912ce95f4b9b3466283fc2198c72f360036e07063ca2fd4868fc89c2002ca95"
    }
  ]
}

