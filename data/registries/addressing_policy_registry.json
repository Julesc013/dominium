          "subject"
        ],
        "extensions": {}
      },
      {
        "schema_version": "1.0.0",
        "addressing_policy_id": "addressing.group_registry",
        "description": "Group target resolved from deterministic membership registry rows.",
        "supported_address_types": [
          "group"
        ],
        "extensions": {}
      },
      {
        "schema_version": "1.0.0",
        "addressing_policy_id": "addressing.broadcast_scope",
        "description": "Broadcast scope resolved via deterministic graph/scope memberships.",
        "supported_address_types": [
          "broadcast"
        ],
        "extensions": {
          "requires_scope_membership": true
        }
      }
    ],
    "extensions": {}
  }
}
