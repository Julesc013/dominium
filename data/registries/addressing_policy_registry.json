{
  "schema_id": "dominium.registry.addressing_policy_registry",
  "schema_version": "1.0.0",
  "record": {
    "registry_id": "dominium.registry.addressing_policy_registry",
    "registry_version": "1.0.0",
    "addressing_policies": [
      {
        "schema_version": "1.0.0",
        "addressing_policy_id": "addressing.subject_direct",
