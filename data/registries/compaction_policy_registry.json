          "merge_intent_logs": false,
          "prune_old_run_meta": false
        },
        "extensions": {}
      },
      {
        "schema_version": "1.0.0",
        "compaction_policy_id": "compaction.policy.rank_strict",
        "rules": {
          "keep_every_nth_checkpoint": 2,
          "merge_intent_logs": true,
          "prune_old_run_meta": false
        },
        "extensions": {
          "ranked_provenance_retention": true
        }
      }
    ],
    "extensions": {}
