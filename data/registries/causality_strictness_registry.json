        "event_required_for_macro_change": true,
        "extensions": {
          "major_change_process_families": [
            "construction",
            "logistics",
            "maintenance"
          ]
        }
      },
      {
        "schema_version": "1.0.0",
        "causality_strictness_id": "causality.C2",
        "level": "C2",
