{
  "schema_id": "dominium.registry.standards_policy_registry",
  "schema_version": "1.0.0",
  "record": {
    "registry_id": "dominium.registry.standards_policy_registry",
    "registry_version": "1.0.0",
    "standards_policies": [
      {
        "schema_version": "1.0.0",
        "standards_policy_id": "standards.basic_body",
        "allowed_spec_types": [
          "spec.transport.infrastructure",
          "spec.transport.vehicle",
          "spec.signal.safety"
        ],
        "credential_issuance_rules": {
          "credential_kind": "certificate",
          "requires_signing_key": true
        },
        "compliance_reporting_rules": {
          "report_family_id": "REPORT",
          "include_failures_only": false
        },
        "extensions": {
          "issuer_scope": "institution"
        }
      }
    ],
    "extensions": {}
  }
}
