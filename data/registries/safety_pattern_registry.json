          "required_substrates": [
            "HazardModel",
            "Effect",
            "ScheduleComponent"
          ],
          "hazards": [
            "hazard.overheat",
            "hazard.thermal_runaway_risk"
          ],
          "effects": [
            "effect.warning.thermal_runaway",
            "effect.graceful_degradation"
          ],
          "logging_requirements": [
            "target_id",
            "runaway_risk_permille",
            "policy_id"
          ]
        }
      }
    ],
    "extensions": {}
  }
}
