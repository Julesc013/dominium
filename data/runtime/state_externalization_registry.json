  "state_externalization_definition": {
    "summary": "State externalization is the constitutional discipline that determines which runtime-relevant state must remain externalized or externalizable and how state may be exposed, transferred, persisted, replayed, reconstructed, audited, or handed off without reassigning semantic ownership or silently changing meaning.",
    "state_externalization_is_not": [
      "truth_itself",
      "runtime_execution_context",
      "cache_policy_alone",
      "projection_or_generated_artifact_authority",
      "storage_technology_choice",
      "save_file_format",
      "snapshot_mechanism",
      "replay_log_mechanism",
      "product_or_ui_state_authority"
    ],
    "why_needed": [
      "truth_must_not_become_trapped_in_transient_runtime_containers",
      "services_components_and_products_must_not_become_hidden_truth_owners",
      "lawful_replay_snapshot_migration_and_handoff_depend_on_explicit_state_boundaries",
      "sparse_materialization_must_not_be_misread_as_partial_truth_ownership",
      "auditability_replaceability_and_correctness_require_explicit_state_classes",
      "later_phi_sigma_upsilon_and_zeta_work_need_explicit_state_law"
    ]
  },
  "required_semantic_inputs": [
    "SPEC_DOMINIUM_UNIVERSAL_REALITY_FRAMEWORK",
    "SPEC_DOMAIN_CONTRACT_TEMPLATE",
    "SPEC_REPRESENTATION_LADDERS",
    "SPEC_SEMANTIC_ASCENT_DESCENT",
    "SPEC_FORMALIZATION_CHAIN",
    "SEMANTIC_OWNERSHIP_REVIEW",
    "SPEC_CROSS_DOMAIN_BRIDGES"
  ],
  "required_governance_inputs": [
    "AGENTS.md",
    ".agentignore",
    "AGENT_TASKS.md",
    "AGENT_MIRROR_POLICY",
    "NATURAL_LANGUAGE_TASK_BRIDGE",
    "AUTHORITY_ORDER",
    "EXTEND_NOT_REPLACE_LEDGER",
    "GATES_AND_PROOFS",
    "FOUNDATION_READINESS_REPORT",
    "CHECKPOINT_C_SIGMAA1_PHIA2_REVIEW"
  ],
  "state_classes": [
    {
      "id": "authoritative_truth_state",
      "description": "Domain-owned semantic state that participates directly in authoritative truth and Process-relevant commitments.",
      "authority_posture": "domain_owned_authoritative",
      "minimum_requirement": "must_be_externalizable"
    },
    {
      "id": "lawful_derived_runtime_managed_state",
      "description": "Runtime-managed state derived from authoritative truth, lawful inputs, or deterministic Process progression and needed for execution or coordination support.",
      "authority_posture": "runtime_managed_non_owning",
      "minimum_requirement": "must_be_deterministically_reconstructable"
    },
    {
      "id": "transient_execution_state",
      "description": "In-flight, activation-local, or scratch execution state used for bounded runtime work.",
      "authority_posture": "explicitly_transient_non_authoritative",
      "minimum_requirement": "explicitly_transient_only"
    },
    {
      "id": "cache_projection_state",
      "description": "Memoized, indexed, mirrored, generated, compatibility-facing, or projection-facing state used for acceleration or adaptation.",
      "authority_posture": "explicitly_non_authoritative",
      "minimum_requirement": "must_be_reconstructable"
    },
    {
      "id": "observation_presentation_state",
      "description": "Perceived, observed, rendered, UI-facing, or operator-facing state derived for display, explanation, or interaction.",
      "authority_posture": "explicitly_non_authoritative",
      "minimum_requirement": "evidence_only_when_externalized"
    },
    {
      "id": "control_plane_operator_visible_state",
      "description": "Health, refusal, compatibility, activation, negotiation, or diagnostics state visible to operators or control surfaces.",
      "authority_posture": "operational_non_owning",
      "minimum_requirement": "must_be_externalizable"
    },
    {
      "id": "provenance_lineage_support_state",
      "description": "Identity, revision, deterministic hash, audit, refusal-evidence, and lineage-preserving support state.",
      "authority_posture": "supporting_non_substitute_but_required_when_claimed",
      "minimum_requirement": "must_preserve_identity_and_lineage_when_externalized"
    },
    {
      "id": "binding_lifecycle_support_state",
      "description": "State supporting activation, quiescence, attach, detach, handoff, replay anchors, or binding continuity.",
      "authority_posture": "runtime_support_non_owning",
      "minimum_requirement": "must_be_externalizable"
    }
  ],
  "externalization_requirement_categories": [
    {
      "id": "must_be_externalizable",
      "description": "The state must be expressible outside one transient runtime container without semantic loss beyond declared lawful limits."
    },
    {
      "id": "must_be_externalized_when_crossing_boundary",
      "description": "The state must be emitted lawfully when persistence, replay, snapshot, migration, handoff, audit, or proof depends on it."
    },
    {
      "id": "must_be_deterministically_reconstructable",
      "description": "If not directly externalized, the state must be reconstructable from authoritative state and declared laws."
    },
    {
      "id": "explicitly_transient_only",
      "description": "The state may remain local only when its temporary and non-authoritative nature is explicit."
    },
    {
      "id": "explicitly_non_authoritative",
      "description": "The state may inform runtime behavior or operators but may not redefine semantic truth."
    },
    {
      "id": "evidence_only_when_externalized",
      "description": "When externalized, the state remains evidence, view, or presentation output rather than truth ownership."
    },
    {
      "id": "must_preserve_identity_and_lineage_when_externalized",
      "description": "Externalized forms must preserve identity, revision posture, provenance, and supersession lineage where relevant."
    }
  ],
  "class_requirement_matrix": {
    "authoritative_truth_state": [
      "must_be_externalizable",
      "must_be_externalized_when_crossing_boundary"
    ],
    "lawful_derived_runtime_managed_state": [
      "must_be_externalizable",
      "must_be_deterministically_reconstructable"
    ],
    "transient_execution_state": [
      "explicitly_transient_only",
      "explicitly_non_authoritative"
    ],
    "cache_projection_state": [
      "must_be_deterministically_reconstructable",
      "explicitly_non_authoritative"
    ],
    "observation_presentation_state": [
      "explicitly_non_authoritative",
      "evidence_only_when_externalized"
    ],
    "control_plane_operator_visible_state": [
      "must_be_externalizable",
      "explicitly_non_authoritative"
    ],
    "provenance_lineage_support_state": [
      "must_be_externalizable",
      "must_preserve_identity_and_lineage_when_externalized"
    ],
    "binding_lifecycle_support_state": [
      "must_be_externalizable",
      "must_be_deterministically_reconstructable"
    ]
  },
  "authority_constraints": {
    "semantic_law_outranks_runtime_containers": true,
    "domains_remain_truth_owners": true,
    "services_must_not_own_hidden_authoritative_truth": true,
