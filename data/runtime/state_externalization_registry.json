        "binding_or_bridge_authority"
      ]
    }
  },
  "distinction_notes": {
    "authoritative_truth_state": "Semantic truth owned by domains and governed by domain contracts.",
    "lawful_derived_runtime_managed_state": "Runtime-managed but non-owning state that supports lawful execution or mediation.",
    "transient_execution_state": "Temporary local runtime state that may be dropped without erasing authoritative commitments.",
    "cache_projection_state": "Reconstructable, discardable, and explicitly non-authoritative state used for acceleration or adaptation.",
    "observation_presentation_state": "Perceived, rendered, or displayed state that remains downstream of truth.",
    "state_externalization": "The law governing what cannot be trapped inside transient hosting convenience."
  },
  "representation_scaling_cautions": {
    "must_preserve": [
      "representation_ladder_invariants",
      "macro_micro_continuity",
      "substitution_legality",
      "sparse_materialization_without_partial_truth_drift",
      "uncertainty_or_refusal_when_active_representation_is_insufficient"
    ],
    "must_not_assume": [
