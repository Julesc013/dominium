  "failure_invalidity_categories": [
    {
      "id": "state_unavailable",
      "description": "Required state is absent for the current lawful scope."
    },
    {
      "id": "state_stale",
      "description": "The state exists but no longer satisfies freshness, continuity, or revision requirements."
    },
    {
      "id": "state_incomplete",
      "description": "Required portions of lawful state are missing."
    },
    {
      "id": "projected_only_state",
      "description": "Only a projection, mirror, or generated derivative is present and canonical authoritative use is therefore invalid."
    },
    {
      "id": "transient_only_state",
      "description": "The state exists only inside a transient runtime container when externalization or reconstructability is required."
    },
    {
      "id": "ownership_invalid",
      "description": "The state targets or reflects the wrong semantic owner or ignores ownership review outcomes."
    },
    {
      "id": "bridge_invalid",
      "description": "The state crosses domain boundaries without lawful bridge support."
    },
    {
      "id": "representation_invalid",
      "description": "The active representation horizon cannot lawfully support the required use."
    },
    {
      "id": "formalization_or_provenance_invalid",
      "description": "Identity, lineage, standard, protocol, or revision posture requirements are not satisfied."
    },
    {
      "id": "determinism_or_process_invalid",
      "description": "The state cannot be used lawfully without violating Process-only mutation, replay equivalence, or deterministic ordering."
    },
    {
      "id": "unsafe_or_under_authorized",
      "description": "The state may exist but may not be used under the present authority or safety envelope."
    }
  ],
  "verification_expectations": [
