  "distributed_authority_definition": {
    "summary": "Distributed authority is the declared, bounded, proof-bearing partitioning, holding, or transfer of authoritative runtime responsibility across more than one authority region while preserving one lawful truth owner for each governed scope at every relevant horizon.",
    "distributed_authority_is_not": [
      "generic_sharding",
      "simple_replication",
      "hotswap",
      "rollback",
      "publication_or_control_plane_action",
      "implementation_level_clustering"
    ],
    "why_needed": [
      "The repo already has shard placement, lifecycle, cross-shard message, checkpoint, version, baseline-hash, and ownership-transfer precursor surfaces that would otherwise be misread as implicit authority law.",
      "Authority partition and handoff change truth-bearing execution assumptions and therefore require explicit proof, continuity, and convergence semantics.",
      "Later Ζ planning needs one constitutional model instead of shard folklore or implementation-specific cluster behavior."
    ]
  },
