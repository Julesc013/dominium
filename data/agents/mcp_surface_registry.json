  "exposure_classes": [
    {
      "id": "read_inspect_surface",
      "description": "Stable read-only inspection of canonical or derived state without tracked mutation.",
      "default_mutation_posture": "read_only",
      "typical_task_families": [
        "planning_checkpointing",
        "documentation_explanation",
        "analysis_inspection"
      ],
      "auditability_expectation": "high"
    },
    {
      "id": "planning_analysis_surface",
      "description": "Classification, proposal, planning, inventory, or analysis behavior that may emit candidate artifacts, summaries, or reports without direct review-free mutation.",
      "default_mutation_posture": "proposal_or_report_only",
      "typical_task_families": [
        "planning_checkpointing",
        "analysis_inspection",
        "documentation_explanation"
      ],
      "auditability_expectation": "high"
    },
    {
      "id": "validation_audit_surface",
      "description": "Deterministic validation, proof, diagnostics, and audit execution emitting findings, refusal payloads, or evidence.",
      "default_mutation_posture": "evidence_emitting_only",
      "typical_task_families": [
        "validation_audit"
      ],
      "auditability_expectation": "high"
    },
    {
      "id": "packaging_checkpoint_surface",
      "description": "Support-artifact packaging such as checkpoint bundles, bundle validation, and manifest generation without release-distribution semantics.",
      "default_mutation_posture": "artifact_emitting_only",
      "typical_task_families": [
        "packaging_bundling"
      ],
      "auditability_expectation": "high"
    },
    {
      "id": "controlled_mutation_surface",
      "description": "Bounded mutation-capable exposure only where scope, authoritative inputs, auditability, review posture, and runtime or semantic boundaries are already explicit enough to support later safety hardening.",
      "default_mutation_posture": "bounded_mutation",
      "typical_task_families": [
        "runtime_platform",
        "product_app_shell"
      ],
      "auditability_expectation": "very_high"
    },
    {
      "id": "strongly_review_gated_surface",
      "description": "Exposure that must remain proposal-oriented, delayed, escalated, or explicitly review-gated rather than directly mutable.",
      "default_mutation_posture": "review_gated_or_proposal_only",
      "typical_task_families": [
        "doctrine_specification",
        "governance_policy",
        "semantic_domain",
        "release_distribution_control_plane"
      ],
      "auditability_expectation": "very_high"
    },
    {
      "id": "non_exposable_or_excluded_surface",
      "description": "Surface excluded from current MCP exposure because the authority, ownership, safety, or continuity model is not yet strong enough.",
      "default_mutation_posture": "not_exposed",
      "typical_task_families": [
        "refactor_convergence",
        "late_zeta_live_ops_equivalents"
      ],
      "auditability_expectation": "n_a"
    }
  ],
