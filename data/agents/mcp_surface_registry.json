  "mcp_interface_definition": {
    "summary": "An MCP-facing interface surface is a bounded, tool-mediated exposure envelope that presents a cataloged task surface through an explicit exposure class, explicit authoritative inputs, explicit output expectations, explicit review posture, and explicit ownership and runtime cautions.",
    "interface_is_not": [
      "canonical_governance",
      "mirror_policy",
      "natural_language_normalization",
      "task_catalog_entry_by_itself",
      "runtime_service",
      "script_or_command_name_by_itself",
      "product_ui",
      "safety_policy_permission"
    ],
    "why_needed": [
      "task_catalog_inclusion_is_broader_than_lawful_interface_exposure",
      "remote_or_tool_mediated_access_increases_bypass_risk",
      "scripts_and_wrappers_do_not_encode_full_legal_boundaries",
      "later_safety_policy_needs_a_stable_exposure_universe",
      "interface_presence_must_not_be_mistaken_for_authority"
    ]
  },
