      "raw_prompt_text",
      "mirror_instruction_by_itself",
      "script_or_command_name_by_itself",
      "runtime_service",
      "product_shell",
      "release_artifact",
      "mcp_interface_contract",
      "safety_policy_permission"
    ],
    "why_needed": [
      "natural_language_normalization_needs_stable_repo_native_task_surfaces_after_classification",
      "scripts_and_wrapper_names_must_not_become_hidden_canon",
      "runtime_semantic_release_and_governance_work_must_not_be_flattened_into_generic_tasks",
      "later_mcp_and_safety_layers_need_a_stable_task_universe",
      "catalog_inclusion_must_not_be_confused_with_automation_permission"
