  "field_semantics_summaries": {
    "profile_identity": "Identifies the profile artifact and its stability without replacing the compatibility truths it carries.",
    "semantic_contract_binding": "Pins semantic meaning compatibility and prevents version labels from impersonating semantic law.",
    "protocol_compatibility": "Carries negotiated interoperability constraints explicitly.",
    "schema_compatibility": "Carries structure and migration or refusal compatibility constraints explicitly.",
    "format_compatibility": "Carries persisted-layout and payload-layout compatibility constraints explicitly.",
    "governance_and_trust": "Binds governance posture and trust posture into the compatibility envelope without authorizing publication workflow.",
    "release_anchors": "Reconnects the profile to the build graph, component graph, release series, install profiles, and optionally concrete release or build identities.",
    "target_compatibility": "Separates broad grouping from exact target meaning so target shorthand cannot stand in for concrete compatibility.",
    "lane_context": "Carries channel or lane context for interpretation while remaining distinct from compatibility facts."
  },
