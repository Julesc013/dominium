{
  "law_profile_id": "law.lab.observe_only",
  "schema_version": "1.0.0",
  "epistemic_policy_id": "ep.policy.player_diegetic",
  "allowed_processes": [
    "process.instrument_tick",
    "process.observe.telemetry"
  ],
  "forbidden_processes": [
    "process.mutate.assembly"
  ],
