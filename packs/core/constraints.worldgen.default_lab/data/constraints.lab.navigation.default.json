{
  "schema_version": "1.0.0",
  "constraints_id": "constraints.lab.navigation.default",
  "universe_scope": "region",
  "hard_constraints": [
    {
      "constraint_id": "hard.elevation.window",
      "target": "world.layer.elevation",
      "operator": "range",
      "value": {
        "min": 400,
        "max": 9400
      },
      "weight": 0,
      "description": "Require spawnable elevation range for deterministic lab traversal."
    }
  ],
  "soft_constraints": [
    {
      "constraint_id": "soft.hydrology.minimum",
      "target": "world.layer.hydrology",
      "operator": "min",
      "value": 1800,
      "weight": 4,
      "description": "Prefer candidates with stable hydrology signal."
    },
    {
      "constraint_id": "soft.resources.minimum",
      "target": "world.layer.resources",
      "operator": "min",
      "value": 2200,
      "weight": 3,
      "description": "Prefer candidates with stronger resource preview scores."
    }
  ],
  "scoring_functions": [
    {
      "scoring_id": "score.elevation.maximize",
      "metric": "world.layer.elevation",
      "operator": "maximize",
      "weight": 2,
      "description": "Maximize terrain elevation metric for observability."
    },
    {
      "scoring_id": "score.hydrology.target",
      "metric": "world.layer.hydrology",
      "operator": "target",
      "target_value": 5000,
      "weight": 1,
      "description": "Bias toward midpoint hydrology metric."
    }
  ],
  "deterministic_seed_policy": "multi",
  "candidate_count": 6,
  "tie_break_policy": "lexicographic",
  "refusal_codes": [
    "refusal.constraints_unsatisfiable",
    "refusal.search_exhausted"
  ],
  "extensions": {
    "description": "Default deterministic worldgen constraints profile for lab navigation sessions.",
    "status": "active"
  }
}
