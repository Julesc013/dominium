#!/usr/bin/env python3
import os
import subprocess
import sys

THIS_DIR = os.path.dirname(os.path.abspath(__file__))
SCRIPT = os.path.join(THIS_DIR, "dominium_client")
if not os.path.isfile(SCRIPT):
    print("client wrapper missing target: {}".format(SCRIPT))
    raise SystemExit(2)
raise SystemExit(subprocess.call([sys.executable, SCRIPT] + sys.argv[1:]))
