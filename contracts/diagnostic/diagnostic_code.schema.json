{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.diagnostics.diagnostic_code_schema.v1",
  "title": "Dominium Diagnostic Code",
  "type": "object",
  "required": [
    "id",
    "code",
    "owner",
    "severity",
    "category",
    "stability",
    "summary",
    "cause",
    "recovery",
    "evidence_expectation",
    "proof"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^dominium\\.diagnostic\\.[a-z0-9][a-z0-9_.-]+$"
    },
    "code": {
      "type": "string",
      "pattern": "^DOM-[A-Z0-9]+(-[A-Z0-9]+)*$"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "stability": {
      "type": "string",
      "enum": [
        "provisional",
        "stable",
        "internal",
        "generated",
        "fixture",
        "historical",
        "retired"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "cause": {
      "type": "string",
      "minLength": 1
    },
    "recovery": {
      "type": "string"
    },
    "evidence_expectation": {
      "type": "string",
      "minLength": 1
    },
    "related_refusal_codes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "related_command_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "related_public_surface_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "related_artifact_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "proof": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
