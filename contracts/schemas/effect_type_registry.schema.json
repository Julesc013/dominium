{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Effect Type Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic CTRL-8 effect type registry output.",
  "x-doc-ref": [
    "docs/audit/EFFECT_SYSTEM_BASELINE.md",
    "docs/architecture/registry_compile.md",
    "schemas/effect_type.schema.json"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "effect_types",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "effect_types": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "effect_type_id",
          "description",
          "applies_to",
          "modifies",
          "default_visibility_policy_id",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "effect_type_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "applies_to": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "modifies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "default_visibility_policy_id": {
            "type": "string"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "effect_types": [],
      "registry_hash": "f7f4b4cfaaf5e7c6ad2e46bc04f04f0b8f4db22844fcd8ac7ddc44506e8c9a0f"
    }
  ]
}
