{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Drift Policy Schema",
  "version": "1.0.0",
  "description": "Deterministic TEMP-2 drift policy declaration for derived time mappings.",
  "x-doc-ref": [
    "docs/time/DRIFT_AND_SYNC_POLICY.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "drift_policy_id",
    "base_rate_multiplier",
    "deterministic_rng_stream",
    "max_skew_allowed",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "drift_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "base_rate_multiplier": {
      "type": "number",
      "minimum": 0
    },
    "deterministic_rng_stream": {
      "type": [
        "string",
        "null"
      ]
    },
    "max_skew_allowed": {
      "type": "integer",
      "minimum": 0
    },
    "deterministic_fingerprint": {
      "type": "string"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "drift_policy_id": "drift.linear_small",
      "base_rate_multiplier": 1.0005,
      "deterministic_rng_stream": null,
      "max_skew_allowed": 2,
      "deterministic_fingerprint": "",
      "extensions": {}
    }
  ]
}
