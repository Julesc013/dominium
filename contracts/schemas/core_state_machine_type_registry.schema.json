{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Core State Machine Type Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic core state machine type registry output.",
  "x-doc-ref": [
    "docs/architecture/CORE_ABSTRACTIONS.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "machine_types",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "machine_types": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "machine_type_id",
          "description",
          "states",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "machine_type_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "states": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "machine_types": [],
      "registry_hash": "b3e36be1ad0ec56f46ecf2be80440ec4a0f421d3a783f5ccf1eb18f6fd1d43cf"
    }
  ]
}

