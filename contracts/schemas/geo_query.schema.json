{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GEO Query Schema",
  "version": "1.0.0",
  "description": "Canonical GEO-0 deterministic query artifact for cache and proof routing.",
  "x-doc-ref": [
    "docs/geo/GEO_CONSTITUTION.md",
    "docs/canon/constitution_v1.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "query_kind",
    "inputs_hash",
    "outputs_hash",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "query_kind": {
      "type": "string",
      "enum": [
        "neighbors",
        "distance",
        "transform",
        "project"
      ]
    },
    "inputs_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "outputs_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "query_kind": "distance",
      "inputs_hash": "2801d6f2e90f75dc3db74023f88be7e50f8f0a679964df1fe9bbfd69ef6b7460",
      "outputs_hash": "47f801aa038f1d339455b6b84d670a164e7b3cc5ffb0cab6a2b70f428ff0c4bd",
      "deterministic_fingerprint": "598a1a2c2e616d1907414d3ef4f9f95427e7203b297c9b6f3e1881a7af57d0dc",
      "extensions": {}
    }
  ]
}
