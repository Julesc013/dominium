{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tier Contract Schema",
  "version": "1.0.0",
  "description": "Mandatory deterministic tier contract declaration for subsystem/process families.",
  "x-doc-ref": [
    "docs/meta/TIER_COUPLING_EXPLAIN_CONTRACTS.md",
    "docs/canon/constitution_v1.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "contract_id",
    "subsystem_id",
    "supported_tiers",
    "deterministic_degradation_order",
    "cost_model_id",
    "shard_safe",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "contract_id": {
      "type": "string",
      "minLength": 1
    },
    "subsystem_id": {
      "type": "string",
      "minLength": 1
    },
    "supported_tiers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "macro",
          "meso",
          "micro"
        ]
      }
    },
    "deterministic_degradation_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "macro",
          "meso",
          "micro"
        ]
      }
    },
    "cost_model_id": {
      "type": "string",
      "minLength": 1
    },
    "micro_roi_requirements": {
      "type": "object",
      "additionalProperties": true
    },
    "shard_safe": {
      "type": "boolean"
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "contract_id": "tier.elec.default",
      "subsystem_id": "ELEC",
      "supported_tiers": [
        "macro",
        "meso",
        "micro"
      ],
      "deterministic_degradation_order": [
        "micro",
        "meso",
        "macro"
      ],
      "cost_model_id": "cost.elec.default",
      "micro_roi_requirements": {
        "requires_roi_binding": true
      },
      "shard_safe": true,
      "deterministic_fingerprint": "6e613dc8a58bb1e2f991c0bbaf295ff5e7ab37ff0d053ef5f6ac4b0f03da0f4f",
      "extensions": {}
    }
  ]
}

