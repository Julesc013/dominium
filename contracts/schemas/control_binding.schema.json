{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Control Binding Schema",
  "version": "1.0.0",
  "description": "Canonical controller-to-target binding contract.",
  "x-doc-ref": [
    "docs/embodiment/CONTROL_SUBSTRATE_DOCTRINE.md",
    "docs/contracts/refusal_contract.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "binding_id",
    "controller_id",
    "binding_type",
    "target_id",
    "created_tick",
    "active",
    "required_entitlements",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "binding_id": {
      "type": "string"
    },
    "controller_id": {
      "type": "string"
    },
    "binding_type": {
      "type": "string",
      "enum": [
        "camera",
        "possess",
        "order"
      ]
    },
    "target_id": {
      "type": "string"
    },
    "created_tick": {
      "type": "integer",
      "minimum": 0
    },
    "active": {
      "type": "boolean"
    },
    "required_entitlements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "binding_id": "binding.controller.client.camera.main",
      "controller_id": "controller.client.default",
      "binding_type": "camera",
      "target_id": "camera.main",
      "created_tick": 0,
      "active": true,
      "required_entitlements": [
        "entitlement.control.camera"
      ],
      "extensions": {}
    }
  ]
}
