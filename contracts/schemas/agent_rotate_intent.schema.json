{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Rotate Intent Schema",
  "version": "1.0.0",
  "description": "Deterministic embodied rotation intent payload.",
  "x-doc-ref": [
    "docs/embodiment/MOVEMENT_PROCESSES.md",
    "docs/canon/constitution_v1.md §3 A1/A2",
    "docs/canon/glossary_v1.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "agent_id",
    "yaw_delta",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "agent_id": {
      "type": "string"
    },
    "yaw_delta": {
      "type": "integer"
    },
    "pitch_delta": {
      "type": "integer"
    },
    "roll_delta": {
      "type": "integer"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "agent_id": "agent.lab.navigator.001",
      "yaw_delta": 90000,
      "pitch_delta": 0,
      "roll_delta": 0,
      "extensions": {}
    }
  ]
}
