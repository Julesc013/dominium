{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Assembly Graph Schema",
  "version": "1.0.0",
  "description": "Canonical assembly graph declaration.",
  "x-doc-ref": [
    "docs/materials/BOM_AND_ASSEMBLY_GRAPH.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "ag_id",
    "description",
    "root_node_id",
    "nodes",
    "edges",
    "version_introduced",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "ag_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "root_node_id": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "ag_node.schema.json"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "ag_edge.schema.json"
      }
    },
    "instancing_rules": {
      "type": "object",
      "additionalProperties": true
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true
    },
    "version_introduced": {
      "type": "string",
      "minLength": 1
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "ag_id": "ag.example",
      "description": "Example deterministic assembly graph.",
      "root_node_id": "node.root",
      "nodes": {
        "node.root": {
          "schema_version": "1.0.0",
          "node_id": "node.root",
          "node_kind": "subassembly",
          "children": [],
          "local_transform": {
            "position_mm": {
              "x": 0,
              "y": 0,
              "z": 0
            },
            "orientation_mdeg": {
              "yaw": 0,
              "pitch": 0,
              "roll": 0
            },
            "scale_permille": 1000
          },
          "tags": [
            "root"
          ],
          "extensions": {}
        }
      },
      "edges": [],
      "instancing_rules": {},
      "constraints": {},
      "version_introduced": "1.0.0",
      "extensions": {}
    }
  ]
}
