{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Routing Rule Schema",
  "version": "1.0.0",
  "description": "Canonical deterministic routing rule declaration.",
  "x-doc-ref": [
    "docs/materials/LOGISTICS_GRAPH.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "rule_id",
    "description",
    "tie_break_policy",
    "allow_multi_hop",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "rule_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "tie_break_policy": {
      "type": "string",
      "minLength": 1
    },
    "allow_multi_hop": {
      "type": "boolean"
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "rule_id": "route.shortest_delay",
      "description": "Shortest delay route with deterministic tie-break.",
      "tie_break_policy": "edge_id_lexicographic",
      "allow_multi_hop": true,
      "constraints": {},
      "extensions": {}
    }
  ]
}
