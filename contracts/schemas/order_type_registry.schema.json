{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Order Type Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic order type registry output.",
  "x-doc-ref": [
    "docs/civilisation/ORDER_LANGUAGE.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "order_types",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "order_types": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "order_type_id",
          "description",
          "payload_schema_id",
          "allowed_target_kinds",
          "default_priority",
          "required_capabilities",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "order_type_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "payload_schema_id": {
            "type": "string"
          },
          "allowed_target_kinds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "default_priority": {
            "type": "integer",
            "minimum": 0
          },
          "required_capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "order_types": [],
      "registry_hash": "f6306f2be18e6daed9916eec703c2efcecc373fa5b29947f4942d85797dc8f5b"
    }
  ]
}
