{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Quantity Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic quantity registry output.",
  "x-doc-ref": [
    "docs/reality/CONSERVATION_AND_EXCEPTIONS.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "quantities",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {"type": "string", "const": "1.0.0"},
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pack_id", "version", "canonical_hash", "signature_status"],
        "additionalProperties": false,
        "properties": {
          "pack_id": {"type": "string"},
          "version": {"type": "string"},
          "canonical_hash": {"type": "string"},
          "signature_status": {"type": "string"}
        }
      }
    },
    "quantities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["quantity_id", "description", "numeric_type", "units_id", "extensions"],
        "additionalProperties": false,
        "properties": {
          "quantity_id": {"type": "string"},
          "description": {"type": "string"},
          "numeric_type": {"type": "string", "const": "fixed_point"},
          "units_id": {"type": "string"},
          "extensions": {"type": "object", "additionalProperties": true}
        }
      }
    },
    "registry_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"}
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "quantities": [],
      "registry_hash": "061922287ede293de247f6806682f4dd5078ca4e58ce39f95de2ecf550cd08af"
    }
  ]
}
