{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Exposure State Schema",
  "version": "1.0.0",
  "description": "Deterministic per-subject pollutant exposure accumulator state.",
  "x-doc-ref": [
    "docs/pollution/POLLUTION_CONSTITUTION.md",
    "docs/canon/constitution_v1.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "subject_id",
    "pollutant_id",
    "accumulated_exposure",
    "last_update_tick",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "subject_id": {
      "type": "string",
      "minLength": 1
    },
    "pollutant_id": {
      "type": "string",
      "minLength": 1
    },
    "accumulated_exposure": {
      "type": "number",
      "minimum": 0
    },
    "last_update_tick": {
      "type": "integer",
      "minimum": 0
    },
    "deterministic_fingerprint": {
      "type": "string"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "subject_id": "subject.example",
      "pollutant_id": "pollutant.toxic_gas_stub",
      "accumulated_exposure": 32,
      "last_update_tick": 20,
      "deterministic_fingerprint": "",
      "extensions": {}
    }
  ]
}
