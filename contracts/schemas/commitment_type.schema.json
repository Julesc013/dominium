{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Commitment Type Schema",
  "version": "1.0.0",
  "description": "Commitment type definition for causality strictness enforcement.",
  "x-doc-ref": [
    "docs/materials/NOTHING_JUST_HAPPENS.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "commitment_type_id",
    "description",
    "required_entitlements",
    "produces_event_type_ids",
    "strictness_requirements",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "commitment_type_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "required_entitlements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "produces_event_type_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "strictness_requirements": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "causality.C0",
          "causality.C1",
          "causality.C2"
        ]
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "commitment_type_id": "commitment_type_id.example",
      "description": "example",
      "extensions": {},
      "produces_event_type_ids": [],
      "required_entitlements": [],
      "schema_version": "1.0.0",
      "strictness_requirements": []
    }
  ]
}
