{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sync Policy Schema",
  "version": "1.0.0",
  "description": "Deterministic TEMP-2 synchronization policy declaration for domain-time correction.",
  "x-doc-ref": [
    "docs/time/DRIFT_AND_SYNC_POLICY.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "sync_policy_id",
    "adjustment_strategy",
    "max_adjust_per_tick",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "sync_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "adjustment_strategy": {
      "type": "string",
      "enum": [
        "observe",
        "adjust",
        "reject"
      ]
    },
    "max_adjust_per_tick": {
      "type": "integer",
      "minimum": 0
    },
    "deterministic_fingerprint": {
      "type": "string"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "sync_policy_id": "sync.adjust_on_receipt",
      "adjustment_strategy": "adjust",
      "max_adjust_per_tick": 5,
      "deterministic_fingerprint": "",
      "extensions": {}
    }
  ]
}
