{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Model Cache Policy Schema",
  "version": "1.0.0",
  "description": "Deterministic constitutive model cache policy row.",
  "type": "object",
  "required": ["schema_version", "cache_policy_id", "mode", "extensions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "cache_policy_id": {"type": "string", "minLength": 1},
    "mode": {"type": "string", "enum": ["none", "by_inputs_hash"]},
    "ttl_ticks": {"type": ["integer", "null"], "minimum": 0},
    "extensions": {"type": "object", "additionalProperties": true}
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "cache_policy_id": "cache.by_inputs_hash",
      "mode": "by_inputs_hash",
      "ttl_ticks": 60,
      "extensions": {}
    }
  ]
}
