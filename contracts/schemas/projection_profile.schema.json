{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Projection Profile Schema",
  "version": "1.0.0",
  "description": "Canonical GEO-0 projection and slice contract.",
  "x-doc-ref": [
    "docs/geo/GEO_CONSTITUTION.md",
    "docs/canon/constitution_v1.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "projection_profile_id",
    "projection_kind",
    "parameters",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "projection_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "projection_kind": {
      "type": "string",
      "enum": [
        "ortho_2d",
        "perspective_3d",
        "atlas_unwrap",
        "slice_nd_stub"
      ]
    },
    "parameters": {
      "type": "object",
      "additionalProperties": true
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "projection_profile_id": "geo.projection.perspective_3d",
      "projection_kind": "perspective_3d",
      "parameters": {
        "fov_deg": 60,
        "near_plane_mm": 1
      },
      "deterministic_fingerprint": "4b3f7b8fc3777c7b4a29cfe61367ee3a7075b3f1d572f1ce3f714ce59139c923",
      "extensions": {}
    }
  ]
}
