{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Thermal Node Kind Schema",
  "version": "1.0.0",
  "description": "Registry-driven THERM thermal node-kind row.",
  "x-doc-ref": [
    "docs/thermal/THERMAL_CONSTITUTION.md",
    "docs/audit/THERMAL_CONSTITUTION_BASELINE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "node_kind_id",
    "description",
    "tags",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "node_kind_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "node_kind_id": "thermal.node.exchanger_stub",
      "description": "Stub thermal exchange node.",
      "tags": [
        "thermal",
        "exchange"
      ],
      "deterministic_fingerprint": "9f2376d2fcfc7d2af0de1b5049893f0f76452b2fbcf9b05c3e627602f5dbf087",
      "extensions": {}
    }
  ]
}

