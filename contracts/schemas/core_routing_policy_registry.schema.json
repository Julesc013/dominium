{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Core Routing Policy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic core routing policy registry output.",
  "x-doc-ref": [
    "docs/architecture/CORE_ABSTRACTIONS.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "routing_policies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "routing_policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "policy_id",
          "description",
          "tie_break_policy",
          "allow_multi_hop",
          "optimization_metric",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "policy_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "tie_break_policy": {
            "type": "string",
            "minLength": 1
          },
          "allow_multi_hop": {
            "type": "boolean"
          },
          "optimization_metric": {
            "type": "string",
            "minLength": 1
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "routing_policies": [],
      "registry_hash": "eb95f311a82eb34879c88f3df43e97e217fdd98f2fa6d76d042d4f4f28479d90"
    }
  ]
}

