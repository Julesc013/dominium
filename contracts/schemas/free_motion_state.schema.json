{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Free Motion State Schema",
  "version": "1.0.0",
  "description": "Deterministic MOB-7 micro free-motion state row.",
  "x-doc-ref": [
    "docs/mobility/MICRO_FREE_MOTION.md",
    "docs/audit/MICRO_FREE_MOTION_BASELINE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "subject_id",
    "body_id",
    "velocity",
    "acceleration",
    "last_update_tick",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "subject_id": {
      "type": "string",
      "minLength": 1
    },
    "vehicle_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "agent_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "body_id": {
      "type": "string",
      "minLength": 1
    },
    "velocity": {
      "type": "object",
      "required": [
        "x",
        "y",
        "z"
      ],
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        },
        "z": {
          "type": "integer"
        }
      }
    },
    "acceleration": {
      "type": "object",
      "required": [
        "x",
        "y",
        "z"
      ],
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        },
        "z": {
          "type": "integer"
        }
      }
    },
    "corridor_geometry_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "volume_geometry_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_update_tick": {
      "type": "integer",
      "minimum": 0
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "oneOf": [
    {
      "required": [
        "vehicle_id"
      ],
      "properties": {
        "vehicle_id": {
          "type": "string",
          "minLength": 1
        },
        "agent_id": {
          "type": [
            "null",
            "string"
          ],
          "maxLength": 0
        }
      }
    },
    {
      "required": [
        "agent_id"
      ],
      "properties": {
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "vehicle_id": {
          "type": [
            "null",
            "string"
          ],
          "maxLength": 0
        }
      }
    }
  ],
  "examples": [
    {
      "schema_version": "1.0.0",
      "subject_id": "vehicle.mob.free.001",
      "vehicle_id": "vehicle.mob.free.001",
      "agent_id": null,
      "body_id": "body.vehicle.mob.free.001",
      "velocity": {
        "x": 120,
        "y": 0,
        "z": 0
      },
      "acceleration": {
        "x": 12,
        "y": 0,
        "z": 0
      },
      "corridor_geometry_id": "geometry.mob.free.corridor.001",
      "volume_geometry_id": null,
      "last_update_tick": 42,
      "deterministic_fingerprint": "c1c5d2b3b5f31175df7ebfd7f8fdf4401f1ef9c822e7eaaf22dd90ca52ec8d0a",
      "extensions": {}
    }
  ]
}
