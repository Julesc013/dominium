{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plan Intent Schema",
  "version": "1.0.0",
  "description": "Deterministic CTRL-4 planning request payload.",
  "x-doc-ref": [
    "docs/control/CONTROL_PLANE_CONSTITUTION.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "plan_intent_id",
    "requester_subject_id",
    "target_context",
    "plan_type_id",
    "parameters",
    "created_tick",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "plan_intent_id": {
      "type": "string",
      "minLength": 1
    },
    "requester_subject_id": {
      "type": "string",
      "minLength": 1
    },
    "target_context": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "site_ref": {
          "type": "string",
          "minLength": 1
        },
        "region_id": {
          "type": "string",
          "minLength": 1
        },
        "spatial_node_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "anyOf": [
        {
          "required": [
            "site_ref"
          ]
        },
        {
          "required": [
            "region_id"
          ]
        },
        {
          "required": [
            "spatial_node_id"
          ]
        }
      ]
    },
    "plan_type_id": {
      "type": "string",
      "enum": [
        "structure",
        "track",
        "road",
        "vehicle",
        "custom"
      ]
    },
    "parameters": {
      "type": "object",
      "additionalProperties": true
    },
    "created_tick": {
      "type": "integer",
      "minimum": 0
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "plan_intent_id": "plan.intent.c57a9c3183f8ec8f0a8d14f7",
      "requester_subject_id": "agent.alpha",
      "target_context": {
        "site_ref": "site.alpha.001",
        "region_id": "region.alpha",
        "spatial_node_id": "node.alpha.001"
      },
      "plan_type_id": "structure",
      "parameters": {
        "blueprint_id": "blueprint.hab.module",
        "logistics_node_id": "log.node.alpha"
      },
      "created_tick": 42,
      "deterministic_fingerprint": "f48cd52c359edec9d62892550c8f7a4517aaf8f0191f0f3547ec254af37151e6",
      "extensions": {}
    }
  ]
}
