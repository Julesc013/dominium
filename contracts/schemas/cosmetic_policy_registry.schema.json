{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cosmetic Policy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic cosmetic policy registry output.",
  "x-doc-ref": [
    "docs/embodiment/REPRESENTATION_LAYER.md",
    "docs/net/RANKED_SERVER_GOVERNANCE.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "policies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "policy_id",
          "description",
          "allow_unsigned_packs",
          "require_signed_packs",
          "allowed_cosmetic_ids",
          "allowed_pack_ids",
          "refusal_codes",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "policy_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "allow_unsigned_packs": {
            "type": "boolean"
          },
          "require_signed_packs": {
            "type": "boolean"
          },
          "allowed_cosmetic_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allowed_pack_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "refusal_codes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "policies": [],
      "registry_hash": "cb930ad2f4984ce17ff6dc78d2ef86ca976b8107b109188d1ac79953e2f00f22"
    }
  ]
}
