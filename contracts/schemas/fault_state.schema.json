{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Electrical Fault State Schema",
  "version": "1.0.0",
  "description": "Deterministic ELEC-2 electrical fault state row.",
  "x-doc-ref": [
    "docs/electric/PROTECTION_AND_FAULT_MODEL.md",
    "docs/audit/ELECTRICAL_PROTECTION_BASELINE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "fault_id",
    "fault_kind_id",
    "target_kind",
    "target_id",
    "detected_tick",
    "severity",
    "active",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "fault_id": {
      "type": "string",
      "minLength": 1
    },
    "fault_kind_id": {
      "type": "string",
      "minLength": 1
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "node",
        "edge",
        "device"
      ]
    },
    "target_id": {
      "type": "string",
      "minLength": 1
    },
    "detected_tick": {
      "type": "integer",
      "minimum": 0
    },
    "severity": {
      "type": "integer",
      "minimum": 0
    },
    "active": {
      "type": "boolean"
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "fault_id": "fault.elec.00ab12cd34ef5678",
      "fault_kind_id": "fault.overcurrent",
      "target_kind": "edge",
      "target_id": "edge.elec.main",
      "detected_tick": 42,
      "severity": 760,
      "active": true,
      "deterministic_fingerprint": "2a6db3e510f02f7a6f1a6c9c7aa6ae292f0ac7eb04622cb95e4f61773099795f",
      "extensions": {}
    }
  ]
}
