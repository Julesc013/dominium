{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cohort Mapping Policy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic cohort mapping policy registry output.",
  "x-doc-ref": [
    "docs/civilisation/COHORT_MODEL.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "policies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "mapping_policy_id",
          "description",
          "max_micro_agents_per_cohort",
          "spawn_distribution_rules",
          "collapse_aggregation_rules",
          "anonymous_micro_agents",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "mapping_policy_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "max_micro_agents_per_cohort": {
            "type": "integer",
            "minimum": 0
          },
          "spawn_distribution_rules": {
            "type": "object",
            "additionalProperties": true
          },
          "collapse_aggregation_rules": {
            "type": "object",
            "additionalProperties": true
          },
          "anonymous_micro_agents": {
            "type": "boolean"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "policies": [],
      "registry_hash": "f6306f2be18e6daed9916eec703c2efcecc373fa5b29947f4942d85797dc8f5b"
    }
  ]
}

