{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Epistemic Memory Item Schema",
  "version": "1.0.0",
  "description": "Deterministic memory item derived from PerceivedModel channels.",
  "x-doc-ref": [
    "docs/epistemics/MEMORY_AND_FOG_OF_WAR.md",
    "docs/net/EPISTEMIC_SCOPE_AND_FOG_OF_WAR.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "memory_item_id",
    "owner_subject_id",
    "source_tick",
    "last_refresh_tick",
    "channel_id",
    "subject_kind",
    "subject_id",
    "payload",
    "precision_tag",
    "ttl_ticks",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "memory_item_id": {
      "type": "string",
      "minLength": 1
    },
    "owner_subject_id": {
      "type": "string",
      "minLength": 1
    },
    "source_tick": {
      "type": "integer",
      "minimum": 0
    },
    "last_refresh_tick": {
      "type": "integer",
      "minimum": 0
    },
    "channel_id": {
      "type": "string",
      "minLength": 1
    },
    "subject_kind": {
      "type": "string",
      "enum": [
        "entity",
        "region",
        "event",
        "signal",
        "custom"
      ]
    },
    "subject_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "precision_tag": {
      "type": "string",
      "enum": [
        "coarse",
        "medium",
        "fine"
      ]
    },
    "ttl_ticks": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "memory_item_id": "mem.item.6c0e8388d5f35456",
      "owner_subject_id": "peer.client.alpha",
      "source_tick": 128,
      "last_refresh_tick": 130,
      "channel_id": "ch.core.entities",
      "subject_kind": "entity",
      "subject_id": "agent.alpha",
      "payload": {
        "entity_id": "agent.alpha",
        "last_known_transform_mm": {
          "x": 1000,
          "y": 2000,
          "z": 0
        }
      },
      "precision_tag": "medium",
      "ttl_ticks": 200,
      "extensions": {}
    }
  ]
}
