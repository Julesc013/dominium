{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Signal Type Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic signal type registry output.",
  "x-doc-ref": [
    "docs/mobility/SIGNALING_AND_INTERLOCKING.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "signal_types",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "signal_types": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "signal_type_id",
          "schema_ref",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "signal_type_id": {
            "type": "string",
            "minLength": 1
          },
          "schema_ref": {
            "type": "string",
            "minLength": 1
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "signal_types": [],
      "registry_hash": "403f7894f6e32af9f8ef2ea57d8eb4517a6493deaa040ca539f67de33411ce84"
    }
  ]
}
