{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Compaction Marker Schema",
  "version": "1.0.0",
  "description": "Canonical deterministic provenance compaction marker.",
  "x-doc-ref": [
    "docs/meta/PROVENANCE_AND_COMPACTION_CONSTITUTION.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "marker_id",
    "shard_id",
    "start_tick",
    "end_tick",
    "pre_compaction_hash",
    "post_compaction_hash",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "marker_id": {
      "type": "string",
      "minLength": 1
    },
    "shard_id": {
      "type": "string",
      "minLength": 1
    },
    "start_tick": {
      "type": "integer",
      "minimum": 0
    },
    "end_tick": {
      "type": "integer",
      "minimum": 0
    },
    "pre_compaction_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "post_compaction_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "start_tick": {
            "type": "integer"
          },
          "end_tick": {
            "type": "integer"
          }
        },
        "required": [
          "start_tick",
          "end_tick"
        ]
      },
      "then": {
        "properties": {
          "end_tick": {
            "minimum": 0
          }
        }
      }
    }
  ],
  "examples": [
    {
      "schema_version": "1.0.0",
      "marker_id": "compaction.marker.c3d87fd2f0f17639",
      "shard_id": "shard.0",
      "start_tick": 1024,
      "end_tick": 2048,
      "pre_compaction_hash": "fca11bd4f25e6256bccf85bb6b64331a6bac4fd255fd11252247e7b7f8018f7f",
      "post_compaction_hash": "8f75bd42407a7aa7068c0e6cb2d57915c48fb53fce5ac2f84b20becece5f0f84",
      "deterministic_fingerprint": "ba4f1c8bd870ad15e2980bcfddcaec4009ac2abeb832c71bc9954906a199f5cc",
      "extensions": {}
    }
  ]
}
