{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Demography Policy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic demography policy registry output.",
  "x-doc-ref": [
    "docs/civilisation/DEMOGRAPHY_OPTIONALITY.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "policies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "demography_policy_id",
          "births_enabled",
          "death_model_id",
          "birth_model_id",
          "migration_model_id",
          "tick_rate",
          "deterministic_tie_break_id",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "demography_policy_id": {
            "type": "string"
          },
          "births_enabled": {
            "type": "boolean"
          },
          "death_model_id": {
            "type": "string"
          },
          "birth_model_id": {
            "type": "string"
          },
          "migration_model_id": {
            "type": "string"
          },
          "tick_rate": {
            "type": "integer",
            "minimum": 1
          },
          "deterministic_tie_break_id": {
            "type": "string"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "policies": [],
      "registry_hash": "f6306f2be18e6daed9916eec703c2efcecc373fa5b29947f4942d85797dc8f5b"
    }
  ]
}

