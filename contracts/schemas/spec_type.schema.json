{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spec Type Schema",
  "version": "1.0.0",
  "description": "Deterministic SPEC-1 spec type declaration.",
  "x-doc-ref": [
    "docs/specs/SPECSHEET_CONSTITUTION.md",
    "docs/audit/SPECSHEET_BASELINE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "spec_type_id",
    "description",
    "parameter_schema_id",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "spec_type_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "parameter_schema_id": {
      "type": "string",
      "minLength": 1
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "spec_type_id": "spec.track",
      "description": "Track engineering specification type.",
      "parameter_schema_id": "dominium.schema.spec.params.track.v1",
      "extensions": {}
    }
  ]
}
