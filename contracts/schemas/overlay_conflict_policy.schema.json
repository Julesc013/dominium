{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Overlay Conflict Policy Schema",
  "version": "1.0.0",
  "description": "Deterministic GEO-9 overlay conflict behavior modes.",
  "x-doc-ref": [
    "docs/canon/constitution_v1.md §3 A1/A10",
    "docs/geo/OVERLAY_CONFLICT_POLICIES.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "policy_id",
    "mode",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "policy_id": {
      "type": "string",
      "pattern": "^overlay\\.conflict\\.[a-z0-9_.-]+$"
    },
    "mode": {
      "type": "string",
      "enum": [
        "last_wins",
        "refuse",
        "prompt_stub"
      ]
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object"
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "policy_id": "overlay.conflict.refuse",
      "mode": "refuse",
      "deterministic_fingerprint": "39245e9f2d28cc32f9374b18af2bc0318f8f7a3dfb80d60c5fd8f1ee650c5c67",
      "extensions": {
        "remediation_hint": "remedy.overlay.resolve_conflict_or_change_policy"
      }
    }
  ]
}
