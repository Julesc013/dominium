{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pollutant Type Schema",
  "version": "1.0.0",
  "description": "Canonical POLL pollutant taxonomy entry used for deterministic emission accounting and policy defaults.",
  "x-doc-ref": [
    "docs/pollution/POLLUTION_CONSTITUTION.md",
    "docs/canon/constitution_v1.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "pollutant_id",
    "description",
    "medium",
    "default_decay_model_id",
    "default_dispersion_policy_id",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "pollutant_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "medium": {
      "type": "string",
      "enum": [
        "air",
        "water",
        "soil",
        "multi"
      ]
    },
    "default_decay_model_id": {
      "type": "string",
      "minLength": 1
    },
    "default_dispersion_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "deterministic_fingerprint": {
      "type": "string"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "pollutant_id": "pollutant.smoke_particulate",
      "description": "Combustion smoke particulate proxy.",
      "medium": "air",
      "default_decay_model_id": "model.poll_decay_half_life_stub",
      "default_dispersion_policy_id": "poll.policy.coarse_diffuse",
      "deterministic_fingerprint": "",
      "extensions": {}
    }
  ]
}
