{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pressure Vessel State Schema",
  "version": "1.0.0",
  "description": "Deterministic FLUID pressure vessel state row.",
  "x-doc-ref": [
    "docs/fluid/CONTAINMENT_AND_FAILURE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "node_id",
    "current_head",
    "last_update_tick",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "current_head": {
      "type": "integer"
    },
    "last_update_tick": {
      "type": "integer",
      "minimum": 0
    },
    "deterministic_fingerprint": {
      "type": "string"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "node_id": "node.vessel.alpha",
      "current_head": 1250,
      "last_update_tick": 420,
      "deterministic_fingerprint": "8c0e96b5089ec5f6b6d2a8f8d5138494ed6eab97f2f0127358f5a53117d7cb9d",
      "extensions": {}
    }
  ]
}
