{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spec Sheet Schema",
  "version": "1.0.0",
  "description": "Deterministic SPEC-1 SpecSheet declaration contract.",
  "x-doc-ref": [
    "docs/specs/SPECSHEET_CONSTITUTION.md",
    "docs/audit/SPECSHEET_BASELINE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "spec_id",
    "spec_type_id",
    "description",
    "parameters",
    "compliance_check_ids",
    "version_introduced",
    "deprecated",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "spec_id": {
      "type": "string",
      "minLength": 1
    },
    "spec_type_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "parameters": {
      "type": "object",
      "additionalProperties": true
    },
    "tolerance_policy_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "compliance_check_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "version_introduced": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "deprecated": {
      "type": "boolean"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "spec_id": "spec.track.standard_gauge.v1",
      "spec_type_id": "spec.track",
      "description": "Example standard gauge track profile.",
      "parameters": {
        "gauge_mm": 1435,
        "max_curvature_radius_mm": 200000
      },
      "tolerance_policy_id": "tol.default",
      "compliance_check_ids": [
        "check.geometry.clearance",
        "check.geometry.curvature_limit",
        "check.operation.max_speed_policy"
      ],
      "version_introduced": "1.0.0",
      "deprecated": false,
      "extensions": {}
    }
  ]
}
