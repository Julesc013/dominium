{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BOM Schema",
  "version": "1.0.0",
  "description": "Canonical bill-of-materials declaration.",
  "x-doc-ref": [
    "docs/materials/BOM_AND_ASSEMBLY_GRAPH.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "bom_id",
    "description",
    "required_materials",
    "version_introduced",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "bom_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "required_materials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "material_id_or_class",
          "quantity_mass_raw"
        ],
        "additionalProperties": false,
        "properties": {
          "material_id_or_class": {
            "type": "string",
            "minLength": 1
          },
          "quantity_mass_raw": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "required_part_classes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "part_class_id",
          "count"
        ],
        "additionalProperties": false,
        "properties": {
          "part_class_id": {
            "type": "string",
            "minLength": 1
          },
          "count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "tolerances": {
      "type": "object",
      "additionalProperties": true
    },
    "version_introduced": {
      "type": "string",
      "minLength": 1
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "bom_id": "bom.example",
      "description": "Example deterministic BOM.",
      "required_materials": [
        {
          "material_id_or_class": "material.steel_basic",
          "quantity_mass_raw": 16777216
        }
      ],
      "required_part_classes": [
        {
          "part_class_id": "partclass.beam.generic",
          "count": 2
        }
      ],
      "tolerances": {},
      "version_introduced": "1.0.0",
      "extensions": {}
    }
  ]
}
