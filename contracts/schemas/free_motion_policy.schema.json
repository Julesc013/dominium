{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Free Motion Policy Schema",
  "version": "1.0.0",
  "description": "Deterministic MOB-7 micro free-motion policy row.",
  "x-doc-ref": [
    "docs/mobility/MICRO_FREE_MOTION.md",
    "docs/audit/MICRO_FREE_MOTION_BASELINE.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "policy_id",
    "max_speed",
    "max_accel",
    "traction_model_id",
    "wind_model_id",
    "corridor_enforcement_mode",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "max_speed": {
      "type": "integer",
      "minimum": 1
    },
    "max_accel": {
      "type": "integer",
      "minimum": 1
    },
    "traction_model_id": {
      "type": "string",
      "minLength": 1
    },
    "wind_model_id": {
      "type": "string",
      "minLength": 1
    },
    "wind_scale_permille": {
      "type": "integer",
      "minimum": 0
    },
    "corridor_enforcement_mode": {
      "type": "string",
      "enum": [
        "clamp",
        "refuse",
        "warn"
      ]
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "policy_id": "free.default_ground",
      "max_speed": 1200,
      "max_accel": 96,
      "traction_model_id": "traction.basic_friction",
      "wind_model_id": "wind.basic_drift",
      "wind_scale_permille": 300,
      "corridor_enforcement_mode": "clamp",
      "deterministic_fingerprint": "f63f7b4596a428f178fd1c6c4e52b98198ba4fc2e11f7c2f4ba9ec4be4136e88",
      "extensions": {}
    }
  ]
}
