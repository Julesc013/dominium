{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Network Snapshot Schema",
  "version": "1.0.0",
  "description": "Deterministic network snapshot metadata contract.",
  "x-doc-ref": [
    "docs/net/MULTIPLAYER_MODEL_OVERVIEW.md",
    "docs/net/REPLICATION_POLICIES.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "snapshot_id",
    "tick",
    "shard_id",
    "pack_lock_hash",
    "registry_hashes",
    "truth_snapshot_hash",
    "payload_ref",
    "schema_versions",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "tick": {
      "type": "integer",
      "minimum": 0
    },
    "shard_id": {
      "type": "string",
      "minLength": 1
    },
    "pack_lock_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "registry_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[A-Fa-f0-9]{64}$"
      }
    },
    "truth_snapshot_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "payload_ref": {
      "type": "string",
      "minLength": 1
    },
    "schema_versions": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "snapshot_id": "snapshot.shard.0.tick.120",
      "tick": 120,
      "shard_id": "shard.0",
      "pack_lock_hash": "83e022ebf2ffc2686d0c2b8854b24b3febd5c80edbe06b3f4a0931575d8eb1b8",
      "registry_hashes": {},
      "truth_snapshot_hash": "bf93cfcb5339fd3f15adceffde26bd249ce7ea6af3788f4aa2b46305211c7d4f",
      "payload_ref": "artifact://snapshot/shard.0/tick.120",
      "schema_versions": {
        "session_spec": "1.0.0"
      },
      "extensions": {}
    }
  ]
}
