{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Profile Trace Schema",
  "version": "1.0.0",
  "description": "Deterministic, non-gating profiling artifact contract for developer acceleration traces.",
  "x-doc-ref": [
    "docs/dev/DEVELOPER_ACCELERATION_MODEL.md",
    "docs/dev/IMPACT_GRAPH.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "trace_id",
    "artifact_class",
    "deterministic",
    "bii",
    "bundle_id",
    "session_id",
    "scenario_id",
    "pack_lock_hash",
    "registry_hashes",
    "metrics",
    "capture_meta",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "artifact_class": {
      "type": "string",
      "enum": [
        "DERIVED"
      ]
    },
    "deterministic": {
      "type": "boolean",
      "const": true
    },
    "bii": {
      "type": "string",
      "minLength": 1
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "scenario_id": {
      "type": "string",
      "minLength": 1
    },
    "pack_lock_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "registry_hashes": {
      "type": "object",
      "required": [
        "domain_registry_hash",
        "law_registry_hash",
        "experience_registry_hash",
        "lens_registry_hash",
        "net_replication_policy_registry_hash",
        "net_resync_strategy_registry_hash",
        "net_server_policy_registry_hash",
        "securex_policy_registry_hash",
        "server_profile_registry_hash",
        "shard_map_registry_hash",
        "perception_interest_policy_registry_hash",
        "anti_cheat_policy_registry_hash",
        "anti_cheat_module_registry_hash",
        "activation_policy_registry_hash",
        "budget_policy_registry_hash",
        "fidelity_policy_registry_hash",
        "worldgen_constraints_registry_hash",
        "astronomy_catalog_index_hash",
        "site_registry_index_hash",
        "ephemeris_registry_hash",
        "terrain_tile_registry_hash",
        "ui_registry_hash"
      ],
      "additionalProperties": false,
      "properties": {
        "domain_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "law_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "experience_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "lens_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "net_replication_policy_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "net_resync_strategy_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "net_server_policy_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "securex_policy_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "server_profile_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "shard_map_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "perception_interest_policy_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "anti_cheat_policy_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "anti_cheat_module_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "activation_policy_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "budget_policy_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "fidelity_policy_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "worldgen_constraints_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "astronomy_catalog_index_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "site_registry_index_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "ephemeris_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "terrain_tile_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "ui_registry_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": [
        "metric_schema_version",
        "resolved_pack_count",
        "registry_count",
        "estimated_compute_units",
        "profile_ms"
      ],
      "additionalProperties": false,
      "properties": {
        "metric_schema_version": {
          "type": "string",
          "const": "1.0.0"
        },
        "resolved_pack_count": {
          "type": "integer",
          "minimum": 0
        },
        "registry_count": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_compute_units": {
          "type": "integer",
          "minimum": 0
        },
        "profile_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "capture_meta": {
      "type": "object",
      "required": [
        "tool_id",
        "tool_version",
        "source_lockfile_path",
        "source_registry_dir"
      ],
      "additionalProperties": false,
      "properties": {
        "tool_id": {
          "type": "string",
          "const": "tool_profile_capture"
        },
        "tool_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "source_lockfile_path": {
          "type": "string",
          "minLength": 1
        },
        "source_registry_dir": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
