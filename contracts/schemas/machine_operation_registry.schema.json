{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Machine Operation Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic machine operation registry output.",
  "x-doc-ref": [
    "docs/interaction/MACHINE_PORTS.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "operations",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "operation_id",
          "description",
          "machine_type_ids",
          "input_materials",
          "output_materials",
          "energy_delta_raw",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "operation_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "machine_type_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "input_materials": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "minimum": 0
            }
          },
          "output_materials": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "minimum": 0
            }
          },
          "energy_delta_raw": {
            "type": "integer"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "operations": [
        {
          "schema_version": "1.0.0",
          "operation_id": "op.saw_planks",
          "description": "Convert wood logs to planks",
          "machine_type_ids": [
            "machine.sawmill.basic"
          ],
          "input_materials": {
            "material.wood_basic": 1000
          },
          "output_materials": {
            "material.wood_basic": 1000
          },
          "energy_delta_raw": 0,
          "extensions": {}
        }
      ],
      "registry_hash": "403f7894f6e32af9f8ef2ea57d8eb4517a6493deaa040ca539f67de33411ce84"
    }
  ]
}
