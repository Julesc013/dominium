{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blueprint Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic blueprint catalog registry output.",
  "x-doc-ref": [
    "docs/materials/BOM_AND_ASSEMBLY_GRAPH.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "blueprints",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array"
    },
    "blueprints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "blueprint_id",
          "description",
          "blueprint_path",
          "tags",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "blueprint_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "blueprint_path": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "blueprints": [],
      "registry_hash": "403f7894f6e32af9f8ef2ea57d8eb4517a6493deaa040ca539f67de33411ce84"
    }
  ]
}
