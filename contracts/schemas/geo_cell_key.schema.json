{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Geo Cell Key Schema",
  "version": "1.0.0",
  "description": "Canonical GEO-1 deterministic spatial cell address.",
  "x-doc-ref": [
    "docs/geo/SPATIAL_INDEX_AND_IDENTITY.md",
    "docs/geo/GEO_CONSTITUTION.md",
    "docs/canon/constitution_v1.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "partition_profile_id",
    "topology_profile_id",
    "chart_id",
    "index_tuple",
    "refinement_level",
    "deterministic_fingerprint",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "partition_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "topology_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "chart_id": {
      "type": "string",
      "minLength": 1
    },
    "index_tuple": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "integer",
        "minimum": -9223372036854775808,
        "maximum": 9223372036854775807
      }
    },
    "refinement_level": {
      "type": "integer",
      "minimum": 0
    },
    "deterministic_fingerprint": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "partition_profile_id": "geo.partition.grid_zd",
      "topology_profile_id": "geo.topology.r3_infinite",
      "chart_id": "chart.global.r3",
      "index_tuple": [
        12,
        -4,
        99
      ],
      "refinement_level": 0,
      "deterministic_fingerprint": "f6b9e8cc870fdf2e8c48e148cf611dbf6fbc85b3a59ff4c6d947136bb460e973",
      "extensions": {}
    }
  ]
}
