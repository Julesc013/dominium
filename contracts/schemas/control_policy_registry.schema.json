{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Control Policy Registry Schema",
  "version": "1.0.0",
  "description": "Derived deterministic control policy registry output.",
  "x-doc-ref": [
    "docs/control/CONTROL_PLANE_CONSTITUTION.md",
    "docs/architecture/registry_compile.md"
  ],
  "type": "object",
  "required": [
    "format_version",
    "generated_from",
    "policies",
    "registry_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "format_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_from": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pack_id",
          "version",
          "canonical_hash",
          "signature_status"
        ],
        "additionalProperties": false,
        "properties": {
          "pack_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "canonical_hash": {
            "type": "string"
          },
          "signature_status": {
            "type": "string"
          }
        }
      }
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "schema_version",
          "control_policy_id",
          "description",
          "allowed_actions",
          "allowed_abstraction_levels",
          "allowed_view_policies",
          "allowed_fidelity_ranges",
          "downgrade_rules",
          "strictness",
          "extensions"
        ],
        "additionalProperties": false,
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0"
          },
          "control_policy_id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "allowed_actions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allowed_abstraction_levels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allowed_view_policies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allowed_fidelity_ranges": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "downgrade_rules": {
            "type": "object",
            "additionalProperties": true
          },
          "strictness": {
            "type": "string"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "registry_hash": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "format_version": "1.0.0",
      "generated_from": [],
      "policies": [],
      "registry_hash": "90a0f3d307e94a17a665f8f8ead7db7f7931d61069b4b0c71f1014ec3e0f7187"
    }
  ]
}
