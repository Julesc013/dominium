{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Control Action Schema",
  "version": "1.0.0",
  "description": "Canonical control action to process/task/plan mapping contract.",
  "x-doc-ref": [
    "docs/control/CONTROL_PLANE_CONSTITUTION.md"
  ],
  "type": "object",
  "required": [
    "schema_version",
    "action_id",
    "display_name",
    "produces",
    "required_entitlements",
    "required_capabilities",
    "target_kinds",
    "extensions"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "action_id": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "produces": {
      "type": "object",
      "required": [
        "process_id",
        "task_type_id",
        "plan_intent_type"
      ],
      "additionalProperties": false,
      "properties": {
        "process_id": {
          "type": "string"
        },
        "task_type_id": {
          "type": "string"
        },
        "plan_intent_type": {
          "type": "string"
        }
      }
    },
    "required_entitlements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "target_kinds": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "surface",
          "pose_slot",
          "mount_point",
          "machine",
          "structure",
          "graph",
          "none"
        ]
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "action_id": "action.surface.execute_task",
      "display_name": "Execute Surface Task",
      "produces": {
        "process_id": "",
        "task_type_id": "task.tighten_fastener",
        "plan_intent_type": ""
      },
      "required_entitlements": [
        "entitlement.tool.use"
      ],
      "required_capabilities": [
        "capability.surface.execute"
      ],
      "target_kinds": [
        "surface"
      ],
      "extensions": {}
    }
  ]
}
