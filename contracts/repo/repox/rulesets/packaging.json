{
  "ruleset_id": "repox/packaging",
  "documentation": "docs/governance/REPOX_RULESETS.md#repoxpackaging",
  "rules": [
    {
      "rule_id": "INV-PKG-MANIFEST-FIELDS",
      "severity": "FAIL",
      "scope_paths": ["archive/generated/dist/pkg", "schema/distribution/pkg_manifest.schema"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-pkg-manifest-fields",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-PKG-CAPABILITY-METADATA",
      "severity": "FAIL",
      "scope_paths": ["archive/generated/dist/pkg", "data/profiles", "contracts/registry/product_graph.json"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-pkg-capability-metadata",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-PKG-SIGNATURE-POLICY",
      "severity": "FAIL",
      "scope_paths": ["archive/generated/dist/pkg", "schema/distribution/trust_policy.schema"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-pkg-signature-policy",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-DIST-SYS-SHIPPING",
      "severity": "FAIL",
      "scope_paths": ["archive/generated/dist/sys", "archive/generated/dist/pkg", "archive/generated/dist/meta"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-dist-sys-shipping",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-DERIVED-PKG-INDEX-FRESHNESS",
      "severity": "FAIL",
      "scope_paths": ["archive/generated/dist/pkg", "archive/generated/dist/meta", "tools/package/distribution"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-derived-pkg-index-freshness",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-PLATFORM-REGISTRY",
      "severity": "FAIL",
      "scope_paths": ["contracts/registry/platform_registry.json", "schema/distribution/platform_registry.schema", "archive/generated/dist/pkg"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-platform-registry",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-PLATFORM-ID-CANONICAL",
      "severity": "FAIL",
      "scope_paths": ["archive/generated/dist/pkg", "archive/generated/dist/meta", "archive/generated/dist/sym", "archive/generated/dist/sys", "contracts/registry/platform_registry.json", "contracts/registry/mode_backend.json"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-platform-id-canonical",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-DIST-SYS-DERIVED",
      "severity": "FAIL",
      "scope_paths": ["tools/package/distribution/pkg_pack_all.py", "CMakeLists.txt", "archive/generated/dist/sys", "archive/generated/dist/pkg"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-dist-sys-derived",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-PRODUCT-GRAPH-CONSTRAINTS",
      "severity": "FAIL",
      "scope_paths": ["contracts/registry/product_graph.json", "schema/distribution/product_graph.schema"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-product-graph-constraints",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-MODE-BACKEND-REGISTRY",
      "severity": "FAIL",
      "scope_paths": ["contracts/registry/mode_backend.json", "schema/ui/mode_backend.schema", "contracts/registry/platform_registry.json"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-mode-backend-registry",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-MODE-BACKEND-SELECTION",
      "severity": "FAIL",
      "scope_paths": ["launcher", "client", "setup", "app", "tools/package/launcher", "tools/package/setup", "contracts/registry/mode_backend.json"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-mode-backend-selection",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-PORTABLE-RUN-CONTRACT",
      "severity": "FAIL",
      "scope_paths": ["tools/package/launcher/launcher_cli.py", "tools/package/setup/setup_cli.py", "docs/development/PORTABLE_TESTING.md"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-portable-run-contract",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-BUILD-PRESET-CONTRACT",
      "severity": "FAIL",
      "scope_paths": ["CMakePresets.json", ".vscode/tasks.json", "docs/development/IDE_BUILD_DEFAULTS.md", "docs/build/BUILD_LANES.md"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-build-preset-contract",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-DIST-RELEASE-LANE-GATE",
      "severity": "FAIL",
      "scope_paths": ["CMakeLists.txt", "cmake/check_release_lane.cmake", "docs/build/BUILD_LANES.md", "docs/testing/ci/VERIFY_FAST_VS_FULL.md"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-dist-release-lane-gate",
      "exemption_policy": "allow_with_expiry"
    }
  ]
}
