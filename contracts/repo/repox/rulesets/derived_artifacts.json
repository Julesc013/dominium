{
  "ruleset_id": "repox/derived_artifacts",
  "documentation": "docs/governance/REPOX_RULESETS.md#repoxderived_artifacts",
  "rules": [
    {
      "rule_id": "INV-DERIVED-ARTIFACT-CONTRACT",
      "severity": "FAIL",
      "scope_paths": ["schema/governance/derived_artifact_contract.schema", "contracts/registry/derived_artifacts.json", "scripts/ci/check_repox_rules.py"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-derived-artifact-contract",
      "exemption_policy": "deny"
    },
    {
      "rule_id": "INV-SOLVER-CONTRACTS",
      "severity": "FAIL",
      "scope_paths": ["contracts/registry/solver_registry.json"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-solver-contracts",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-AUDITX-ARTIFACT-HEADERS",
      "severity": "FAIL",
      "scope_paths": ["docs/archive/audit/auditx", "tools/xstack/auditx/output"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-auditx-artifact-headers",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-AUDITX-DETERMINISM",
      "severity": "FAIL",
      "scope_paths": ["tools/auditx", "docs/archive/audit/auditx"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-auditx-determinism",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-AUDITX-NONRUNTIME",
      "severity": "FAIL",
      "scope_paths": ["engine", "game", "client", "server", "launcher", "setup", "libs", "tools/auditx"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-auditx-nonruntime",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-AUDITX-PROMOTION-CANDIDATE-SHAPE",
      "severity": "FAIL",
      "scope_paths": ["docs/archive/audit/auditx/PROMOTION_CANDIDATES.json", "tools/xstack/auditx/output", "scripts/ci/check_repox_rules.py"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-auditx-promotion-candidate-shape",
      "exemption_policy": "allow_with_expiry"
    },
    {
      "rule_id": "INV-AUDITX-OUTPUT-STALE",
      "severity": "WARN",
      "scope_paths": ["docs/archive/audit/auditx", "tools/auditx"],
      "documentation": "docs/governance/REPOX_RULESETS.md#inv-auditx-output-stale",
      "exemption_policy": "allow_with_expiry"
    }
  ]
}
