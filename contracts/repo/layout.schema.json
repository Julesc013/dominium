{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dominium.local/contracts/repo/layout.schema.json",
  "title": "Dominium Repository Layout Contract",
  "description": "Broad JSON Schema for the TOML-to-object shape of contracts/repo/layout.contract.toml.",
  "type": "object",
  "required": [
    "contract",
    "policy",
    "canonical_roots",
    "metadata_roots",
    "allowed_root_files",
    "transitional_aliases",
    "domain_roots",
    "generated_roots"
  ],
  "properties": {
    "contract": {
      "type": "object",
      "required": ["id", "status", "enforcement", "phase"],
      "properties": {
        "id": {
          "type": "string",
          "const": "dominium.repo.layout.v1"
        },
        "status": {
          "type": "string"
        },
        "enforcement": {
          "type": "string",
          "enum": ["audit", "strict", "disabled"]
        },
        "phase": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "default_for_unknown_root",
        "strict_fails_unknown_root",
        "strict_fails_forbidden_root",
        "strict_fails_missing_required_root",
        "generated_outputs_tracked",
        "source_repo_layout_is_not_runtime_layout"
      ],
      "properties": {
        "default_for_unknown_root": {
          "type": "string"
        },
        "strict_fails_unknown_root": {
          "type": "boolean"
        },
        "strict_fails_forbidden_root": {
          "type": "boolean"
        },
        "strict_fails_missing_required_root": {
          "type": "boolean"
        },
        "strict_fails_stale_alias_after_phase": {
          "type": "string"
        },
        "generated_outputs_tracked": {
          "type": "boolean"
        },
        "source_repo_layout_is_not_runtime_layout": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "canonical_roots": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/root_definition"
      }
    },
    "optional_roots": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/root_definition"
      }
    },
    "metadata_roots": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "object",
          "properties": {
            "allowed": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "allowed_root_files": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "object",
          "properties": {
            "allowed": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "patterns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "transitional_aliases": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["target", "action", "classification"],
        "properties": {
          "target": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "classification": {
            "type": "string"
          },
          "retire_by_phase": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "domain_roots": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["classification", "targets"],
        "properties": {
          "classification": {
            "type": "string",
            "const": "split_required_domain_root"
          },
          "targets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "generated_roots": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["classification"],
        "properties": {
          "purpose": {
            "type": "string"
          },
          "classification": {
            "type": "string"
          },
          "tracked": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "distribution_projection_note": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "text": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      ]
    }
  },
  "additionalProperties": true,
  "$defs": {
    "root_definition": {
      "type": "object",
      "required": ["purpose", "required", "category", "may_contain"],
      "properties": {
        "purpose": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "category": {
          "type": "string"
        },
        "may_contain": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "must_not_contain": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  }
}
