{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.artifact.ref_schema.v1",
  "title": "Dominium Artifact Reference",
  "type": "object",
  "required": [
    "artifact_id",
    "artifact_kind"
  ],
  "additionalProperties": true,
  "properties": {
    "artifact_id": {
      "type": "string"
    },
    "artifact_kind": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "hash": {
      "type": "string"
    },
    "path": {
      "type": "string",
      "description": "Optional non-authoritative location hint."
    },
    "schema_id": {
      "type": "string"
    }
  }
}
