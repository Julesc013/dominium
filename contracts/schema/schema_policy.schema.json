{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.schema.policy_schema.v1",
  "title": "Dominium Schema Policy",
  "type": "object",
  "required": [
    "schema_id",
    "owner",
    "version",
    "stability",
    "compatibility_range",
    "unknown_field_policy",
    "required_field_policy",
    "default_policy",
    "canonical_serialization",
    "migration_policy",
    "refusal_policy"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_id": {"type": "string", "minLength": 3},
    "owner": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "stability": {"type": "string"},
    "artifact_kinds": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "compatibility_range": {"type": ["string", "object"]},
    "unknown_field_policy": {"type": "string"},
    "required_field_policy": {"type": "string"},
    "default_policy": {"type": "string"},
    "defaults_are_silent": {"type": "boolean"},
    "canonical_serialization": {"type": "string"},
    "migration_policy": {"type": "string"},
    "refusal_policy": {"type": "string"},
    "fixtures": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "negative_fixtures": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "proof": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "notes": {"type": "string"}
  }
}
