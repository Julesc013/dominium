{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.evidence.packet_schema.v1",
  "title": "Dominium Evidence Packet",
  "type": "object",
  "required": [
    "status",
    "proof"
  ],
  "additionalProperties": true,
  "properties": {
    "evidence_id": {
      "type": "string",
      "description": "Stable or run-scoped evidence packet identifier."
    },
    "subject_id": {
      "type": "string",
      "description": "Command, task, artifact, validator, or surface being evidenced."
    },
    "subject_kind": {
      "type": "string",
      "enum": [
        "command",
        "task",
        "validator",
        "surface",
        "artifact",
        "release",
        "test",
        "runtime",
        "aide",
        "unknown"
      ]
    },
    "command_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "diagnostic_codes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "warning",
        "refused",
        "error",
        "pass",
        "pass_with_warnings",
        "fail",
        "blocked",
        "not_run",
        "partial"
      ]
    },
    "generated_at": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "repo_commit": {
      "type": "string"
    },
    "tool": {
      "type": "string"
    },
    "inputs": {
      "type": "object"
    },
    "outputs": {
      "type": "object"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "proof": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "object"
    },
    "related_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "$ref": "../artifact/artifact_ref.schema.json"
      },
      "description": "Optional structured artifact references. Paths are non-authoritative hints."
    },
    "validation_context": {
      "type": "object"
    },
    "notes": {
      "type": "string"
    }
  }
}
