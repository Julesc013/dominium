{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.module.descriptor.v1",
  "title": "Dominium Module Descriptor",
  "type": "object",
  "required": ["module_id", "module_kind", "owner", "version", "stability"],
  "properties": {
    "module_id": {"type": "string"},
    "module_kind": {"type": "string"},
    "owner": {"type": "string"},
    "version": {"type": "string"},
    "stability": {"type": "string"},
    "implementation_status": {"type": "string"},
    "implementation_path": {"type": ["string", "null"]},
    "implementation_path_is_identity": {"type": "boolean"},
    "provided_surfaces": {"type": "array", "items": {"type": "string"}},
    "required_surfaces": {"type": "array", "items": {"type": "string"}},
    "required_services": {"type": "array", "items": {"type": "string"}},
    "required_commands": {"type": "array", "items": {"type": "string"}},
    "required_capabilities": {"type": "array", "items": {"type": "string"}},
    "required_providers": {"type": "array", "items": {"type": "string"}},
    "documents": {"type": "array", "items": {"type": "string"}},
    "views": {"type": "array", "items": {"type": "string"}},
    "events": {"type": "array", "items": {"type": "string"}},
    "refusals": {"type": "array", "items": {"type": "string"}},
    "diagnostics": {"type": "array", "items": {"type": "string"}},
    "artifacts": {"type": "array", "items": {"type": "string"}},
    "packs": {"type": "array", "items": {"type": "string"}},
    "tests": {"type": "array", "items": {"type": "string"}},
    "proof": {"type": "array", "items": {"type": "string"}},
    "replacement_policy": {"type": "string"},
    "compatibility_policy": {"type": "string"},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
