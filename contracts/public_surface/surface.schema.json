{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.public_surface.surface.schema.v1",
  "title": "Dominium Public Surface Registry",
  "type": "object",
  "required": ["contract", "policy", "surface"],
  "additionalProperties": true,
  "properties": {
    "contract": {
      "type": "object",
      "required": ["id", "status", "owner", "purpose"],
      "properties": {
        "id": {"type": "string", "pattern": "^dominium\\.public_surface\\.registry\\.v[0-9]+$"},
        "status": {"type": "string"},
        "owner": {"type": "string"},
        "purpose": {"type": "string"}
      }
    },
    "policy": {
      "type": "object",
      "required": ["paths_are_identity", "implementation_is_contract", "generated_output_is_source_truth", "default_stability", "stable_requires_proof", "stable_requires_compatibility_policy"],
      "properties": {
        "paths_are_identity": {"const": false},
        "implementation_is_contract": {"const": false},
        "generated_output_is_source_truth": {"const": false},
        "ui_is_authority": {"const": false},
        "default_stability": {"type": "string"},
        "stable_requires_proof": {"const": true},
        "stable_requires_compatibility_policy": {"const": true}
      }
    },
    "surface": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "path", "owner", "stability", "proof", "compatibility", "replacement_policy", "notes"],
        "additionalProperties": true,
        "properties": {
          "id": {"type": "string", "pattern": "^(domino|dominium)(\\.[a-z0-9][a-z0-9_-]*)+\\.v[0-9]+$"},
          "kind": {"type": "string"},
          "path": {"type": "string", "minLength": 1},
          "owner": {"type": "string", "minLength": 1},
          "stability": {"type": "string"},
          "language": {"type": "string"},
          "version": {"type": "string"},
          "introduced": {"type": "string"},
          "proof": {"type": "array", "items": {"type": "string"}},
          "compatibility": {"type": "string"},
          "replacement_policy": {"type": "string"},
          "retirement_reason": {"type": "string"},
          "source": {"type": "string"},
          "generator": {"type": "string"},
          "notes": {"type": "string"}
        },
        "allOf": [
          {
            "if": {"properties": {"stability": {"enum": ["frozen_abi", "stable_api", "stable_data_contract", "stable_command_contract", "stable_protocol"]}}},
            "then": {
              "properties": {
                "proof": {"minItems": 1},
                "compatibility": {"minLength": 1}
              }
            }
          },
          {
            "if": {"properties": {"stability": {"const": "generated"}}},
            "then": {"required": ["source", "generator"]}
          },
          {
            "if": {"properties": {"stability": {"const": "retired"}}},
            "then": {"required": ["retirement_reason", "replacement_policy"]}
          }
        ]
      }
    }
  }
}
