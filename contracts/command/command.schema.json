{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.command.command_schema.v1",
  "title": "Dominium Command Surface Entry",
  "type": "object",
  "required": [
    "id",
    "version",
    "owner",
    "stability",
    "kind",
    "surfaces",
    "input_schema",
    "result_schema",
    "refusals",
    "required_capabilities",
    "service_owner",
    "proof",
    "compatibility",
    "replacement_policy"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(domino|dominium)(\\.[a-z0-9][a-z0-9_-]*)+$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "stability": {
      "type": "string",
      "enum": [
        "stable_command_contract",
        "provisional",
        "internal",
        "experimental",
        "historical",
        "retired"
      ]
    },
    "kind": {
      "type": "string"
    },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "input_schema": {
      "type": "string",
      "minLength": 1
    },
    "result_schema": {
      "type": "string",
      "minLength": 1
    },
    "refusals": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "events": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "evidence_schema": {
      "type": "string"
    },
    "required_capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "service_owner": {
      "type": "string",
      "minLength": 1
    },
    "proof": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compatibility": {
      "type": "string",
      "minLength": 1
    },
    "replacement_policy": {
      "type": "string",
      "minLength": 1
    },
    "planned": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    }
  }
}
