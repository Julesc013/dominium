{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.command.validation_run_input.v1",
  "title": "Validation Command Input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "target": {
      "type": "string",
      "description": "Optional target path, command ID, gate, tier, or validator scope."
    },
    "strict": {
      "type": "boolean",
      "default": true
    },
    "profile": {
      "type": "string",
      "enum": [
        "FAST",
        "STRICT",
        "FULL"
      ],
      "description": "Validation profile requested by the command caller."
    },
    "surface": {
      "type": "string",
      "enum": [
        "cli",
        "headless",
        "workbench",
        "aide",
        "test"
      ],
      "description": "Declared invocation surface for command/result parity checks."
    },
    "emit_reports": {
      "type": "boolean",
      "default": false,
      "description": "When true, the service adapter may write normal validation report artifacts."
    },
    "json_out": {
      "type": "string"
    },
    "md_out": {
      "type": "string"
    },
    "continue_on_fail": {
      "type": "boolean",
      "default": false
    }
  }
}
