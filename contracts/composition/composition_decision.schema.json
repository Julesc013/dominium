{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.composition.decision.v1",
  "title": "Dominium Composition Decision",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "composition_decision_id",
    "plan_ref",
    "status",
    "selected_profile_refs",
    "selected_pack_refs",
    "selected_module_refs",
    "selected_provider_refs",
    "capability_decisions",
    "refusal_refs",
    "diagnostic_refs",
    "conflict_reports",
    "lockfile_refs",
    "evidence_ref",
    "fallback_trace",
    "limitations",
    "source_refs",
    "generated_by",
    "deterministic_order_key"
  ],
  "properties": {
    "schema_id": {"type": "string", "const": "dominium.composition.decision"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "composition_decision_id": {"type": "string"},
    "plan_ref": {"type": "string"},
    "status": {"type": "string", "enum": ["selected", "degraded", "refused", "partial", "fixture_only", "planned"]},
    "selected_app_ref": {"type": ["string", "null"]},
    "selected_profile_refs": {"type": "array", "items": {"type": "string"}},
    "selected_pack_refs": {"type": "array", "items": {"type": "string"}},
    "selected_module_refs": {"type": "array", "items": {"type": "string"}},
    "selected_provider_refs": {"type": "array", "items": {"type": "string"}},
    "capability_decisions": {"type": "array", "items": {"type": "object"}},
    "refusal_refs": {"type": "array", "items": {"type": "string"}},
    "diagnostic_refs": {"type": "array", "items": {"type": "string"}},
    "conflict_reports": {"type": "array", "items": {"type": "object"}},
    "lockfile_refs": {"type": "array", "items": {"type": "string"}},
    "evidence_ref": {"type": "string"},
    "fallback_trace": {"type": "array", "items": {"type": "object"}},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "source_refs": {"type": "array", "items": {"type": "string"}},
    "generated_by": {"type": "string"},
    "deterministic_order_key": {"type": "string"},
    "support_claim": {"type": "boolean"},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
