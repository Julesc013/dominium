  "allowed_inference_classes": [
    {
      "inference_id": "structural_existence_from_live_tree",
      "rule": "A path present in the live repo may be treated as structurally real for intake."
    },
    {
      "inference_id": "family_assignment_from_path_and_file_role",
      "rule": "A source may be assigned to an artifact family when path plus file role makes the classification explicit."
    },
    {
      "inference_id": "derived_status_from_provenance",
      "rule": "A report or emitted artifact may be classified as derived when provenance is inspectable."
    },
    {
      "inference_id": "stale_or_transitional_from_explicit_markers",
      "rule": "Supersession metadata, quarantine roots, or stronger contradictory sources may mark an artifact stale or transitional."
    }
  ],
  "forbidden_inference_classes": [
    {
      "inference_id": "semantic_equivalence_from_name_similarity",
      "rule": "Do not infer semantic equivalence from similar names, nearby paths, or overlapping topics."
    },
    {
      "inference_id": "canonical_status_from_path_name_alone",
      "rule": "Do not infer canonical or legacy status from directory naming alone."
    },
    {
      "inference_id": "current_truth_from_historical_plan",
      "rule": "Do not let earlier planning assumptions override the live repo without current evidence."
    },
    {
      "inference_id": "silent_migration_or_defaulting",
      "rule": "Do not invent migrations, coercions, or semantic defaults."
    },
    {
      "inference_id": "generated_output_equals_current_state",
      "rule": "Do not assume a generated artifact reflects the current source snapshot without explicit provenance."
    }
  ],
  "review_escalation_conditions": [
