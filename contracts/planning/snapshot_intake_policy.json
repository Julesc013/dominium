  "quarantine_triggers": [
    {
      "trigger_id": "same_tier_material_conflict",
      "condition": "Two same-tier authoritative sources make materially incompatible claims in the same authority domain.",
      "default_action": "quarantine"
    },
    {
      "trigger_id": "parallel_canonical_implementation",
      "condition": "A transitional or legacy area appears to implement the same canonical concept as a live area.",
      "default_action": "quarantine"
    },
    {
      "trigger_id": "unsafe_ownership_resolution",
      "condition": "Ownership of a concept, interface, registry, or manifest cannot be determined safely.",
      "default_action": "quarantine"
    },
    {
      "trigger_id": "schema_projection_conflict",
      "condition": "schema/** and schemas/** disagree in a way that changes meaning or validator shape without an explicit projection rule.",
      "default_action": "quarantine"
    },
    {
      "trigger_id": "generated_artifact_without_provenance",
      "condition": "A generated artifact is being used as authority without explicit provenance or emission contract.",
      "default_action": "quarantine"
    },
    {
      "trigger_id": "silent_inference_required",
      "condition": "Continuing would require invented semantics, invented migration behavior, or invented structural ownership.",
      "default_action": "quarantine"
    }
  ],
