{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.versioning.version_compatibility.v1",
  "title": "Dominium Version Compatibility Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_id",
    "kind",
    "version",
    "owner",
    "lifecycle_state",
    "stability",
    "compatibility_range",
    "introduced_in",
    "migration_policy",
    "refusal_policy",
    "proof"
  ],
  "properties": {
    "surface_id": {"type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9_]+)+$"},
    "kind": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "owner": {"type": "string", "minLength": 1},
    "lifecycle_state": {"type": "string"},
    "stability": {"type": "string"},
    "compatibility_range": {"$ref": "compatibility_range.schema.json"},
    "introduced_in": {"type": "string", "minLength": 1},
    "deprecated_in": {"type": "string"},
    "retired_in": {"type": "string"},
    "removed_in": {"type": "string"},
    "replacement": {"type": "string"},
    "migration_policy": {"type": "object"},
    "refusal_policy": {"type": "object"},
    "proof": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "notes": {"type": "string"}
  }
}
