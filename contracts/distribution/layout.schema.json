{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dominium.local/contracts/distribution/layout.schema.json",
  "title": "Dominium Distribution Layout Contract",
  "type": "object",
  "required": [
    "contract",
    "policy",
    "logical_roots",
    "projections"
  ],
  "properties": {
    "contract": {
      "type": "object",
      "required": [
        "id",
        "status",
        "enforcement",
        "phase"
      ],
      "properties": {
        "id": {
          "const": "dominium.distribution.layout.v1"
        },
        "status": {
          "type": "string"
        },
        "enforcement": {
          "type": "string"
        },
        "phase": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": [
        "source_repo_layout_is_not_runtime_layout",
        "dist_is_generated_output",
        "package_exports_use_logical_roots",
        "absolute_host_paths_for_packages_forbidden",
        "validators_audit_only_by_default"
      ],
      "additionalProperties": {
        "type": [
          "boolean",
          "string",
          "number"
        ]
      }
    },
    "logical_roots": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "purpose",
          "mutable",
          "required_in_portable",
          "required_in_installed",
          "package_export_allowed"
        ],
        "properties": {
          "purpose": {
            "type": "string"
          },
          "mutable": {
            "type": [
              "boolean",
              "string"
            ]
          },
          "required_in_portable": {
            "type": [
              "boolean",
              "string"
            ]
          },
          "required_in_installed": {
            "type": [
              "boolean",
              "string"
            ]
          },
          "package_export_allowed": {
            "type": [
              "boolean",
              "string"
            ]
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "projections": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "platform_ids": {
      "type": "object",
      "properties": {
        "allowed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "provisional": {
          "type": "boolean"
        },
        "source": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
