  "schema_id": "dominium.schema.governance.controlx_policy",
  "schema_version": "1.0.0",
  "record": {
    "registry_id": "dominium.registry.controlx.policy",
    "registry_version": "1.0.0",
    "forbidden_patterns": [
      {
        "pattern_id": "controlx.forbid.stop_on_failure",
        "pattern": "\\bstop\\s+on\\s+failure\\b",
        "reason": "mechanical failures are remediated, not stop conditions",
        "stability": {
          "schema_version": "1.0.0",
          "stability_class_id": "provisional",
          "rationale": "MVP stub or first implementation",
          "future_series": "INF/TOOLING",
          "replacement_target": "Replace MVP tooling and workflow scaffolds with release-pinned infrastructure and governance surfaces.",
          "contract_id": "",
          "deterministic_fingerprint": "670275540f2734ebf482950b2aa09201a53ecfb4e5086fe44f6f2ad821a93a8c",
          "extensions": {}
        }
      },
      {
        "pattern_id": "controlx.forbid.ask_permission",
        "pattern": "\\b(do you want|should i proceed|please advise|would you like me)\\b",
        "reason": "permission-asking in remediation flow is not allowed",
        "stability": {
          "schema_version": "1.0.0",
          "stability_class_id": "provisional",
          "rationale": "MVP stub or first implementation",
          "future_series": "INF/TOOLING",
          "replacement_target": "Replace MVP tooling and workflow scaffolds with release-pinned infrastructure and governance surfaces.",
          "contract_id": "",
          "deterministic_fingerprint": "670275540f2734ebf482950b2aa09201a53ecfb4e5086fe44f6f2ad821a93a8c",
          "extensions": {}
        }
      },
      {
        "pattern_id": "controlx.forbid.bypass",
        "pattern": "\\b(bypass|disable|skip)\\s+(repox|testx|gate|governance)\\b",
        "reason": "gate and governance bypasses are forbidden",
        "stability": {
          "schema_version": "1.0.0",
          "stability_class_id": "provisional",
          "rationale": "MVP stub or first implementation",
          "future_series": "INF/TOOLING",
          "replacement_target": "Replace MVP tooling and workflow scaffolds with release-pinned infrastructure and governance surfaces.",
          "contract_id": "",
          "deterministic_fingerprint": "670275540f2734ebf482950b2aa09201a53ecfb4e5086fe44f6f2ad821a93a8c",
          "extensions": {}
        }
      },
      {
        "pattern_id": "controlx.forbid.schema_policy_bypass",
        "pattern": "\\b(ignore|bypass|skip)\\s+(the\\s+)?schema\\s+version\\s+policy\\b",
        "reason": "schema version policy cannot be bypassed in prompts",
        "stability": {
          "schema_version": "1.0.0",
          "stability_class_id": "provisional",
          "rationale": "MVP stub or first implementation",
          "future_series": "INF/TOOLING",
          "replacement_target": "Replace MVP tooling and workflow scaffolds with release-pinned infrastructure and governance surfaces.",
          "contract_id": "",
          "deterministic_fingerprint": "670275540f2734ebf482950b2aa09201a53ecfb4e5086fe44f6f2ad821a93a8c",
          "extensions": {}
        }
      },
      {
        "pattern_id": "controlx.forbid.workspace_escape",
        "pattern": "\\bwrite\\s+outside\\s+workspace\\b",
        "reason": "workspace isolation must remain enforced",
        "stability": {
          "schema_version": "1.0.0",
          "stability_class_id": "provisional",
          "rationale": "MVP stub or first implementation",
          "future_series": "INF/TOOLING",
          "replacement_target": "Replace MVP tooling and workflow scaffolds with release-pinned infrastructure and governance surfaces.",
          "contract_id": "",
          "deterministic_fingerprint": "670275540f2734ebf482950b2aa09201a53ecfb4e5086fe44f6f2ad821a93a8c",
          "extensions": {}
        }
      },
      {
        "pattern_id": "controlx.forbid.disable_determinism",
        "pattern": "\\bdisable\\s+determinism\\b",
        "reason": "determinism cannot be disabled by prompt directives",
        "stability": {
          "schema_version": "1.0.0",
          "stability_class_id": "provisional",
          "rationale": "MVP stub or first implementation",
          "future_series": "INF/TOOLING",
          "replacement_target": "Replace MVP tooling and workflow scaffolds with release-pinned infrastructure and governance surfaces.",
          "contract_id": "",
          "deterministic_fingerprint": "670275540f2734ebf482950b2aa09201a53ecfb4e5086fe44f6f2ad821a93a8c",
          "extensions": {}
        }
      },
      {
        "pattern_id": "controlx.forbid.raw_gate_calls",
        "pattern": "(check_repox_rules\\.py|\\bctest\\b|\\btool_ui_bind\\b|\\btool_ui_validate\\b|\\btool_ui_doc_annotate\\b|tools[\\\\/]performx[\\\\/]performx\\.py|\\bperformx\\.py\\b)",
        "reason": "raw gate or tool invocations are replaced by gate.py routing",
        "stability": {
          "schema_version": "1.0.0",
          "stability_class_id": "provisional",
          "rationale": "MVP stub or first implementation",
          "future_series": "INF/TOOLING",
          "replacement_target": "Replace MVP tooling and workflow scaffolds with release-pinned infrastructure and governance surfaces.",
          "contract_id": "",
          "deterministic_fingerprint": "670275540f2734ebf482950b2aa09201a53ecfb4e5086fe44f6f2ad821a93a8c",
          "extensions": {}
        }
      }
