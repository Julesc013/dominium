{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.platform.pointer_width_policy.schema.v1",
  "title": "Dominium Pointer Width Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "stable_format_id", "fields"],
  "properties": {
    "schema_version": {
      "const": "dominium.platform.pointer_width_policy.instance.v1"
    },
    "stable_format_id": {
      "type": "string",
      "pattern": "^(domino|dominium)(\\.[a-z0-9_]+)+$"
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "type": {
            "type": "string"
          },
          "encoding": {
            "type": "string",
            "enum": ["explicit_little_endian", "schema_declared", "not_persisted"]
          }
        }
      }
    }
  },
  "x-dominium-allowed_stable_types": ["u8", "u16", "u32", "u64", "i8", "i16", "i32", "i64", "fixed32", "fixed64", "le_u16", "le_u32", "le_u64", "le_i32", "le_i64"],
  "x-dominium-forbidden_persisted_types": ["size_t", "ptrdiff_t", "long", "unsigned long", "intptr_t", "uintptr_t", "raw_pointer", "native_object_layout", "native_padding", "pointer_order", "address_hash"]
}
