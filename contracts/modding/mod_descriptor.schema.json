{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.mod_pack.mod_descriptor.v1",
  "title": "Dominium Mod Descriptor",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "mod_id",
    "mod_kind",
    "trust_level",
    "owner",
    "version",
    "capabilities",
    "permissions",
    "dependencies",
    "conflicts",
    "payloads",
    "schemas_used",
    "determinism_impact",
    "security_impact",
    "review_status",
    "compatibility_range",
    "validation_fixtures",
    "diagnostic_codes",
    "refusal_codes"
  ],
  "properties": {
    "mod_id": {"type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9_-]+)+$"},
    "mod_kind": {
      "type": "string",
      "enum": [
        "data_pack",
        "schema_validated_pack",
        "scriptless_rule_data_pack",
        "workbench_module_pack",
        "external_process_adapter_pack",
        "native_provider_pack",
        "signed_native_provider_pack",
        "theme_pack",
        "ui_pack",
        "profile_pack",
        "module_pack",
        "fixture_pack"
      ]
    },
    "trust_level": {"type": "string"},
    "owner": {"type": "string"},
    "version": {"type": "string"},
    "capabilities": {"type": "array", "items": {"type": "string"}},
    "permissions": {"type": "array", "items": {"type": "string"}},
    "declared_permissions": {"type": "object"},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "conflicts": {"type": "array", "items": {"type": "string"}},
    "payloads": {"type": "array", "items": {"type": "object"}},
    "schemas_used": {"type": "array", "items": {"type": "string"}},
    "determinism_impact": {"type": "object"},
    "security_impact": {"type": "object"},
    "filesystem_access": {"type": "string"},
    "network_access": {"type": "string"},
    "process_access": {"type": "string"},
    "native_code": {"type": "boolean"},
    "external_process": {"type": "boolean"},
    "sandbox_required": {"type": "boolean"},
    "review_required": {"type": "boolean"},
    "signature_required": {"type": "boolean"},
    "allowed_contexts": {"type": "array", "items": {"type": "string"}},
    "review_status": {"type": "string"},
    "compatibility_range": {"type": "object"},
    "validation_fixtures": {"type": "array", "items": {"type": "string"}},
    "diagnostic_codes": {"type": "array", "items": {"type": "string"}},
    "refusal_codes": {"type": "array", "items": {"type": "string"}},
    "overlays": {"type": "array", "items": {"type": "object"}},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": "string"}
  }
}
