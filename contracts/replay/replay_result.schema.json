{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.replay.expected_result.v1",
  "title": "Dominium Command Replay Expected Result",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "expected_result_id",
    "command_ref",
    "result_ref",
    "result_schema_ref",
    "canonicalization_policy_ref",
    "hash_algorithm",
    "result_hash",
    "expected_diagnostic_refs",
    "expected_refusal_refs",
    "evidence_refs",
    "source_refs",
    "support_claim"
  ],
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "dominium.replay.expected_result"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "expected_result_id": {
      "type": "string"
    },
    "command_ref": {
      "type": "string"
    },
    "result_ref": {
      "type": "string"
    },
    "result_schema_ref": {
      "type": "string"
    },
    "canonicalization_policy_ref": {
      "type": "string"
    },
    "hash_algorithm": {
      "type": "string",
      "const": "sha256"
    },
    "result_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "expected_diagnostic_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_refusal_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "support_claim": {
      "type": "boolean",
      "const": false
    }
  },
  "additionalProperties": true
}
