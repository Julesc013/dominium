{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.service.descriptor.schema.v1",
  "title": "Dominium Service Descriptor",
  "type": "object",
  "required": ["service_id", "service_kind", "owner", "version", "stability", "public_surface_ref", "commands_exposed", "result_schema_refs", "refusal_code_refs", "diagnostic_code_refs", "capability_refs", "provider_kinds_allowed", "determinism_class", "authority_class", "artifact_inputs", "artifact_outputs", "replay_impact", "execution_model", "conformance_suite_refs", "replacement_policy_ref", "deprecation_policy_ref"],
  "properties": {
    "service_id": {"type": "string", "pattern": "^(domino|dominium)\\.service\\.[a-z0-9][a-z0-9_.-]*$"},
    "service_kind": {"type": "string"},
    "owner": {"type": "string"},
    "version": {"type": "string"},
    "stability": {"type": "string"},
    "public_surface_ref": {"type": "string"},
    "commands_consumed": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "commands_exposed": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "result_schema_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "refusal_code_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "diagnostic_code_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "capability_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "provider_kinds_allowed": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "determinism_class": {"type": "string"},
    "authority_class": {"type": "string"},
    "artifact_inputs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "artifact_outputs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "replay_impact": {"type": "string"},
    "thread_model": {"type": "string"},
    "execution_model": {"type": "string"},
    "conformance_suite_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "replacement_policy_ref": {"type": "string"},
    "deprecation_policy_ref": {"type": "string"},
    "support_claim": {"type": "boolean"},
    "fallback_behavior": {"type": "string"},
    "refusal_behavior": {"type": "string"},
    "evidence_policy": {"type": "string"},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
