{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.governance.doctrine_recovery_matrix.schema.v1",
  "title": "Dominium Doctrine Recovery Matrix Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "stability",
    "status",
    "non_canonical_notice",
    "binding_sources",
    "authority_order",
    "drift_kinds",
    "recovery_actions",
    "review_gates",
    "protected_roots",
    "matrix"
  ],
  "properties": {
    "schema_id": {
      "const": "dominium.governance.doctrine_recovery_matrix.v1"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "stability": {
      "enum": [
        "provisional",
        "stable"
      ]
    },
    "status": {
      "const": "derived_non_canonical"
    },
    "non_canonical_notice": {
      "type": "string",
      "minLength": 20
    },
    "binding_sources": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/repo_path"
      }
    },
    "authority_order": {
      "type": "array",
      "minItems": 6,
      "items": {
        "$ref": "#/$defs/authority_source"
      }
    },
    "drift_kinds": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/drift_kind"
      }
    },
    "recovery_actions": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/recovery_action"
      }
    },
    "review_gates": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/review_gate"
      }
    },
    "protected_roots": {
      "type": "array",
      "minItems": 8,
      "items": {
        "$ref": "#/$defs/protected_root"
      }
    },
    "matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/matrix_entry"
      }
    }
  },
  "$defs": {
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^[A-Za-z]:|^/"
      }
    },
    "authority_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rank",
        "path",
        "authority_class",
        "disposition"
      ],
      "properties": {
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "path": {
          "$ref": "#/$defs/repo_path"
        },
        "authority_class": {
          "type": "string",
          "minLength": 3
        },
        "disposition": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "drift_kind": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "default_recovery_action"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "description": {
          "type": "string",
          "minLength": 10
        },
        "default_recovery_action": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        }
      }
    },
    "recovery_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "allowed_mutation_targets",
        "forbidden_mutation_targets",
        "default_review_gate"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "description": {
          "type": "string",
          "minLength": 10
        },
        "allowed_mutation_targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_mutation_targets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/repo_path"
          }
        },
        "default_review_gate": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        }
      }
    },
    "review_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "trigger",
        "required_output"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "trigger": {
          "type": "string",
          "minLength": 10
        },
        "required_output": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "protected_root": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "protection_reason",
        "default_recovery_action",
        "review_gate"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/repo_path"
        },
        "protection_reason": {
          "type": "string",
          "minLength": 10
        },
        "default_recovery_action": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "review_gate": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        }
      }
    },
    "matrix_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "surface_label",
        "authority_domain",
        "authority_tier",
        "source_paths",
        "protected_roots",
        "owned_meaning",
        "drift_cases"
      ],
      "properties": {
        "surface_id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "surface_label": {
          "type": "string",
          "minLength": 3
        },
        "authority_domain": {
          "enum": [
            "semantic",
            "structural",
            "compatibility",
            "release_distribution",
            "planning",
            "governance_execution",
            "evidence"
          ]
        },
        "authority_tier": {
          "type": "string",
          "minLength": 3
        },
        "source_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/repo_path"
          }
        },
        "protected_roots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/repo_path"
          }
        },
        "owned_meaning": {
          "type": "string",
          "minLength": 10
        },
        "drift_cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/drift_case"
          }
        }
      }
    },
    "drift_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drift_kind",
        "when",
        "disposition",
        "recovery_action",
        "review_gate"
      ],
      "properties": {
        "drift_kind": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "when": {
          "type": "string",
          "minLength": 10
        },
        "disposition": {
          "type": "string",
          "minLength": 10
        },
        "recovery_action": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "review_gate": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        }
      }
    }
  }
}
