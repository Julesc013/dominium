{
  "schema_version": "dominium.aide.workflow_law.v1",
  "law_id": "dominium.aide.workflow_law.v1",
  "status": "provisional",
  "introduced_by": "AIDE-WORKFLOW-LAW-01",
  "owner": "aide.control_plane",
  "stability": "provisional",
  "principle": "development_non_blocking_promotion_evidence_blocked",
  "summary": "AIDE work may make bounded progress on task, repair, dev, and checkpoint branches, but promotion to main requires checkpointed evidence, classified warnings, and review.",
  "source_refs": [
    "AGENTS.md",
    ".aide/policy/workflow_law.md",
    ".aide/policy/branch_roles.md",
    ".aide/policy/task_lifecycle.md",
    ".aide/policy/blocker_taxonomy.md",
    ".aide/policy/dirty_worktree_policy.md",
    ".aide/policy/parallel_execution_law.md",
    ".aide/policy/evidence_requirements.md",
    ".aide/policy/warning_acceptance_policy.md",
    ".aide/policies/branch-roles.yaml",
    ".aide/policies/git-workflow.yaml",
    ".aide/policies/work-units.yaml",
    ".aide/policies/recovery.yaml",
    ".aide/policies/promotion-rules.yaml",
    ".aide/policies/workunit-sizing.yaml",
    "docs/repo/audits/PRODUCT_SPINE_REVIEW_01.md"
  ],
  "branch_roles": [
    {
      "role": "origin/main",
      "purpose": "remote canonical baseline",
      "promotion_eligibility": "canonical_target_only_after_checkpoint_or_reviewed_hotfix"
    },
    {
      "role": "origin/dev",
      "purpose": "remote integration baseline when present",
      "promotion_eligibility": "checkpoint_source_after_integration_evidence"
    },
    {
      "role": "local/dev",
      "purpose": "local integration branch, not canonical truth",
      "promotion_eligibility": "checkpoint_candidate_only"
    },
    {
      "role": "task/<task-id>",
      "purpose": "bounded WorkUnit execution lane",
      "promotion_eligibility": "merge_candidate_to_dev_after_task_evidence"
    },
    {
      "role": "repair/<task-id>",
      "purpose": "bounded blocker repair lane",
      "promotion_eligibility": "merge_candidate_to_task_or_dev_after_blocker_resolution"
    },
    {
      "role": "checkpoint/<wave-id>",
      "purpose": "temporary integration proof branch",
      "promotion_eligibility": "reviewed_main_candidate_after_checkpoint_gate"
    },
    {
      "role": "quarantine/<reason>",
      "purpose": "risk isolation branch",
      "promotion_eligibility": "not_promotable_until_risk_disposition_and_revalidation"
    },
    {
      "role": "experiment/<name>",
      "purpose": "optional exploratory non-promotional branch",
      "promotion_eligibility": "not_promotable"
    }
  ],
  "lifecycle_states": [
    "PROPOSED",
    "READY",
    "RUNNING",
    "DONE_LOCAL",
    "PARTIAL",
    "BLOCKED_REPAIRABLE",
    "BLOCKED_MISSING_PREREQ",
    "BLOCKED_NEEDS_DECISION",
    "BLOCKED_UNSAFE",
    "REPAIR_QUEUED",
    "RESUME_READY",
    "MERGE_CANDIDATE",
    "MERGED_TO_DEV",
    "CHECKPOINT_CANDIDATE",
    "CHECKPOINT_REPAIR",
    "PROMOTED_TO_MAIN",
    "QUARANTINED",
    "SUPERSEDED"
  ],
  "main_promotable_states": [
    "PROMOTED_TO_MAIN"
  ],
  "dev_allowed_states": [
    "PARTIAL",
    "BLOCKED_REPAIRABLE",
    "BLOCKED_MISSING_PREREQ",
    "BLOCKED_NEEDS_DECISION",
    "REPAIR_QUEUED",
    "RESUME_READY",
    "MERGE_CANDIDATE",
    "MERGED_TO_DEV",
    "CHECKPOINT_CANDIDATE",
    "CHECKPOINT_REPAIR",
    "SUPERSEDED"
  ],
  "blocker_classes": [
    {
      "id": "dirty_worktree_unrelated",
      "severity": "warning",
      "default_action": "continue_without_staging_unrelated_files",
      "behavior": "continue"
    },
    {
      "id": "dirty_worktree_same_task",
      "severity": "info",
      "default_action": "continue_as_same_task_evidence",
      "behavior": "continue"
    },
    {
      "id": "merge_conflict",
      "severity": "error",
      "default_action": "resolve_if_owned_else_create_repair_task",
      "behavior": "repair"
    },
    {
      "id": "validator_failure_repairable",
      "severity": "error",
      "default_action": "repair_in_scope_and_rerun_targeted_validation",
      "behavior": "repair"
    },
    {
      "id": "validator_failure_policy",
      "severity": "error",
      "default_action": "create_policy_or_prerequisite_task",
      "behavior": "create_prerequisite"
    },
    {
      "id": "missing_prerequisite",
      "severity": "error",
      "default_action": "create_prerequisite_task",
      "behavior": "create_prerequisite"
    },
    {
      "id": "missing_tool",
      "severity": "warning",
      "default_action": "use_equivalent_existing_tool_or_create_prerequisite",
      "behavior": "create_prerequisite"
    },
    {
      "id": "missing_connector",
      "severity": "warning",
      "default_action": "record_missing_connector_and_use_allowed_fallback_or_ask_human",
      "behavior": "ask_human"
    },
    {
      "id": "missing_capability",
      "severity": "error",
      "default_action": "create_capability_prerequisite_task",
      "behavior": "create_prerequisite"
    },
    {
      "id": "missing_secret",
      "severity": "error",
      "default_action": "stop_without_recording_secret_value",
      "behavior": "stop"
    },
    {
      "id": "unsafe_operation",
      "severity": "error",
      "default_action": "stop_and_report_exact_risk",
      "behavior": "stop"
    },
    {
      "id": "destructive_git_required",
      "severity": "error",
      "default_action": "ask_human_before_destructive_git",
      "behavior": "ask_human"
    },
    {
      "id": "architecture_decision_required",
      "severity": "error",
      "default_action": "ask_human_or_create_decision_task",
      "behavior": "ask_human"
    },
    {
      "id": "human_review_required",
      "severity": "error",
      "default_action": "stop_at_review_gate",
      "behavior": "ask_human"
    },
    {
      "id": "test_timeout",
      "severity": "warning",
      "default_action": "bounded_retry_then_classify",
      "behavior": "repair"
    },
    {
      "id": "flaky_test_suspected",
      "severity": "warning",
      "default_action": "rerun_bounded_sample_and_record_disposition",
      "behavior": "repair"
    },
    {
      "id": "generated_artifact_drift",
      "severity": "warning",
      "default_action": "refresh_in_scope_or_create_repair_task",
      "behavior": "repair"
    },
    {
      "id": "stale_queue_state",
      "severity": "error",
      "default_action": "reconcile_if_assigned_else_stop_for_coordination",
      "behavior": "repair"
    },
    {
      "id": "stale_context_packet",
      "severity": "warning",
      "default_action": "refresh_if_assigned_else_record_stale_packet",
      "behavior": "repair"
    },
    {
      "id": "source_authority_conflict",
      "severity": "error",
      "default_action": "stop_and_escalate_without_inventing_winner",
      "behavior": "stop"
    }
  ],
  "dirty_worktree_policy": {
    "do_not_stop_merely_because_dirty": true,
    "classifications": [
      "ignored/generated/transient",
      "prior task evidence",
      "unstaged unrelated changes",
      "same-task continuation",
      "overlapping another-task changes",
      "merge conflict markers",
      "global AIDE/status file conflict"
    ],
    "forbidden_actions": [
      "stage unrelated files",
      "overwrite unrelated user changes",
      "run destructive git commands",
      "fabricate clean state"
    ]
  },
  "warning_policy": {
    "known_warnings_may_pass_on_dev": true,
    "new_warnings_require_classification": true,
    "warnings_must_not_be_hidden": true,
    "main_acceptance_requires_checkpoint_policy": true,
    "full_ctest": "full_gate_debt_until_resolved",
    "fixture_only_warning": "must_not_be_called_implemented"
  },
  "evidence_requirements": {
    "required_for_every_task": [
      "changed_files",
      "commands_run",
      "validation_output",
      "warnings",
      "blockers",
      "evidence_refs",
      "commit_hash_when_committed",
      "next_action"
    ],
    "task_types": [
      "coordinator/status task",
      "contract/schema task",
      "validator task",
      "product slice",
      "runtime implementation slice",
      "Workbench/presentation slice",
      "structure/move task",
      "repair task",
      "checkpoint task",
      "promotion task"
    ]
  },
  "promotion_gates": {
    "task_to_dev": [
      "scope evidence exists",
      "targeted validation passes or warnings are classified",
      "forbidden paths are not touched",
      "unrelated dirty work is preserved"
    ],
    "dev_to_checkpoint": [
      "selected task branches or dev integration identified",
      "merge conflicts resolved with evidence",
      "checkpoint validation plan recorded"
    ],
    "checkpoint_to_main": [
      "checkpoint gate passes or accepted warning disposition is explicit",
      "public surface and dependency direction strict pass when relevant",
      "full CTest disposition is recorded",
      "broad feature blockers remain visible",
      "promotion is reviewed and non-automatic"
    ]
  },
  "parallel_execution": {
    "large_parallel_execution_authorized": false,
    "limited_parallel_prompt_generation_authorized": true,
    "limited_parallel_task_execution_authorized": false,
    "recommended_parallel_candidate": "PRESENTATION-CONTRACT-01",
    "before_workunit_schema": {
      "recommended_concurrent_tasks": 2,
      "maximum_concurrent_tasks": 4
    },
    "large_parallelism_requires": [
      "AIDE-WORKFLOW-LAW-01",
      "AIDE-WORKUNIT-SCHEMA-01",
      "AIDE-DEV-MAIN-POLICY-01",
      "checkpoint/review policy",
      "repair/resume policy"
    ]
  },
  "closeout_queue": {
    "current_task": "AIDE-WORKFLOW-LAW-01",
    "status": "PASS_WITH_WARNINGS",
    "next_task": "AIDE-WORKUNIT-SCHEMA-01",
    "alternate_next_task": "AIDE-DEV-MAIN-POLICY-01",
    "secondary_follow_up": "AIDE-CHECKPOINT-LOOP-01",
    "recommended_parallel_candidate": "PRESENTATION-CONTRACT-01"
  },
  "non_goals": [
    "no full scheduler",
    "no automatic branch/worktree manager",
    "no automatic merge or promotion engine",
    "no repair engine",
    "no Workbench Agent Board",
    "no product runtime implementation",
    "no package runtime",
    "no replay runtime",
    "no provider runtime",
    "no runtime module loader",
    "no gameplay",
    "no renderer or native GUI",
    "no release publication"
  ]
}
