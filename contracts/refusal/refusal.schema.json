{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.refusal.refusal_schema.v1",
  "title": "Dominium Refusal",
  "type": "object",
  "required": ["code", "owner", "reason", "recovery", "stability"],
  "additionalProperties": true,
  "properties": {
    "refusal_id": {
      "type": "string",
      "pattern": "^dominium\\.refusal\\.[a-z0-9][a-z0-9_.-]+$"
    },
    "code": {
      "type": "string",
      "pattern": "^dominium\\.refusal\\.[a-z0-9][a-z0-9_.-]+$"
    },
    "owner": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "stability": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "recovery": {
      "type": ["string", "object"]
    },
    "diagnostic_codes": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "related_diagnostic_codes": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "related_capabilities": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "related_commands": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "proof": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "evidence_reference": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}
