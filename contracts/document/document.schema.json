{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.document.document_schema.v1",
  "title": "Dominium Result Document",
  "type": "object",
  "required": [
    "document_id",
    "owner",
    "schema_id",
    "content"
  ],
  "additionalProperties": true,
  "properties": {
    "document_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "schema_id": {
      "type": "string"
    },
    "content": {},
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
