{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dominium.document.patch_transaction_schema.v1",
  "title": "Dominium Document Patch Transaction",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "stability",
    "transaction_id",
    "document_id",
    "document_schema_id",
    "expected_content_hash",
    "authority",
    "operations"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "dominium.document.patch_transaction.v1"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "stability": {
      "type": "string",
      "const": "provisional"
    },
    "transaction_id": {
      "type": "string",
      "pattern": "^dominium\\.document\\.patch_txn\\.[a-z0-9][a-z0-9_.-]*$"
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "document_schema_id": {
      "type": "string",
      "minLength": 1
    },
    "expected_content_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "authority": {
      "type": "object",
      "required": [
        "authority_origin",
        "law_profile_id",
        "actor_id"
      ],
      "additionalProperties": false,
      "properties": {
        "authority_origin": {
          "type": "string",
          "minLength": 1
        },
        "law_profile_id": {
          "type": "string",
          "minLength": 1
        },
        "actor_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "$ref": "#/$defs/operation"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "path": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "integer",
            "minimum": 0
          }
        ]
      }
    },
    "mutation_path": {
      "allOf": [
        {
          "$ref": "#/$defs/path"
        },
        {
          "minItems": 1
        }
      ]
    },
    "json_value": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/json_value"
          }
        },
        {
          "type": "object",
          "propertyNames": {
            "minLength": 1
          },
          "additionalProperties": {
            "$ref": "#/$defs/json_value"
          }
        }
      ]
    },
    "operation": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "op",
            "path",
            "value"
          ],
          "additionalProperties": false,
          "properties": {
            "op": {
              "type": "string",
              "const": "test"
            },
            "path": {
              "$ref": "#/$defs/path"
            },
            "value": {
              "$ref": "#/$defs/json_value"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "op",
            "path",
            "value"
          ],
          "additionalProperties": false,
          "properties": {
            "op": {
              "type": "string",
              "const": "add"
            },
            "path": {
              "$ref": "#/$defs/mutation_path"
            },
            "value": {
              "$ref": "#/$defs/json_value"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "op",
            "path",
            "value"
          ],
          "additionalProperties": false,
          "properties": {
            "op": {
              "type": "string",
              "const": "replace"
            },
            "path": {
              "$ref": "#/$defs/mutation_path"
            },
            "value": {
              "$ref": "#/$defs/json_value"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "op",
            "path"
          ],
          "additionalProperties": false,
          "properties": {
            "op": {
              "type": "string",
              "const": "remove"
            },
            "path": {
              "$ref": "#/$defs/mutation_path"
            }
          }
        }
      ]
    }
  }
}
