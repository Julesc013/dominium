{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Domain Contract Schema",
  "version": "1.0.0",
  "x-schema-id": "dominium.schema.reality.domain_contract",
  "x-stability": "stable",
  "description": "Canonical Dominium domain contract structure. Domain contracts inherit the universal reality framework and define lawful domain shape without redefining core reality semantics locally.",
  "x-doc-ref": [
    "specs/reality/SPEC_DOMINIUM_UNIVERSAL_REALITY_FRAMEWORK.md",
    "specs/reality/SPEC_DOMAIN_CONTRACT_TEMPLATE.md"
  ],
  "type": "object",
  "required": [
    "contract_kind",
    "schema_version",
    "inherits_from_framework",
    "identity",
    "scope",
    "primitive_substrate",
    "process_model",
    "recognition_model",
    "affordance_model",
    "formalization_model",
    "representation_model",
    "failure_model",
    "verification",
    "observation_bindings",
    "interface_bindings",
    "compatibility_and_stability",
    "civilization_scaling_path",
    "mod_extension_path",
    "extensions"
  ],
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "stringArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    },
    "interactionBinding": {
      "type": "object",
      "required": [
        "support_state",
        "interaction_modes",
        "observation_dependencies",
        "refusal_conditions",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "support_state": {
          "type": "string",
          "enum": [
            "supported",
            "conditional",
            "not_supported"
          ]
        },
        "interaction_modes": {
          "$ref": "#/$defs/stringArray"
        },
        "observation_dependencies": {
          "$ref": "#/$defs/stringArray"
        },
        "refusal_conditions": {
          "$ref": "#/$defs/stringArray"
        },
        "notes": {
          "$ref": "#/$defs/stringArray"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    }
  },
  "properties": {
    "contract_kind": {
      "type": "string",
      "const": "domain_contract"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "inherits_from_framework": {
      "type": "object",
      "required": [
        "artifact_id",
        "minimum_version",
        "prohibited_local_redefinitions",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "type": "string",
          "const": "spec.dominium.universal_reality_framework"
        },
        "minimum_version": {
          "$ref": "#/$defs/semver"
        },
        "prohibited_local_redefinitions": {
          "$ref": "#/$defs/stringArray"
        },
        "notes": {
          "$ref": "#/$defs/stringArray"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "identity": {
      "type": "object",
      "required": [
        "domain_id",
        "domain_name",
        "domain_summary",
        "domain_classes",
        "phenomenon_scope",
        "authority_roots",
        "owned_truth_classes",
        "declared_related_roots"
      ],
      "additionalProperties": false,
      "properties": {
        "domain_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain_name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain_summary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "domain_classes": {
          "$ref": "#/$defs/stringArray"
        },
        "phenomenon_scope": {
          "$ref": "#/$defs/stringArray"
        },
        "authority_roots": {
          "$ref": "#/$defs/stringArray"
        },
        "owned_truth_classes": {
          "$ref": "#/$defs/stringArray"
        },
        "declared_related_roots": {
          "$ref": "#/$defs/stringArray"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "scope": {
      "type": "object",
      "required": [
        "governs",
        "boundary_claims",
        "explicit_non_goals",
        "overlap_statement",
        "known_overlap_zones",
        "ownership_notes"
      ],
      "additionalProperties": false,
      "properties": {
        "governs": {
          "$ref": "#/$defs/stringArray"
        },
        "boundary_claims": {
          "$ref": "#/$defs/stringArray"
        },
        "explicit_non_goals": {
          "$ref": "#/$defs/stringArray"
        },
        "overlap_statement": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "known_overlap_zones": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "surface",
              "status",
              "notes"
            ],
            "additionalProperties": false,
            "properties": {
              "surface": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "status": {
                "type": "string",
                "enum": [
                  "declared_overlap",
                  "quarantine_sensitive",
                  "none_declared"
                ]
              },
              "notes": {
                "$ref": "#/$defs/stringArray"
              },
              "extensions": {
                "$ref": "#/$defs/extensions"
              }
            }
          }
        },
        "ownership_notes": {
          "$ref": "#/$defs/stringArray"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "primitive_substrate": {
      "type": "object",
      "required": [
        "primitive_units",
        "truth_bearing_entities",
        "primitive_invariants",
        "primitive_refusal_conditions",
        "higher_order_semantics_not_implicit",
        "source_roots",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "primitive_units": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "primitive_id",
              "summary",
              "truth_role",
              "preserved_properties",
              "notes"
            ],
            "additionalProperties": false,
            "properties": {
              "primitive_id": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "summary": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "truth_role": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "preserved_properties": {
                "$ref": "#/$defs/stringArray"
              },
              "notes": {
                "$ref": "#/$defs/stringArray"
              },
              "extensions": {
                "$ref": "#/$defs/extensions"
              }
            }
          }
        },
        "truth_bearing_entities": {
          "$ref": "#/$defs/stringArray"
        },
        "primitive_invariants": {
          "$ref": "#/$defs/stringArray"
        },
        "primitive_refusal_conditions": {
          "$ref": "#/$defs/stringArray"
        },
        "higher_order_semantics_not_implicit": {
          "type": "boolean",
          "const": true
        },
        "source_roots": {
          "$ref": "#/$defs/stringArray"
        },
        "notes": {
          "$ref": "#/$defs/stringArray"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "process_model": {
      "type": "object",
      "required": [
        "truth_mutation_rule",
        "processes",
        "process_invariants",
        "process_scope_notes"
      ],
      "additionalProperties": false,
      "properties": {
        "truth_mutation_rule": {
          "type": "string",
          "const": "truth_mutation_only_through_processes"
        },
        "processes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "process_id",
              "summary",
              "inputs",
              "outputs",
              "invariants",
              "refusal_conditions",
              "deterministic_notes"
            ],
            "additionalProperties": false,
            "properties": {
              "process_id": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "summary": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "inputs": {
                "$ref": "#/$defs/stringArray"
              },
              "outputs": {
                "$ref": "#/$defs/stringArray"
              },
              "invariants": {
                "$ref": "#/$defs/stringArray"
              },
              "refusal_conditions": {
                "$ref": "#/$defs/stringArray"
              },
              "deterministic_notes": {
                "$ref": "#/$defs/stringArray"
              },
              "extensions": {
                "$ref": "#/$defs/extensions"
              }
            }
          }
        },
        "process_invariants": {
          "$ref": "#/$defs/stringArray"
        },
        "process_scope_notes": {
          "$ref": "#/$defs/stringArray"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "recognition_model": {
      "type": "object",
      "required": [
        "recognitions",
        "recognitions_cannot_replace_primitives",
        "recognition_notes"
      ],
      "additionalProperties": false,
      "properties": {
        "recognitions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "recognition_id",
              "summary",
              "derives_from",
              "validity_conditions",
              "observer_dependence"
            ],
            "additionalProperties": false,
            "properties": {
              "recognition_id": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "summary": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "derives_from": {
                "$ref": "#/$defs/stringArray"
              },
              "validity_conditions": {
                "$ref": "#/$defs/stringArray"
              },
              "observer_dependence": {
                "type": "string",
                "enum": [
                  "none",
                  "epistemic_filtered",
                  "contextual"
                ]
              },
              "notes": {
                "$ref": "#/$defs/stringArray"
              },
              "extensions": {
                "$ref": "#/$defs/extensions"
              }
            }
          }
        },
        "recognitions_cannot_replace_primitives": {
          "type": "boolean",
          "const": true
        },
        "recognition_notes": {
          "$ref": "#/$defs/stringArray"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "affordance_model": {
      "type": "object",
      "required": [
        "affordances",
        "law_gated_affordances_only",
        "affordance_notes"
      ],
      "additionalProperties": false,
      "properties": {
        "affordances": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "affordance_id",
              "summary",
              "actors",
              "authority_conditions",
              "process_refs",
              "capability_refs",
              "failure_or_refusal_conditions"
            ],
            "additionalProperties": false,
            "properties": {
              "affordance_id": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "summary": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "actors": {
                "$ref": "#/$defs/stringArray"
              },
              "authority_conditions": {
                "$ref": "#/$defs/stringArray"
              },
              "process_refs": {
                "$ref": "#/$defs/stringArray"
              },
              "capability_refs": {
                "$ref": "#/$defs/stringArray"
              },
              "failure_or_refusal_conditions": {
                "$ref": "#/$defs/stringArray"
              },
              "extensions": {
                "$ref": "#/$defs/extensions"
              }
            }
          }
        },
        "law_gated_affordances_only": {
          "type": "boolean",
          "const": true
        },
        "affordance_notes": {
          "$ref": "#/$defs/stringArray"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "formalization_model": {
      "type": "object",
      "required": [
        "formalization_policy",
        "formalizations",
        "formalization_notes"
      ],
      "additionalProperties": false,
      "properties": {
        "formalization_policy": {
          "type": "string",
          "enum": [
            "none_declared",
            "defined"
          ]
        },
        "formalizations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "formalization_id",
              "artifact_kind",
              "summary",
              "activation_conditions",
              "normative_refs"
            ],
            "additionalProperties": false,
            "properties": {
              "formalization_id": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "artifact_kind": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "summary": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "activation_conditions": {
                "$ref": "#/$defs/stringArray"
              },
              "normative_refs": {
                "$ref": "#/$defs/stringArray"
              },
              "notes": {
                "$ref": "#/$defs/stringArray"
              },
              "extensions": {
                "$ref": "#/$defs/extensions"
              }
            }
          }
        },
        "formalization_notes": {
          "$ref": "#/$defs/stringArray"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "formalization_policy": {
                "const": "defined"
              }
            }
          },
          "then": {
            "properties": {
              "formalizations": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "representation_model": {
      "type": "object",
      "required": [
        "representations",
        "representation_invariants",
        "substitution_policy",
        "representation_notes"
      ],
      "additionalProperties": false,
      "properties": {
        "representations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "representation_id",
              "representation_class",
              "summary",
              "preserved_invariants",
              "causal_horizon",
              "expansion_triggers"
            ],
            "additionalProperties": false,
            "properties": {
              "representation_id": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "representation_class": {
                "type": "string",
                "enum": [
                  "primitive",
                  "recognized",
                  "formalized",
                  "substituted",
                  "macro",
                  "micro",
                  "other"
                ]
              },
              "summary": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "preserved_invariants": {
                "$ref": "#/$defs/stringArray"
              },
              "causal_horizon": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "observation_scope": {
                "$ref": "#/$defs/stringArray"
              },
              "expansion_triggers": {
                "$ref": "#/$defs/stringArray"
              },
              "notes": {
                "$ref": "#/$defs/stringArray"
              },
              "extensions": {
                "$ref": "#/$defs/extensions"
              }
            }
          }
        },
        "representation_invariants": {
          "$ref": "#/$defs/stringArray"
        },
        "substitution_policy": {
          "type": "object",
          "required": [
            "mode",
            "implicit_substitution_forbidden",
            "substitutions"
          ],
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "none_declared",
                "lawful_substitutions_defined"
              ]
            },
            "implicit_substitution_forbidden": {
              "type": "boolean",
              "const": true
            },
            "substitutions": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "substitution_id",
                  "from_representation",
                  "to_representation",
                  "preserved_invariants",
                  "continuity_conditions",
                  "causal_closure_horizon",
                  "activation_conditions",
                  "refusal_conditions"
                ],
                "additionalProperties": false,
                "properties": {
                  "substitution_id": {
                    "$ref": "#/$defs/nonEmptyString"
                  },
                  "from_representation": {
                    "$ref": "#/$defs/nonEmptyString"
                  },
                  "to_representation": {
                    "$ref": "#/$defs/nonEmptyString"
                  },
                  "preserved_invariants": {
                    "$ref": "#/$defs/stringArray"
                  },
                  "continuity_conditions": {
                    "$ref": "#/$defs/stringArray"
                  },
                  "causal_closure_horizon": {
                    "$ref": "#/$defs/nonEmptyString"
                  },
                  "activation_conditions": {
                    "$ref": "#/$defs/stringArray"
                  },
                  "refusal_conditions": {
                    "$ref": "#/$defs/stringArray"
                  },
                  "notes": {
                    "$ref": "#/$defs/stringArray"
                  },
                  "extensions": {
                    "$ref": "#/$defs/extensions"
                  }
                }
              }
            },
            "extensions": {
              "$ref": "#/$defs/extensions"
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "mode": {
                    "const": "lawful_substitutions_defined"
                  }
                }
              },
              "then": {
                "properties": {
                  "substitutions": {
                    "minItems": 1
                  }
                }
              }
            }
          ]
        },
        "representation_notes": {
          "$ref": "#/$defs/stringArray"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "failure_model": {
      "type": "object",
      "required": [
        "ordinary_vs_failure_boundary",
        "failure_modes",
        "degradation_rules",
        "failure_notes"
      ],
      "additionalProperties": false,
      "properties": {
        "ordinary_vs_failure_boundary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "failure_modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "failure_id",
              "failure_class",
              "trigger_conditions",
              "effect_on_truth",
              "effect_on_observation",
              "refusal_or_degradation_response",
              "recoverability"
            ],
            "additionalProperties": false,
            "properties": {
              "failure_id": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "failure_class": {
                "type": "string",
                "enum": [
                  "degraded",
                  "invalid",
                  "unsafe",
                  "unknown",
                  "external_absence",
                  "other"
                ]
              },
              "trigger_conditions": {
                "$ref": "#/$defs/stringArray"
              },
              "effect_on_truth": {
                "$ref": "#/$defs/stringArray"
              },
              "effect_on_observation": {
                "$ref": "#/$defs/stringArray"
              },
              "refusal_or_degradation_response": {
                "$ref": "#/$defs/stringArray"
              },
              "recoverability": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "extensions": {
                "$ref": "#/$defs/extensions"
              }
            }
          }
        },
        "degradation_rules": {
          "$ref": "#/$defs/stringArray"
        },
        "failure_notes": {
          "$ref": "#/$defs/stringArray"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "verification": {
      "type": "object",
      "required": [
        "invariants",
        "audit_surfaces",
        "replay_requirements",
        "determinism_requirements",
        "proof_artifacts",
        "verification_notes"
      ],
      "additionalProperties": false,
      "properties": {
        "invariants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "invariant_id",
              "statement",
              "checkability"
            ],
            "additionalProperties": false,
            "properties": {
              "invariant_id": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "statement": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "checkability": {
                "type": "string",
                "enum": [
                  "manual",
                  "static",
                  "runtime",
                  "schema",
                  "replay",
                  "hybrid"
                ]
              },
              "notes": {
                "$ref": "#/$defs/stringArray"
              },
              "extensions": {
                "$ref": "#/$defs/extensions"
              }
            }
          }
        },
        "audit_surfaces": {
          "$ref": "#/$defs/stringArray"
        },
        "replay_requirements": {
          "$ref": "#/$defs/stringArray"
        },
        "determinism_requirements": {
          "$ref": "#/$defs/stringArray"
        },
        "proof_artifacts": {
          "$ref": "#/$defs/stringArray"
        },
        "verification_notes": {
          "$ref": "#/$defs/stringArray"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "observation_bindings": {
      "type": "object",
      "required": [
        "truth_is_not_observation",
        "bindings",
        "observation_notes"
      ],
      "additionalProperties": false,
      "properties": {
        "truth_is_not_observation": {
          "type": "boolean",
          "const": true
        },
        "bindings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "binding_id",
              "observer_kind",
              "derived_from_truth_classes",
              "epistemic_artifacts",
              "channels",
              "redaction_or_quantization_rules"
            ],
            "additionalProperties": false,
            "properties": {
              "binding_id": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "observer_kind": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "derived_from_truth_classes": {
                "$ref": "#/$defs/stringArray"
              },
              "epistemic_artifacts": {
                "$ref": "#/$defs/stringArray"
              },
              "channels": {
                "$ref": "#/$defs/stringArray"
              },
              "redaction_or_quantization_rules": {
                "$ref": "#/$defs/stringArray"
              },
              "notes": {
                "$ref": "#/$defs/stringArray"
              },
              "extensions": {
                "$ref": "#/$defs/extensions"
              }
            }
          }
        },
        "observation_notes": {
          "$ref": "#/$defs/stringArray"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "interface_bindings": {
      "type": "object",
      "required": [
        "reality_is_interface_agnostic",
        "embodied_user",
        "abstract_planner",
        "ai_agent",
        "npc_actor",
        "system_actor",
        "interface_notes"
      ],
      "additionalProperties": false,
      "properties": {
        "reality_is_interface_agnostic": {
          "type": "boolean",
          "const": true
        },
        "embodied_user": {
          "$ref": "#/$defs/interactionBinding"
