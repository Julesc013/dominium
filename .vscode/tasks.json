{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build (Local)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "local"],
      "linux": {
        "args": ["--build", "--preset", "linux-gcc-dev"]
      },
      "osx": {
        "args": ["--build", "--preset", "macos-dev"]
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Test (Verify Fast)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "verify", "--target", "verify_fast"],
      "linux": {
        "args": ["--build", "--preset", "linux-verify", "--target", "verify_fast"]
      },
      "osx": {
        "args": ["--build", "--preset", "macos-verify", "--target", "verify_fast"]
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Release Check (Dry-Run)",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/repox/repox_release.py",
        "--repo-root",
        "${workspaceFolder}",
        "--kind",
        "beta",
        "--channel",
        "beta",
        "--dry-run",
        "--ctest-preset",
        "verify"
      ],
      "linux": {
        "args": [
          "scripts/repox/repox_release.py",
          "--repo-root",
          "${workspaceFolder}",
          "--kind",
          "beta",
          "--channel",
          "beta",
          "--dry-run",
          "--ctest-preset",
          "linux-verify"
        ]
      },
      "osx": {
        "args": [
          "scripts/repox/repox_release.py",
          "--repo-root",
          "${workspaceFolder}",
          "--kind",
          "beta",
          "--channel",
          "beta",
          "--dry-run",
          "--ctest-preset",
          "macos-verify"
        ]
      },
      "problemMatcher": []
    }
  ]
}
